{
  "bundle_id": "insurance_bundle",
  "domain": "insurance",
  "audience": ["executive", "actuary", "underwriter"],
  "version": "v1.0.0",
  "owner": "patrick",
  "tags": ["insurance", "underwriting", "claims", "premiums", "reserves"],
  "functions": [
    {
      "name": "SUMX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns the sum of an expression evaluated over a table."
    },
    {
      "name": "AVERAGEX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Calculates the average of an expression evaluated over a table."
    },
    {
      "name": "FILTER",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns a table that represents a subset of another table or expression."
    },
    {
      "name": "DISTINCTCOUNT",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Counts the number of distinct values in a column."
    },
    {
      "name": "DIVIDE",
      "class": "DAX-Logical",
      "badge": "🟧",
      "description": "Performs division and returns alternate result or BLANK() on division by 0."
    }
  ],
  "metrics": [
    {
      "node_id": "combined_ratio",
      "category": "underwriting_performance",
      "description": "Total of loss ratio and expense ratio - below 100% indicates profitable underwriting.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({claims_table}, {claims_paid}) + SUMX({expenses_table}, {underwriting_expenses}), SUMX({premiums_table}, {earned_premiums}))",
        "arguments": {
          "claims_table": "table:claims",
          "claims_paid": "field:amount",
          "expenses_table": "table:underwriting_expenses",
          "underwriting_expenses": "field:amount",
          "premiums_table": "table:earned_premiums",
          "earned_premiums": "field:amount"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "loss_ratio",
      "category": "claims_performance",
      "description": "Claims paid as a percentage of earned premiums.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({claims_table}, {claims_paid}), SUMX({premiums_table}, {earned_premiums}))",
        "arguments": {
          "claims_table": "table:claims",
          "claims_paid": "field:amount",
          "premiums_table": "table:earned_premiums",
          "earned_premiums": "field:amount"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "expense_ratio",
      "category": "efficiency",
      "description": "Underwriting expenses as a percentage of written premiums.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({expenses_table}, {underwriting_expenses}), SUMX({premiums_table}, {written_premiums}))",
        "arguments": {
          "expenses_table": "table:underwriting_expenses",
          "underwriting_expenses": "field:amount",
          "premiums_table": "table:written_premiums",
          "written_premiums": "field:amount"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "underwriting_profit",
      "category": "profitability",
      "description": "Net underwriting profit or loss.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "SUMX({premiums_table}, {earned_premiums}) - SUMX({claims_table}, {claims_paid}) - SUMX({expenses_table}, {underwriting_expenses})",
        "arguments": {
          "premiums_table": "table:earned_premiums",
          "earned_premiums": "field:amount",
          "claims_table": "table:claims",
          "claims_paid": "field:amount",
          "expenses_table": "table:underwriting_expenses",
          "underwriting_expenses": "field:amount"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "retention_ratio",
      "category": "underwriting",
      "description": "Percentage of business retained vs. ceded to reinsurers.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({premiums_table}, {net_premiums}), SUMX({premiums_table}, {gross_premiums}))",
        "arguments": {
          "premiums_table": "table:premiums",
          "net_premiums": "field:net_amount",
          "gross_premiums": "field:gross_amount"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "claims_frequency",
      "category": "claims_performance",
      "description": "Average number of claims per policy or per exposure unit.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(DISTINCTCOUNT({claims_table}, {claim_id}), SUMX({policies_table}, {exposure_units}))",
        "arguments": {
          "claims_table": "table:claims",
          "claim_id": "field:id",
          "policies_table": "table:policies",
          "exposure_units": "field:exposure_amount"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["DISTINCTCOUNT", "SUMX", "DIVIDE"],
      "governance": { "status": "draft" }
    },
    {
      "node_id": "claims_severity",
      "category": "claims_performance",
      "description": "Average claim amount per claim.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({claims_table}, {claim_amount}), DISTINCTCOUNT({claims_table}, {claim_id}))",
        "arguments": {
          "claims_table": "table:claims",
          "claim_amount": "field:amount",
          "claim_id": "field:id"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DISTINCTCOUNT", "DIVIDE"],
      "governance": { "status": "draft" }
    },
    {
      "node_id": "reserve_adequacy_ratio",
      "category": "reserving",
      "description": "Outstanding reserves as a percentage of ultimate expected losses.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({reserves_table}, {outstanding_reserves}), SUMX({actuarial_table}, {ultimate_losses}))",
        "arguments": {
          "reserves_table": "table:loss_reserves",
          "outstanding_reserves": "field:amount",
          "actuarial_table": "table:actuarial_projections",
          "ultimate_losses": "field:projected_amount"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "policyholder_surplus_ratio",
      "category": "solvency",
      "description": "Policyholder surplus as a percentage of total liabilities.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({surplus_table}, {policyholder_surplus}), SUMX({liabilities_table}, {total_liabilities}))",
        "arguments": {
          "surplus_table": "table:policyholder_surplus",
          "policyholder_surplus": "field:amount",
          "liabilities_table": "table:liabilities",
          "total_liabilities": "field:amount"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "return_on_equity",
      "category": "profitability",
      "description": "Net income as a percentage of policyholder surplus.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({income_table}, {net_income}), AVERAGEX({surplus_table}, {policyholder_surplus}))",
        "arguments": {
          "income_table": "table:net_income",
          "net_income": "field:amount",
          "surplus_table": "table:policyholder_surplus",
          "policyholder_surplus": "field:amount"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "AVERAGEX", "DIVIDE"],
      "governance": { "status": "golden" }
    }
  ]
}
