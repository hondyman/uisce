# Cube.js Semantic Layer - Environment Variables

# API Secret (change in production)
CUBEJS_API_SECRET=your-secret-key-change-me

# StarRocks (Hot Tier)
STARROCKS_HOST=localhost
STARROCKS_PORT=9030
STARROCKS_USER=root
STARROCKS_PASSWORD=your-starrocks-password
STARROCKS_DATABASE=semantic_layer

# Trino (Cold Tier - Iceberg/Parquet)
TRINO_HOST=localhost
TRINO_PORT=8080
TRINO_CATALOG=iceberg
TRINO_SCHEMA=default

# Development Mode
CUBEJS_DEV_MODE=true

# Rollup-Only Enforcement (Governance)
CUBEJS_ROLLUP_ONLY=true
