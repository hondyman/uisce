# AI Trade Reconciliation Backend - Environment Configuration
# Copy this file to .env and adjust values as needed
# Example configuration with all Phase 2/3 features enabled

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=atr-db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=alpha
DATABASE_URL=postgres://postgres:postgres@atr-db:5432/alpha?sslmode=disable

# ============================================================================
# TEMPORAL WORKFLOW CONFIGURATION
# ============================================================================
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=reconciliation

# ============================================================================
# API SERVER CONFIGURATION
# ============================================================================
PORT=8080

# Logging & Debug
GIN_MODE=debug          # debug, release
LOG_LEVEL=info          # debug, info, warn, error

# Server timeouts
REQUEST_TIMEOUT=30s
READ_TIMEOUT=15s
WRITE_TIMEOUT=30s

# ============================================================================
# PHASE 3: CACHING LAYER CONFIGURATION
# ============================================================================
# Cache enables 50-100x faster queries for repeated template access
# Typical cache hit rate: 70-90%

CACHE_ENABLED=true
CACHE_TTL=300s          # 5 minutes (adjust based on data freshness needs)
                        # 60s = more fresh, 600s = higher hit rate

# Cache size limits (optional)
CACHE_MAX_TEMPLATES=1000
CACHE_MAX_MEMORY=100MB

# ============================================================================
# PHASE 3: AUDIT LOGGING CONFIGURATION
# ============================================================================
# Audit logging creates a compliance trail of all changes
# Async queue worker: zero impact to main request latency

AUDIT_ENABLED=true
AUDIT_QUEUE_SIZE=1000   # Queue capacity (adjust for high-volume systems)
                        # Low volume: 100-500
                        # Medium: 1000-5000
                        # High volume: 5000-50000

# Audit retention
AUDIT_RETENTION_DAYS=365    # Keep audit logs for 1 year

# ============================================================================
# PHASE 3: PERFORMANCE METRICS CONFIGURATION
# ============================================================================
# Metrics collection enables real-time performance monitoring
# Thread-safe collection with <0.1ms overhead per operation

METRICS_ENABLED=true

# Metrics export
METRICS_PORT=9090           # Prometheus scrape port
METRICS_PATH=/metrics       # Prometheus metrics endpoint

# ============================================================================
# EXTERNAL API KEYS
# ============================================================================
# Optional: Add any required API keys here

XAI_API_KEY=
# Add other API keys as needed

# ============================================================================
# MONITORING CONFIGURATION (Optional)
# ============================================================================
# Enable monitoring with: docker-compose --profile monitoring up

PROMETHEUS_ENABLED=false
GRAFANA_ENABLED=false
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ============================================================================
# DEVELOPMENT / TESTING FLAGS
# ============================================================================

# Enable debug endpoints
DEBUG_ENABLED=false

# Mock external services (for testing)
MOCK_TEMPORAL=false
MOCK_EXTERNAL_APIS=false

# Database seeding
DB_SEED_DATA=false      # Load sample data on startup

# ============================================================================
# DOCKER COMPOSE SPECIFIC
# ============================================================================

# Project name (used for container names)
COMPOSE_PROJECT_NAME=atr

# Use this to enable monitoring services
# COMPOSE_PROFILES=monitoring
