// GetQueryTemplate retrieves the full details of a single query template.
// This is a mock implementation.
func (s *SemanticService) GetQueryTemplate(ctx context.Context, templateID uuid.UUID) (*models.QueryTemplate, error) {
	// In a real app, this would query the explorer_query_template table by ID.
	// We'll return a mock based on a hardcoded ID.
	requiredFilters, _ := json.Marshal([]models.Filter{
		{Field: "order_date", Op: "last_n_days", Values: []string{"7"}},
	})

	return &models.QueryTemplate{
		QueryTemplateMeta: models.QueryTemplateMeta{
			ID:           templateID,
			Name:         "Weekly Revenue Analysis",
			Description:  "Tracks total revenue, segmented by customer region, for the last 7 days.",
			SemanticView: "sales_overview",
			Tags:         pq.StringArray{"revenue", "weekly"},
			Certified:    true,
		},
		DefaultDimensions: []string{"customer_region"},
		DefaultMetrics:    []string{"total_revenue"},
		RequiredFilters:   requiredFilters,
		OwnerUserID:       "analytics_team",
		UpdatedAt:         time.Now(),
	}, nil
}

// ListCatalogNodesByType returns catalog nodes filtered by type and tenant/datasource.
func (s *SemanticService) ListCatalogNodesByType(ctx context.Context, tenantID, datasourceID, nodeType, parentID, q string, limit int) ([]map[string]interface{}, error) {
	if s.db == nil {
		return nil, fmt.Errorf("database not configured")
	}

	tenantID = strings.TrimSpace(tenantID)
	datasourceID = strings.TrimSpace(datasourceID)
	nodeType = strings.TrimSpace(nodeType)

	log.Printf("[DEBUG] ListCatalogNodesByType: tenantID=%s, datasourceID=%s, nodeType=%s, parentID=%s, q=%s, limit=%d", tenantID, datasourceID, nodeType, parentID, q, limit)

	// Parse UUIDs like in ListSemanticViews
	tenantUUID, err := uuid.Parse(tenantID)
	if err != nil {
		return nil, fmt.Errorf("invalid tenant_id format: %w", err)
	}
	datasourceUUID, err := uuid.Parse(datasourceID)
	if err != nil {
		return nil, fmt.Errorf("invalid datasource_id format: %w", err)
	}

	// Build query based on nodeType, parent, and search q
	baseQuery := `
		SELECT cn.id, cn.node_name, cn.qualified_path, cn.properties,
			   cnt.catalog_type_name, cn.parent_id, cn.created_at
		FROM public.catalog_node cn
		JOIN public.catalog_node_type cnt ON cnt.id = cn.node_type_id
		WHERE cn.tenant_id = $1 AND cn.tenant_datasource_id = $2`

	args := []interface{}{tenantUUID, datasourceUUID}
	argIdx := 2

	if nodeType != "" {
		argIdx++
		baseQuery += fmt.Sprintf(" AND cnt.catalog_type_name = $%d", argIdx)
		args = append(args, nodeType)
	}
	if parentID != "" {
		argIdx++
		baseQuery += fmt.Sprintf(" AND cn.parent_id = $%d", argIdx)
		// parent_id should be a uuid -> parse
		pid, err := uuid.Parse(parentID)
		if err == nil {
			args = append(args, pid)
			log.Printf("[DEBUG] Added parent_id filter: %s", parentID)
		} else {
			log.Printf("[DEBUG] Invalid parent_id format: %s, error: %v", parentID, err)
			// invalid parent id -> no results
			return []map[string]interface{}{}, nil
		}
	} else {
		log.Printf("[DEBUG] No parent_id filter applied (empty)")
	}
	if q != "" {
		argIdx++
		baseQuery += fmt.Sprintf(" AND cn.qualified_path ILIKE $%d", argIdx)
		args = append(args, "%"+q+"%")
	}

	baseQuery += " ORDER BY cn.qualified_path"

	if limit > 0 {
		baseQuery += fmt.Sprintf(" LIMIT %d", limit)
	}

	rows, err := s.db.QueryxContext(ctx, baseQuery, args...)
	if err != nil {
		return nil, fmt.Errorf("failed to list catalog nodes: %w", err)
	}
	defer rows.Close()

	nodes := make([]map[string]interface{}, 0)
	for rows.Next() {
		var (
			id            string
			nodeName      sql.NullString
			qualifiedPath sql.NullString
			properties    []byte
			catalogType   string
			parentID      sql.NullString
			createdAt     time.Time
		)
		if err := rows.Scan(&id, &nodeName, &qualifiedPath, &properties, &catalogType, &parentID, &createdAt); err != nil {
			continue
		}

		node := map[string]interface{}{
			"id":             id,
			"node_name":      nodeName.String,
			"qualified_path": qualifiedPath.String,
			"catalog_type":   catalogType,
			"parent_id":      parentID.String,
			"created_at":     createdAt,
		}

		// Parse properties JSON if present
		if len(properties) > 0 {
			var props map[string]interface{}
			if json.Unmarshal(properties, &props) == nil {
				node["properties"] = props
			}
		}

		nodes = append(nodes, node)
	}

	return nodes, nil
}
