# AI Builder Service Configuration

# Server Configuration
AI_BUILDER_PORT=8082

# xAI API Configuration
XAI_API_KEY=your-xai-api-key-here
XAI_API_ENDPOINT=https://api.x.ai/v1
XAI_MODEL=grok-beta

# Temporal Configuration
TEMPORAL_HOST_PORT=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ai-builder
WORKFLOW_TIMEOUT=300

# ABAC Configuration (TODO: implement ABAC permission checks)
ABAC_ENABLED=false

# Default Task Queue
DEFAULT_TASK_QUEUE=ai-builder
