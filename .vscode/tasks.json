{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Starlark: Run tests in current file",
      "type": "shell",
      "command": "go",
      "args": [
        "run",
        "./cmd/starlarktest",
        "-file",
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
