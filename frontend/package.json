{
  "name": "semlayer-monorepo",
  "private": true,
  "workspaces": [
    "services/*",
    "libs/*",
    "frontend"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:workspaces": "npm run build --workspaces",
    "build:libs": "npm run build --workspace=libs/*",
    "build:services": "npm run build --workspace=services/*",
    "test": "npm run test:jest --workspaces",
    "test:jest": "jest --runInBand",
    "test:vitest": "vitest",
    "test:e2e": "playwright test",
    "lint": "npm run lint --workspaces",
    "clean": "npm run clean --workspaces"
  },
  "version": "0.0.0",
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.1.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}