VITE_API_BASE_URL=http://localhost:8001
# Optional: set to the API gateway or backend host used in your development setup.
# Example for running the frontend locally against the API gateway started with docker-compose:
# VITE_API_BASE_URL=http://localhost:8001

# OIDC / Keycloak configuration
# The realm issuer URL and client ID must match the Keycloak client configured for this app.
VITE_OIDC_ISSUER=http://100.84.50.65:8089/realms/master
VITE_OIDC_CLIENT_ID=semlayer-frontend
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_OIDC_POST_LOGOUT_URI=http://localhost:5173/login

# When running the frontend dev server use:
# VITE_API_BASE_URL=http://localhost:8001 npm run dev
