{
  "bundle_id": "healthcare_bundle",
  "domain": "healthcare",
  "audience": ["healthcare_admin", "clinician", "payer"],
  "version": "v1.0.0",
  "owner": "patrick",
  "tags": ["healthcare", "patient_care", "financial", "operational"],
  "functions": [
    {
      "name": "SUMX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns the sum of an expression evaluated over a table."
    },
    {
      "name": "AVERAGEX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Calculates the average of an expression evaluated over a table."
    },
    {
      "name": "FILTER",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns a table that represents a subset of another table or expression."
    },
    {
      "name": "DIVIDE",
      "class": "DAX-Logical",
      "badge": "🟧",
      "description": "Performs division and returns alternate result or BLANK() on division by 0."
    },
    {
      "name": "MINX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns the minimum value of an expression evaluated over a table."
    },
    {
      "name": "MAXX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns the maximum value of an expression evaluated over a table."
    }
  ],
  "metrics": [
    {
      "node_id": "patient_satisfaction_score",
      "category": "patient_experience",
      "description": "Average patient satisfaction rating across all services.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "AVERAGEX({surveys_table}, {satisfaction_rating})",
        "arguments": {
          "surveys_table": "table:patient_surveys",
          "satisfaction_rating": "field:rating"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["AVERAGEX"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "average_length_of_stay",
      "category": "operational_efficiency",
      "description": "Average number of days patients stay in hospital.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "AVERAGEX({admissions_table}, {length_of_stay})",
        "arguments": {
          "admissions_table": "table:hospital_admissions",
          "length_of_stay": "field:days"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["AVERAGEX"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "readmission_rate",
      "category": "quality_of_care",
      "description": "Percentage of patients readmitted within 30 days.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({readmissions_table}, {readmission_count}), SUMX({discharges_table}, {total_discharges}))",
        "arguments": {
          "readmissions_table": "table:readmissions",
          "readmission_count": "field:count",
          "discharges_table": "table:patient_discharges",
          "total_discharges": "field:count"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "bed_occupancy_rate",
      "category": "resource_utilization",
      "description": "Percentage of hospital beds occupied.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({occupancy_table}, {occupied_beds}), SUMX({capacity_table}, {total_beds}))",
        "arguments": {
          "occupancy_table": "table:bed_occupancy",
          "occupied_beds": "field:count",
          "capacity_table": "table:bed_capacity",
          "total_beds": "field:count"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "average_cost_per_patient",
      "category": "financial_performance",
      "description": "Average cost incurred per patient treated.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({costs_table}, {treatment_cost}), SUMX({patients_table}, {patient_count}))",
        "arguments": {
          "costs_table": "table:treatment_costs",
          "treatment_cost": "field:amount",
          "patients_table": "table:patient_counts",
          "patient_count": "field:count"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "infection_rate",
      "category": "patient_safety",
      "description": "Rate of hospital-acquired infections per 1000 patient days.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({infections_table}, {infection_count}), SUMX({patient_days_table}, {total_patient_days})) * 1000",
        "arguments": {
          "infections_table": "table:hospital_infections",
          "infection_count": "field:count",
          "patient_days_table": "table:patient_days",
          "total_patient_days": "field:days"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "physician_productivity",
      "category": "staff_efficiency",
      "description": "Average number of patients seen per physician per day.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({visits_table}, {patient_visits}), SUMX({physicians_table}, {physician_count}))",
        "arguments": {
          "visits_table": "table:patient_visits",
          "patient_visits": "field:count",
          "physicians_table": "table:active_physicians",
          "physician_count": "field:count"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "medication_error_rate",
      "category": "medication_safety",
      "description": "Rate of medication errors per 1000 doses administered.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({errors_table}, {error_count}), SUMX({doses_table}, {total_doses})) * 1000",
        "arguments": {
          "errors_table": "table:medication_errors",
          "error_count": "field:count",
          "doses_table": "table:doses_administered",
          "total_doses": "field:count"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "emergency_wait_time",
      "category": "emergency_services",
      "description": "Average wait time for emergency department patients.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "AVERAGEX({wait_times_table}, {wait_minutes})",
        "arguments": {
          "wait_times_table": "table:emergency_wait_times",
          "wait_minutes": "field:minutes"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["AVERAGEX"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "revenue_per_bed",
      "category": "financial_efficiency",
      "description": "Average revenue generated per hospital bed.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({revenue_table}, {total_revenue}), SUMX({beds_table}, {bed_count}))",
        "arguments": {
          "revenue_table": "table:hospital_revenue",
          "total_revenue": "field:amount",
          "beds_table": "table:available_beds",
          "bed_count": "field:count"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    }
  ]
}
