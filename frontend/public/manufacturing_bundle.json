{
  "bundle_id": "manufacturing_bundle",
  "domain": "manufacturing",
  "audience": ["production_manager", "engineer", "executive"],
  "version": "v1.0.0",
  "owner": "patrick",
  "tags": ["manufacturing", "production", "quality", "efficiency"],
  "functions": [
    {
      "name": "SUMX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns the sum of an expression evaluated over a table."
    },
    {
      "name": "AVERAGEX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Calculates the average of an expression evaluated over a table."
    },
    {
      "name": "FILTER",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns a table that represents a subset of another table or expression."
    },
    {
      "name": "DIVIDE",
      "class": "DAX-Logical",
      "badge": "🟧",
      "description": "Performs division and returns alternate result or BLANK() on division by 0."
    },
    {
      "name": "MINX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns the minimum value of an expression evaluated over a table."
    },
    {
      "name": "MAXX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns the maximum value of an expression evaluated over a table."
    }
  ],
  "metrics": [
    {
      "node_id": "overall_equipment_effectiveness",
      "category": "production_efficiency",
      "description": "Measure of manufacturing productivity combining availability, performance, and quality.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({production_table}, {good_units_produced}), SUMX({capacity_table}, {total_available_time}))",
        "arguments": {
          "production_table": "table:production_output",
          "good_units_produced": "field:units",
          "capacity_table": "table:equipment_capacity",
          "total_available_time": "field:hours"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "cycle_time",
      "category": "process_efficiency",
      "description": "Average time required to complete one production cycle.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "AVERAGEX({cycles_table}, {cycle_duration})",
        "arguments": {
          "cycles_table": "table:production_cycles",
          "cycle_duration": "field:minutes"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["AVERAGEX"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "defect_rate",
      "category": "quality_control",
      "description": "Percentage of products that fail to meet quality standards.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({defects_table}, {defect_count}), SUMX({production_table}, {total_units}))",
        "arguments": {
          "defects_table": "table:quality_defects",
          "defect_count": "field:count",
          "production_table": "table:production_output",
          "total_units": "field:units"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "machine_utilization_rate",
      "category": "equipment_utilization",
      "description": "Percentage of available time that equipment is actively producing.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({runtime_table}, {actual_runtime}), SUMX({capacity_table}, {available_time}))",
        "arguments": {
          "runtime_table": "table:machine_runtime",
          "actual_runtime": "field:hours",
          "capacity_table": "table:machine_capacity",
          "available_time": "field:hours"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "labor_productivity",
      "category": "workforce_efficiency",
      "description": "Units produced per labor hour.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({production_table}, {units_produced}), SUMX({labor_table}, {labor_hours}))",
        "arguments": {
          "production_table": "table:production_output",
          "units_produced": "field:count",
          "labor_table": "table:labor_hours",
          "labor_hours": "field:hours"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "material_yield_rate",
      "category": "material_efficiency",
      "description": "Percentage of raw materials that become finished products.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({output_table}, {finished_goods}), SUMX({input_table}, {raw_materials}))",
        "arguments": {
          "output_table": "table:finished_goods",
          "finished_goods": "field:weight",
          "input_table": "table:raw_materials",
          "raw_materials": "field:weight"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "maintenance_cost_ratio",
      "category": "maintenance_efficiency",
      "description": "Maintenance costs as a percentage of equipment value.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({maintenance_table}, {maintenance_cost}), SUMX({assets_table}, {equipment_value}))",
        "arguments": {
          "maintenance_table": "table:maintenance_expenses",
          "maintenance_cost": "field:amount",
          "assets_table": "table:equipment_assets",
          "equipment_value": "field:value"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "energy_efficiency_ratio",
      "category": "energy_management",
      "description": "Energy consumption per unit of production.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({energy_table}, {energy_consumed}), SUMX({production_table}, {units_produced}))",
        "arguments": {
          "energy_table": "table:energy_usage",
          "energy_consumed": "field:kwh",
          "production_table": "table:production_output",
          "units_produced": "field:count"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "on_time_delivery_rate",
      "category": "supply_chain",
      "description": "Percentage of orders delivered on or before promised date.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({deliveries_table}, {on_time_deliveries}), SUMX({orders_table}, {total_orders}))",
        "arguments": {
          "deliveries_table": "table:order_deliveries",
          "on_time_deliveries": "field:count",
          "orders_table": "table:customer_orders",
          "total_orders": "field:count"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "inventory_accuracy_rate",
      "category": "inventory_control",
      "description": "Percentage of inventory records that match physical counts.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({accuracy_table}, {accurate_records}), SUMX({inventory_table}, {total_records}))",
        "arguments": {
          "accuracy_table": "table:inventory_accuracy",
          "accurate_records": "field:count",
          "inventory_table": "table:inventory_records",
          "total_records": "field:count"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    }
  ]
}
