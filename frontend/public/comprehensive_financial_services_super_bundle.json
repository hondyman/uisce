  "metrics": [
    {
      "node_id": "portfolio_allocation_pct",
      "category": "composition",
      "description": "Percentage of portfolio value allocated to each asset class, sector, or region.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({asset_class_table}, {asset_class_value}), SUM({total_portfolio_value}))",
        "arguments": {
          "asset_class_table": "table:asset_class_breakdown",
          "asset_class_value": "field:value",
          "total_portfolio_value": "field:portfolio_value"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "SUM", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "net_interest_margin",
      "category": "banking",
      "description": "Net interest income divided by average earning assets.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUM({interest_income}) - SUM({interest_expense}), AVERAGE({earning_assets}))",
        "arguments": {
          "interest_income": "field:interest_income",
          "interest_expense": "field:interest_expense",
          "earning_assets": "field:earning_assets"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUM", "AVERAGE", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "loss_ratio",
      "category": "insurance",
      "description": "Incurred losses divided by earned premiums.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUM({incurred_losses}), SUM({earned_premiums}))",
        "arguments": {
          "incurred_losses": "field:incurred_losses",
          "earned_premiums": "field:earned_premiums"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUM", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "value_at_risk",
      "category": "capital_markets",
      "description": "Maximum expected loss over a period at a given confidence level.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "PERCENTILEX.INC({loss_distribution}, {confidence_level})",
        "arguments": {
          "loss_distribution": "ARRAY_AGG(loss_amount)",
          "confidence_level": "field:confidence_level"
        }
      },
      "badge": "🟩",
      "function_class": "DAX-Financial",
      "functions_used": ["PERCENTILEX.INC"],
      "governance": { "status": "draft" }
    },
    {
      "node_id": "yield_to_maturity",
      "category": "yield",
      "description": "Internal rate of return of all future cash flows until maturity.",
      "financial_calc": {
        "type": "excel_formula",
        "formula": "=YIELD({settlement_date}, {maturity_date}, {coupon_rate}, {price}, {redemption}, {frequency}, {basis})",
        "arguments": {
          "settlement_date": "field:settlement_date",
          "maturity_date": "field:maturity_date",
          "coupon_rate": "field:coupon_rate",
          "price": "field:clean_price",
          "redemption": "field:redemption_value",
          "frequency": "field:coupon_frequency",
          "basis": "field:day_count_basis"
        }
      },
      "badge": "🟩",
      "function_class": "DAX-Financial",
      "functions_used": ["YIELD"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "esg_composite_score",
      "category": "esg",
      "description": "Weighted blend of Environmental, Social, and Governance sub-scores.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "({E_score} * {E_weight}) + ({S_score} * {S_weight}) + ({G_score} * {G_weight})",
        "arguments": {
          "E_score": "field:E_score",
          "E_weight": "field:E_weight",
          "S_score": "field:S_score",
          "S_weight": "field:S_weight",
          "G_score": "field:G_score",
          "G_weight": "field:G_weight"
        }
      },
      "badge": "🟧",
      "function_class": "DAX-Logical",
      "functions_used": ["ADD", "MULTIPLY"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "carbon_intensity",
      "category": "esg",
      "description": "CO₂e emissions per million USD revenue.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE({total_emissions}, DIVIDE({revenue}, 1000000))",
        "arguments": {
