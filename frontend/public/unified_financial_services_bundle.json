{
  "bundle_id": "unified_financial_services_bundle",
  "domain": "financial_services",
  "audience": [
    "advisor",
    "client",
    "executive",
    "portfolio_manager",
    "regulator",
    "risk"
  ],
  "version": "v3.0.0",
  "owner": "patrick",
  "tags": [
    "asset_management",
    "attribution",
    "banking",
    "business_efficiency",
    "capital_markets",
    "client_kpi",
    "cross_domain",
