    "wealth_management",
    "yield"
  ],
  "functions": [
    null,
    {
      "name": "ADD",
      "class": "DAX-Logical",
      "badge": "🟧",
      "description": "Returns the result of adding two numbers."
    },
    {
      "name": "AVERAGE",
      "class": "DAX-Aggregator",
      "badge": "🟨",
      "description": "Returns the average (arithmetic mean) of all the numbers in a column."
    },
    {
      "name": "AVERAGEX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Calculates the average of an expression evaluated over a table."
    },
    {
      "name": "COALESCE",
      "class": "DAX-Logical",
      "badge": "🟧",
      "description": "Returns the first expression that does not evaluate to BLANK."
    },
    {
      "name": "DATESYTD",
      "class": "DAX-Time",
      "badge": "🟦",
      "description": "Returns a table with dates from the beginning of the year to the last date in the current context."
    },
    {
      "name": "DISTINCTCOUNT",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Counts the number of distinct values in a column."
    },
    {
      "name": "DIVIDE",
      "class": "DAX-Logical",
      "badge": "🟧",
      "description": "Performs division and returns alternate result or BLANK() on division by 0."
    },
    {
      "name": "FILTER",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns a table that represents a subset of another table or expression."
    },
    {
      "name": "ISFILTERED",
      "class": "DAX-Meta",
      "badge": "🟪",
      "description": "Returns TRUE when the specified column is being filtered directly."
    },
    {
      "name": "MULTIPLY",
      "class": "DAX-Logical",
      "badge": "🟧",
      "description": "Returns the result of multiplying two numbers."
    },
    {
      "name": "PERCENTILEX.INC",
      "class": "DAX-Statistical",
      "badge": "🟩",
      "description": "Returns the k-th percentile of values in a column."
    },
    {
      "name": "POWER",
      "class": "DAX-Logical",
      "badge": "🟧",
      "description": "Returns the result of a number raised to a power."
    },
    {
      "name": "PRODUCTX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns the product of an expression evaluated over a table."
    },
    {
      "name": "SELECTEDVALUE",
      "class": "DAX-Meta",
      "badge": "🟪",
      "description": "Returns the value when the context for columnName has been filtered down to one distinct value only."
    },
    {
      "name": "SQRT",
      "class": "DAX-Logical",
      "badge": "🟧",
      "description": "Returns the square root of a number."
    },
    {
      "name": "STDEVX.P",
      "class": "DAX-Financial",
      "badge": "🟩",
      "description": "Returns the standard deviation of an expression evaluated over a table."
    },
    {
      "name": "SUBTRACT",
      "class": "DAX-Logical",
      "badge": "🟧",
      "description": "Returns the result of subtracting the second argument from the first argument."
    },
    {
      "name": "SUM",
      "class": "DAX-Aggregator",
      "badge": "🟨",
      "description": "Returns the sum of all the numbers in a column."
    },
    {
      "name": "SUMX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns the sum of an expression evaluated over a table."
    },
    {
      "name": "SWITCH",
      "class": "DAX-Logical",
      "badge": "🟧",
      "description": "Evaluates an expression against a list of values and returns one of multiple possible result expressions."
    },
    {
      "name": "TOTALYTD",
      "class": "DAX-Time",
      "badge": "🟦",
      "description": "Calculates a year-to-date value for the specified measure."
    },
    {
      "name": "XIRR",
      "class": "DAX-Financial",
      "badge": "🟩",
      "description": "Returns the internal rate of return for a schedule of cash flows that is not necessarily periodic."
    },
    {
      "name": "XNPV",
      "class": "DAX-Financial",
      "badge": "🟩",
      "description": "Returns the net present value for a schedule of cash flows that is not necessarily periodic."
    }
  ],
  "metrics": [
    {
      "node_id": "portfolio_allocation_pct",
      "category": "composition",
      "description": "Percentage of portfolio value allocated to each asset class, sector, or region.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({asset_class_table}, {asset_class_value}), SUM({total_portfolio_value}))",
        "arguments": {
          "asset_class_table": "table:asset_class_breakdown",
          "asset_class_value": "field:value",
          "total_portfolio_value": "field:portfolio_value"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": [
        "SUMX",
        "SUM",
        "DIVIDE"
      ],
      "governance": {
        "status": "golden"
      }
    },
    {
      "node_id": "asset_class_exposure",
      "category": "composition",
      "description": "Portfolio exposure by asset class.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({asset_class_value}), SUMX({total_portfolio_value}))",
        "arguments": {
          "asset_class_value": "table:value_by_class",
          "total_portfolio_value": "table:portfolio_value"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": [
        "SUMX",
        "DIVIDE"
      ],
      "governance": {
        "status": "golden"
      }
    },
    {
      "node_id": "portfolio_twr",
      "category": "performance",
      "description": "Time-weighted rate of return excluding impact of cash flows.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "PRODUCTX(1 + {subperiod_returns}) - 1",
        "arguments": {
          "subperiod_returns": "ARRAY_AGG(period_return)"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": [
        "PRODUCTX"
      ],
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "portfolio_mwr",
      "category": "performance",
      "description": "Money-weighted rate of return including timing of cash flows.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "XIRR({net_cash_flows}, {dates})",
        "arguments": {
          "net_cash_flows": "ARRAY_AGG(net_cash_flow)",
          "dates": "ARRAY_AGG(transaction_date)"
        }
      },
      "badge": "🟩",
      "function_class": "DAX-Financial",
      "functions_used": [
        "XIRR"
      ],
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "annualized_return",
      "category": "performance",
      "description": "Annualized return over a given period.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "POWER(1 + TOTALYTD({period_return}, {date}), 1 / {years}) - 1",
        "arguments": {
          "period_return": "field:period_return",
          "date": "field:date",
          "years": "field:number_of_years"
        }
      },
      "badge": "🟦",
      "function_class": "DAX-Time",
      "functions_used": [
        "TOTALYTD",
        "POWER"
      ],
      "governance": {
        "status": "golden"
      }
    },
    {
      "node_id": "portfolio_volatility",
      "category": "risk",
      "description": "Annualized standard deviation of returns.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "STDEVX.P({periodic_returns}) * SQRT({periods_per_year})",
        "arguments": {
          "periodic_returns": "ARRAY_AGG(period_return)",
          "periods_per_year": "field:periods_per_year"
        }
      },
      "badge": "🟩",
      "function_class": "DAX-Financial",
      "functions_used": [
        "STDEVX.P"
      ],
      "governance": {
        "status": "golden"
      }
    },
    {
      "node_id": "sharpe_ratio",
      "category": "risk_adjusted_performance",
      "description": "Risk-adjusted return using Sharpe Ratio.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE({annualized_return} - {risk_free_rate}, {portfolio_volatility})",
        "arguments": {
          "annualized_return": "calc:annualized_return",
          "risk_free_rate": "field:risk_free_rate",
          "portfolio_volatility": "calc:portfolio_volatility"
        }
      },
      "badge": "🟧",
      "function_class": "DAX-Logical",
      "functions_used": [
        "DIVIDE"
      ],
      "governance": {
        "status": "golden"
      }
    },
    {
      "node_id": "sortino_ratio",
      "category": "risk_adjusted_performance",
      "description": "Downside-risk-adjusted return using Sortino Ratio.",
      "financial_calc": {
        "type": "formula",
        "formula": "({annualized_return} - {risk_free_rate}) / {downside_deviation}",
        "arguments": {
          "annualized_return": "calc:annualized_return",
          "risk_free_rate": "field:risk_free_rate",
          "downside_deviation": "calc:downside_deviation"
        }
      },
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "beta",
      "category": "risk",
      "description": "Portfolio beta relative to benchmark.",
      "financial_calc": {
        "type": "formula",
        "formula": "COVAR({portfolio_returns}, {benchmark_returns}) / VAR({benchmark_returns})",
        "arguments": {
          "portfolio_returns": "ARRAY_AGG(portfolio_return)",
          "benchmark_returns": "ARRAY_AGG(benchmark_return)"
        }
      },
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "alpha",
      "category": "risk_adjusted_performance",
      "description": "Excess return over benchmark given beta.",
      "financial_calc": {
        "type": "formula",
        "formula": "{portfolio_return} - ({risk_free_rate} + {beta} * ({benchmark_return} - {risk_free_rate}))",
        "arguments": {
          "portfolio_return": "calc:annualized_return",
          "risk_free_rate": "field:risk_free_rate",
          "beta": "calc:beta",
          "benchmark_return": "calc:benchmark_annualized_return"
        }
      },
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "max_drawdown",
      "category": "risk",
      "description": "Largest peak-to-trough loss over period.",
      "financial_calc": {
        "type": "formula",
        "formula": "MIN(({trough_value} - {peak_value}) / {peak_value})",
        "arguments": {
          "trough_value": "calc:rolling_min_value",
          "peak_value": "calc:rolling_max_value"
        }
      },
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "dividend_yield",
      "category": "income",
      "description": "Annual dividends divided by current portfolio value.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({dividend_table}, {annualized_dividends}), SUMX({portfolio_table}, {total_portfolio_value}))",
        "arguments": {
          "dividend_table": "table:dividend_payments",
          "annualized_dividends": "field:dividend_amount",
          "portfolio_table": "table:portfolio_values",
          "total_portfolio_value": "field:value"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": [
        "SUMX",
        "DIVIDE"
      ],
      "governance": {
        "status": "golden"
      }
    },
    {
      "node_id": "rolling_return_1y",
      "category": "performance",
      "description": "Annualized return over rolling 1-year windows.",
      "financial_calc": {
        "type": "formula",
        "formula": "ROLLING_ANNUALIZED_RETURN({portfolio_returns}, 12)",
        "arguments": {
          "portfolio_returns": "ARRAY_AGG(monthly_return)"
        }
      },
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "tracking_error",
      "category": "risk",
      "description": "Standard deviation of active returns vs. benchmark.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "STDEVX.P({portfolio_returns} - {benchmark_returns})",
        "arguments": {
          "portfolio_returns": "ARRAY_AGG(portfolio_return)",
          "benchmark_returns": "ARRAY_AGG(benchmark_return)"
        }
      },
      "badge": "🟩",
      "function_class": "DAX-Financial",
      "functions_used": [
        "STDEVX.P"
      ],
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "upside_capture_ratio",
      "category": "risk_adjusted_performance",
      "description": "Portfolio's participation in benchmark gains.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(AVERAGEX(FILTER({returns_table}, {benchmark_return}>0), {portfolio_return}), AVERAGEX(FILTER({returns_table}, {benchmark_return}>0), {benchmark_return}))",
        "arguments": {
          "returns_table": "table:portfolio_vs_benchmark",
          "portfolio_return": "field:portfolio_return",
          "benchmark_return": "field:benchmark_return"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": [
        "AVERAGEX",
        "FILTER",
        "DIVIDE"
      ],
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "downside_capture_ratio",
      "category": "risk_adjusted_performance",
      "description": "Portfolio's participation in benchmark losses.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(AVERAGEX(FILTER({returns_table}, {benchmark_return}<0), {portfolio_return}), AVERAGEX(FILTER({returns_table}, {benchmark_return}<0), {benchmark_return}))",
        "arguments": {
          "returns_table": "table:portfolio_vs_benchmark",
          "portfolio_return": "field:portfolio_return",
          "benchmark_return": "field:benchmark_return"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": [
        "AVERAGEX",
        "FILTER",
        "DIVIDE"
      ],
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "information_ratio",
      "category": "risk_adjusted_performance",
      "description": "Risk-adjusted excess return vs. benchmark.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE({portfolio_return} - {benchmark_return}, {tracking_error})",
        "arguments": {
          "portfolio_return": "calc:annualized_return",
          "benchmark_return": "calc:benchmark_annualized_return",
          "tracking_error": "calc:tracking_error"
        }
      },
      "badge": "🟧",
      "function_class": "DAX-Logical",
      "functions_used": [
        "DIVIDE"
      ],
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "income_contribution_pct",
      "category": "income",
      "description": "Percentage of total return attributable to income vs. capital gains.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({income_return}), {total_return})",
        "arguments": {
          "income_return": "table:income_amount",
          "total_return": "calc:total_return"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": [
        "SUMX",
        "DIVIDE"
      ],
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "realized_vs_unrealized_gains",
      "category": "performance",
      "description": "Ratio of realized to total gains, showing tax impact and liquidity.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({realized_gains}), SUMX({realized_gains}) + SUMX({unrealized_gains}))",
        "arguments": {
          "realized_gains": "table:realized_gain",
          "unrealized_gains": "table:unrealized_gain"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": [
        "SUMX",
        "DIVIDE"
      ],
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "client_retention_rate",
      "category": "client_kpi",
      "description": "Percentage of clients retained over a period.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(DISTINCTCOUNT(FILTER({clients_table}, {acquisition_date} < {period_start} AND {end_date} >= {period_end})), DISTINCTCOUNT(FILTER({clients_table}, {acquisition_date} < {period_start})))",
        "arguments": {
          "clients_table": "table:clients",
          "acquisition_date": "field:acquisition_date",
          "end_date": "field:end_date",
          "period_start": "field:period_start",
          "period_end": "field:period_end"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": [
        "DISTINCTCOUNT",
        "FILTER",
        "DIVIDE"
      ],
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "net_promoter_score",
      "category": "client_kpi",
      "description": "Client satisfaction and loyalty measure.",
      "financial_calc": {
        "type": "formula",
        "formula": "{promoters_pct} - {detractors_pct}",
        "arguments": {
          "promoters_pct": "COUNT(CASE WHEN nps_score >= 9 THEN 1 END) / COUNT(*)",
          "detractors_pct": "COUNT(CASE WHEN nps_score <= 6 THEN 1 END) / COUNT(*)"
        }
      },
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "client_acquisition_cost",
      "category": "client_kpi",
      "description": "Marketing and sales cost per new client.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({acquisition_table}, {total_acquisition_spend}), DISTINCTCOUNT(FILTER({clients_table}, {acquisition_date} >= {period_start})))",
        "arguments": {
          "acquisition_table": "table:acquisition_costs",
          "total_acquisition_spend": "field:cost",
          "clients_table": "table:clients",
          "acquisition_date": "field:acquisition_date",
          "period_start": "field:period_start"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": [
        "SUMX",
        "DISTINCTCOUNT",
        "FILTER",
        "DIVIDE"
      ],
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "client_lifetime_value",
      "category": "client_kpi",
      "description": "Total revenue expected from a client over relationship.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "AVERAGEX({clients_table}, {avg_annual_revenue} * {avg_client_lifespan})",
        "arguments": {
          "clients_table": "table:clients",
          "avg_annual_revenue": "field:annual_revenue",
          "avg_client_lifespan": "field:lifespan_years"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": [
        "AVERAGEX"
      ],
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "revenue_per_advisor",
      "category": "business_efficiency",
      "description": "Productivity measure for advisors.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({revenue_table}, {total_revenue}), DISTINCTCOUNT({advisor_table}, {advisor_id}))",
        "arguments": {
          "revenue_table": "table:revenues",
          "total_revenue": "field:amount",
          "advisor_table": "table:advisors",
          "advisor_id": "field:id"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": [
        "SUMX",
        "DISTINCTCOUNT",
        "DIVIDE"
      ],
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "operating_expense_ratio",
      "category": "business_efficiency",
      "description": "Cost efficiency measure.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({expense_table}, {operating_expenses}), SUMX({revenue_table}, {revenue}))",
        "arguments": {
          "expense_table": "table:expenses",
          "operating_expenses": "field:amount",
          "revenue_table": "table:revenues",
          "revenue": "field:amount"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": [
        "SUMX",
        "DIVIDE"
      ],
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "gross_margin",
      "category": "business_efficiency",
      "description": "Service delivery efficiency.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({revenue_table}, {revenue}) - SUMX({cost_table}, {direct_costs}), SUMX({revenue_table}, {revenue}))",
        "arguments": {
          "revenue_table": "table:revenues",
          "revenue": "field:amount",
          "cost_table": "table:costs",
          "direct_costs": "field:amount"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": [
        "SUMX",
        "DIVIDE"
      ],
      "governance": {
        "status": "draft"
      }
    },
    {
      "node_id": "net_interest_margin",
      "category": "banking",
      "description": "Net interest income divided by average earning assets. Core profitability metric for banks.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUM({interest_income}) - SUM({interest_expense}), AVERAGE({earning_assets}))",
        "arguments": {
          "interest_income": "field:interest_income",
          "interest_expense": "field:interest_expense",
          "earning_assets": "field:earning_assets"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Aggregator",
      "functions_used": [
        "SUM",
        "AVERAGE",
        "DIVIDE"
      ],
      "governance": {
        "status": "golden"
      }
    },
    {
      "node_id": "loan_to_deposit_ratio",
