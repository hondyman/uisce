# Frontend local env sample for running Vite locally (not in Docker)
# If you run the frontend on your host machine (npm run dev), set these values
# so Vite proxies /api requests to the backend container which exposes the API on port 8082.

# Enable Vite proxy to forward /api -> backend
VITE_USE_PROXY=true

# When backend runs in Docker the container port 8080 is mapped to host 8082 in dev compose
# Use localhost here because the frontend is running on the host (not in Docker)
VITE_BACKEND_TARGET=http://localhost:8082
VITE_API_BASE_URL=http://localhost:8082

# OIDC / Keycloak configuration
VITE_OIDC_ISSUER=http://100.84.50.65:8089/realms/master
VITE_OIDC_CLIENT_ID=semlayer-frontend
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_OIDC_POST_LOGOUT_URI=http://localhost:5173/login
