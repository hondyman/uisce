{
  "bundle_id": "fof_private_markets_bundle",
  "domain": "private_markets",
  "audience": "fund_of_funds",
  "version": "v1.0.0",
  "owner": "patrick",
  "tags": ["fof", "portfolio", "aggregation", "benchmarking"],
  "description": "Curated registry pack for Fund-of-Funds managers — optimized for portfolio-level analysis, manager diversification, and vintage/strategy allocation tracking.",
  "metrics": [
    {
      "node_id": "private_markets_net_irr",
      "name": "Net IRR",
      "type": "measure",
      "category": "Performance",
      "subcategory": "IRR",
      "financial_calc": {
        "type": "excel_formula",
        "formula": "=XIRR({cash_flows}, {dates})",
        "arguments": {
          "cash_flows": "ARRAY_AGG(net_cash_flow)",
          "dates": "ARRAY_AGG(transaction_date)"
        }
      },
      "description": "Net Internal Rate of Return after fees",
      "preaggregation": {
        "enabled": true,
        "grain": ["portfolio_id", "month"],
        "refresh": "daily",
        "reason": "High-frequency query, complex calculation, stable monthly grain"
      }
    },
    {
      "node_id": "private_markets_tvpi",
      "name": "TVPI",
      "type": "measure",
      "category": "Performance",
      "subcategory": "Multiples",
      "financial_calc": {
        "type": "excel_formula",
        "formula": "=SUM({distributions}) / SUM({invested_capital})",
        "arguments": {
          "distributions": "ARRAY_AGG(distribution_amount)",
          "invested_capital": "ARRAY_AGG(invested_amount)"
        }
      },
      "description": "Total Value to Paid-In capital",
      "preaggregation": {
        "enabled": true,
        "grain": ["portfolio_id", "quarter"],
        "refresh": "weekly",
        "reason": "Stable quarterly grain, used in multiple FoF dashboards"
      }
    },
    {
      "node_id": "private_markets_pme",
      "name": "PME",
      "type": "measure",
      "category": "Performance",
      "subcategory": "Benchmarking",
      "financial_calc": {
        "type": "excel_formula",
        "formula": "=SUM({distributions}) / SUM({invested_capital}) / {benchmark_return}",
        "arguments": {
          "distributions": "ARRAY_AGG(distribution_amount)",
          "invested_capital": "ARRAY_AGG(invested_amount)",
          "benchmark_return": "benchmark_return_value"
        }
      },
      "description": "Public Market Equivalent",
      "preaggregation": {
        "enabled": true,
        "grain": ["portfolio_id", "quarter"],
        "refresh": "weekly",
        "reason": "Benchmark-dependent, quarterly grain sufficient"
      }
    },
    {
      "node_id": "private_markets_diversification_score",
      "name": "Diversification Score",
      "type": "measure",
      "category": "Risk",
      "subcategory": "Diversification",
      "financial_calc": {
        "type": "excel_formula",
        "formula": "=1 - SUMSQ({weights})",
        "arguments": {
          "weights": "ARRAY_AGG(allocation_weight)"
        }
      },
      "description": "Herfindahl-Hirschman Index for portfolio diversification",
      "preaggregation": {
        "enabled": true,
        "grain": ["portfolio_id", "month"],
        "refresh": "weekly",
        "reason": "Monthly grain sufficient for risk monitoring"
      }
    },
    {
      "node_id": "private_markets_risk_adjusted_return",
      "name": "Risk-Adjusted Return",
      "type": "measure",
      "category": "Risk",
      "subcategory": "Sharpe",
      "financial_calc": {
        "type": "excel_formula",
        "formula": "=AVERAGE({returns}) / STDEV.P({returns})",
        "arguments": {
          "returns": "ARRAY_AGG(monthly_return)"
        }
      },
      "description": "Sharpe ratio for risk-adjusted performance",
      "preaggregation": {
        "enabled": false,
        "reason": "Requires rolling window calculations, high computational cost"
      }
    }
  ],
  "modules": [
    "FundSelector",
    "PortfolioOverview",
    "VintageAnalysis",
    "StrategyAllocation",
    "ManagerPerformance",
    "BenchmarkComparison",
    "RiskAttribution",
    "LiquidityAnalysis"
  ],
  "governance": {
    "steward_group": "fof_stewards",
    "review_cycle": "quarterly",
    "audit_required": true,
    "change_approval": "steward_approval"
  },
  "data_sources": [
    {
      "name": "portfolio_data",
      "type": "database",
      "schema": "private_markets",
      "tables": ["portfolios", "funds", "managers", "allocations", "performance"]
    },
    {
      "name": "market_intelligence",
      "type": "api",
      "provider": "preqin",
      "endpoints": ["manager_database", "fund_universe", "benchmark_data"]
    },
    {
      "name": "due_diligence",
      "type": "api",
      "provider": "cambridge_associates",
      "endpoints": ["peer_analysis", "market_trends"]
    }
  ],
  "sla": {
    "data_freshness": "daily",
    "query_performance": "< 5 seconds",
    "uptime": "99.9%"
  }
}
