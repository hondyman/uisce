{
  "bundle_id": "gp_private_markets_bundle",
  "domain": "private_markets",
  "audience": "general_partner",
  "version": "v1.0.0",
  "owner": "patrick",
  "tags": ["gp", "performance", "deployment", "fees", "benchmarking"],
  "description": "Curated registry pack for General Partners — optimized for fund deployment tracking, gross performance monitoring, fee management, and peer benchmarking.",
  "metrics": [
    {
      "node_id": "private_markets_gross_irr",
      "name": "Gross IRR",
      "type": "measure",
      "category": "Performance",
      "subcategory": "IRR",
      "financial_calc": {
        "type": "excel_formula",
        "formula": "=XIRR({cash_flows}, {dates})",
        "arguments": {
          "cash_flows": "ARRAY_AGG(gross_cash_flow)",
          "dates": "ARRAY_AGG(transaction_date)"
        }
      },
      "description": "Gross Internal Rate of Return before fees",
      "preaggregation": {
        "enabled": true,
        "grain": ["fund_id", "month"],
        "refresh": "daily",
        "reason": "High-frequency query, complex calculation, stable monthly grain"
      }
    },
    {
      "node_id": "private_markets_gross_moic",
      "name": "Gross MOIC",
      "type": "measure",
      "category": "Performance",
      "subcategory": "Multiples",
      "financial_calc": {
        "type": "excel_formula",
        "formula": "=SUM({distributions}) / SUM({invested_capital})",
        "arguments": {
          "distributions": "ARRAY_AGG(gross_distribution)",
          "invested_capital": "ARRAY_AGG(invested_amount)"
        }
      },
      "description": "Gross Multiple of Invested Capital",
      "preaggregation": {
        "enabled": true,
        "grain": ["fund_id", "quarter"],
        "refresh": "weekly",
        "reason": "Stable quarterly grain, used in multiple GP dashboards"
      }
    },
    {
      "node_id": "private_markets_fee_ratio",
      "name": "Fee Ratio",
      "type": "measure",
      "category": "Fees",
      "subcategory": "Management",
      "financial_calc": {
        "type": "excel_formula",
        "formula": "=SUM({management_fees}) / SUM({assets_under_management})",
        "arguments": {
          "management_fees": "ARRAY_AGG(management_fee_amount)",
          "assets_under_management": "ARRAY_AGG(aum_amount)"
        }
      },
      "description": "Management fee as percentage of AUM",
      "preaggregation": {
        "enabled": true,
        "grain": ["fund_id", "month"],
        "refresh": "daily",
        "reason": "High-frequency monitoring, stable monthly grain"
      }
    },
    {
      "node_id": "private_markets_carry_accrual",
      "name": "Carry Accrual",
      "type": "measure",
      "category": "Fees",
      "subcategory": "Carried Interest",
      "financial_calc": {
        "type": "excel_formula",
        "formula": "=SUM({carried_interest}) / SUM({profit_waterfall})",
        "arguments": {
          "carried_interest": "ARRAY_AGG(carry_amount)",
          "profit_waterfall": "ARRAY_AGG(profit_amount)"
        }
      },
      "description": "Accrued carried interest based on profit waterfall",
      "preaggregation": {
        "enabled": false,
        "reason": "High volatility, depends on real-time profit calculations"
      }
    },
    {
      "node_id": "private_markets_deployment_pace",
      "name": "Deployment Pace",
      "type": "measure",
      "category": "Operations",
      "subcategory": "Deployment",
      "financial_calc": {
        "type": "excel_formula",
        "formula": "=SUM({deployments}) / SUM({commitments})",
        "arguments": {
          "deployments": "ARRAY_AGG(deployment_amount)",
          "commitments": "ARRAY_AGG(commitment_amount)"
        }
      },
      "description": "Percentage of committed capital deployed",
      "preaggregation": {
        "enabled": true,
        "grain": ["fund_id", "month"],
        "refresh": "daily",
        "reason": "Key operational metric, monitored daily"
      }
    }
  ],
  "modules": [
    "FundSelector",
    "DeploymentPacingChart",
    "GrossIRRChart",
    "NAVEvolutionChart",
    "FeeCarryPanel",
    "ValueAttributionBridge",
    "ExitTrackingTable",
    "BenchmarkComparison"
  ],
  "governance": {
    "steward_group": "gp_stewards",
    "review_cycle": "quarterly",
    "audit_required": true,
    "change_approval": "steward_approval"
  },
  "data_sources": [
    {
      "name": "fund_operations",
      "type": "database",
      "schema": "private_markets",
      "tables": ["funds", "deployments", "fees", "carried_interest", "exits"]
    },
    {
      "name": "valuation_data",
      "type": "api",
      "provider": "fund_administrator",
      "endpoints": ["nav_calculations", "performance_attribution"]
    },
    {
      "name": "benchmark_data",
      "type": "api",
      "provider": "preqin",
      "endpoints": ["peer_benchmarks", "market_indices"]
    }
  ],
  "sla": {
    "data_freshness": "daily",
    "query_performance": "< 3 seconds",
    "uptime": "99.9%"
  }
}
