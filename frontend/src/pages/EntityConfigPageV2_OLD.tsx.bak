import React, { useState, useMemo, useEffect } from 'react';
import {
  Card,
  Button,
  Form,
  Input,
  Select,
  message,
  Modal,
  Col,
  Row,
  Space,
  Tooltip,
  Popconfirm,
  Tag,
  Table,
  Tabs,
  Empty,
  Spin,
  Badge,
  Drawer,
  Divider,
  List,
  Affix,
} from 'antd';
import {
  PlusOutlined,
  DeleteOutlined,
  EditOutlined,
  CopyOutlined,
  SearchOutlined,
  SaveOutlined,
} from '@ant-design/icons';
import Editor from '@monaco-editor/react';
import { saveEntitySchema, fetchEntitySchema } from '../api/entitySchema';
import type { Entities, Entity, Subtype, Field } from '../types/entity-schema';
import { devLog } from ../utils/devLogger';
import { hasTenantScope } from '../utils/tenantScope';
import ProfessionalSearchInput from '../components/common/ProfessionalSearchInput';

const { Option } = Select;

// Core Business Objects (Workday-style seed data)
const CORE_ENTITIES: Entities = {
  client_investor: {
    name: 'ClientInvestor',
    description: 'Core BO: Investor profile with relationship tracking',
    isCore: true,
    entity_fields: [
      { key: 'investor_id', name: 'Investor ID', type: 'text', isCore: true },
      { key: 'legal_name', name: 'Legal Name', type: 'text', isCore: true },
      { key: 'email', name: 'Email', type: 'text', isCore: true },
      { key: 'phone', name: 'Phone', type: 'text', isCore: true },
      { key: 'aum', name: 'AUM', type: 'number', isCore: true },
    ],
    subtypes: {
      individual: {
        name: 'IndividualInvestor',
        isCore: true,
        subtype_fields: [
          { key: 'ssn', name: 'SSN', type: 'text', isCore: true },
          { key: 'date_of_birth', name: 'Date of Birth', type: 'date', isCore: true },
        ],
      },
      institutional: {
        name: 'InstitutionalInvestor',
        isCore: true,
        subtype_fields: [
          { key: 'ein', name: 'EIN', type: 'text', isCore: true },
          { key: 'registration_status', name: 'Registration Status', type: 'text', isCore: true },
        ],
      },
    },
  },
  portfolio: {
    name: 'Portfolio',
    description: 'Core BO: Asset portfolio management',
    isCore: true,
    entity_fields: [
      { key: 'portfolio_id', name: 'Portfolio ID', type: 'text', isCore: true },
      { key: 'portfolio_name', name: 'Name', type: 'text', isCore: true },
      { key: 'inception_date', name: 'Inception Date', type: 'date', isCore: true },
      { key: 'total_value', name: 'Total Value', type: 'number', isCore: true },
    ],
    subtypes: {
      discretionary: {
        name: 'DiscretionaryPortfolio',
        isCore: true,
        subtype_fields: [
          { key: 'advisor_controlled', name: 'Advisor Controlled', type: 'boolean', isCore: true },
        ],
      },
    },
  },
  trade: {
    name: 'Trade',
    description: 'Core BO: Security transaction',
    isCore: true,
    entity_fields: [
      { key: 'trade_id', name: 'Trade ID', type: 'text', isCore: true },
      { key: 'trade_date', name: 'Trade Date', type: 'date', isCore: true },
      { key: 'ticker', name: 'Ticker', type: 'text', isCore: true },
      { key: 'quantity', name: 'Quantity', type: 'number', isCore: true },
      { key: 'price', name: 'Price', type: 'number', isCore: true },
    ],
    subtypes: {
      regular: {
        name: 'RegularTrade',
        isCore: true,
        subtype_fields: [
          { key: 'settlement_date', name: 'Settlement Date', type: 'date', isCore: true },
        ],
      },
      block_trade: {
        name: 'BlockTrade',
        isCore: true,
        subtype_fields: [
          { key: 'block_size', name: 'Block Size', type: 'number', isCore: true },
          { key: 'negotiated_price', name: 'Negotiated Price', type: 'boolean', isCore: true },
        ],
      },
    },
  },
};

export default function EntityConfigPageV2() {
  const [entities, setEntities] = useState<Entities>(CORE_ENTITIES);
  const [initialEntities, setInitialEntities] = useState<Entities>(CORE_ENTITIES);
  const [searchTerm, setSearchTerm] = useState('');
  const [isSaving, setIsSaving] = useState(false);
  const [editingEntity, setEditingEntity] = useState<string | null>(null);
  const [drawerOpen, setDrawerOpen] = useState(false);
  const [form] = Form.useForm();
  const [modalConfig, setModalConfig] = useState<{ type: string; open: boolean; entityKey?: string }>({
    type: '',
    open: false,
  });

  // Load saved schema from backend on mount
  useEffect(() => {
    const loadSchema = async () => {
      if (!hasTenantScope()) {
        devLog('[EntityConfigPageV2] No tenant scope, using core BOs');
        return;
      }

      try {
        devLog('[EntityConfigPageV2] Loading schema from backend');
        const savedSchema = await fetchEntitySchema();

        if (Object.keys(savedSchema).length > 0) {
          devLog('[EntityConfigPageV2] Schema loaded:', { savedSchema });
          // Merge with core entities
          const merged = { ...CORE_ENTITIES, ...savedSchema };
          setInitialEntities(merged);
          setEntities(merged);
        }
      } catch (error) {
        devLog('[EntityConfigPageV2] Error loading schema:', { error });
      }
    };

    loadSchema();
  }, []);

  // Compute changes (delta)
  const computeChanges = useMemo(() => {
    const changed: string[] = [];
    const deleted: string[] = [];

    for (const key of Object.keys(entities)) {
      if (!(key in initialEntities)) {
        changed.push(key);
      } else if (JSON.stringify(entities[key]) !== JSON.stringify(initialEntities[key])) {
        changed.push(key);
      }
    }

    for (const key of Object.keys(initialEntities)) {
      if (!(key in entities)) {
        deleted.push(key);
      }
    }

    return { changed, deleted };
  }, [entities, initialEntities]);

  // Filter entities by search term
  const filteredEntities = useMemo(() => {
    const term = searchTerm.toLowerCase();
    return Object.fromEntries(
      Object.entries(entities).filter(([key, entity]) => {
        return (
          key.toLowerCase().includes(term) ||
          entity.name.toLowerCase().includes(term) ||
          entity.description?.toLowerCase().includes(term) ||
          Object.values(entity.subtypes).some(
            (s) => s.name.toLowerCase().includes(term)
          )
        );
      })
    );
  }, [entities, searchTerm]);

  const saveAndApply = async () => {
    devLog('[saveAndApply] Saving changes...');
    setIsSaving(true);

    try {
      if (!hasTenantScope()) {
        message.error('Please select a tenant first');
        return;
      }

      const { changed, deleted } = computeChanges;
      const changedEntities = Object.fromEntries(
        changed.map((key) => [key, entities[key]])
      );

      const payload = { changed: changedEntities, deleted };
      await saveEntitySchema(payload);

      setInitialEntities(entities);
      message.success(`✅ Saved! ${changed.length} changed, ${deleted.length} deleted`);
    } catch (error) {
      devLog('[saveAndApply] Error:', { error });
      message.error('Failed to save schema');
    } finally {
      setIsSaving(false);
    }
  };

  const handleAddEntity = () => {
    setModalConfig({ type: 'entity', open: true });
  };

  const handleEditEntity = (entityKey: string) => {
    setEditingEntity(entityKey);
    setDrawerOpen(true);
  };

  const handleCloneEntity = (fromKey: string) => {
    const sourceEntity = entities[fromKey];
    const newKey = `${fromKey}_custom_1`;
    const newEntity: Entity = {
      ...sourceEntity,
      isCore: false,
      clonesFrom: fromKey,
      coreFields: sourceEntity.entity_fields.filter((f) => f.isCore),
      customFields: [],
      name: `${sourceEntity.name} (Custom)`,
      description: `Custom clone of ${sourceEntity.name}`,
    };

    setEntities({ ...entities, [newKey]: newEntity });
    message.success(`✅ Cloned "${sourceEntity.name}" as new custom entity!`);
  };

  const handleDeleteEntity = (entityKey: string) => {
    const newEntities = { ...entities };
    delete newEntities[entityKey];
    setEntities(newEntities);
    message.success('Entity deleted');
  };

  const handleFinishModal = (values: any) => {
    if (modalConfig.type === 'entity') {
      const key = values.name.toLowerCase().replace(/\s+/g, '_');
      const newEntity: Entity = {
        name: values.name,
        description: values.description,
        entity_fields: [],
        subtypes: {},
        isCore: false,
        coreFields: [],
        customFields: [],
      };
      setEntities({ ...entities, [key]: newEntity });
      message.success('Entity created!');
    }

    setModalConfig({ type: '', open: false });
    form.resetFields();
  };

  const handleAddSubtype = (entityKey: string, subtypeName: string) => {
    const key = subtypeName.toLowerCase().replace(/\s+/g, '_');
    const newSubtypes = {
      ...entities[entityKey].subtypes,
      [key]: { name: subtypeName, subtype_fields: [], isCore: false },
    };
    setEntities({
      ...entities,
      [entityKey]: { ...entities[entityKey], subtypes: newSubtypes },
    });
    message.success(`Subtype "${subtypeName}" added`);
  };

  const handleAddField = (
    entityKey: string,
    fieldName: string,
    fieldType: string,
    level: 'entity' | 'subtype',
    subtypeKey?: string
  ) => {
    const field: Field = {
      key: fieldName.toLowerCase().replace(/\s+/g, '_'),
      name: fieldName,
      type: fieldType as any,
      isCore: false,
    };

    let updatedEntity = entities[entityKey];

    if (level === 'entity') {
      updatedEntity = {
        ...updatedEntity,
        entity_fields: [...updatedEntity.entity_fields, field],
        customFields: [...(updatedEntity.customFields || []), field],
      };
    } else if (subtypeKey) {
      const newSubtypes = {
        ...updatedEntity.subtypes,
        [subtypeKey]: {
          ...updatedEntity.subtypes[subtypeKey],
          subtype_fields: [...updatedEntity.subtypes[subtypeKey].subtype_fields, field],
        },
      };
      updatedEntity = { ...updatedEntity, subtypes: newSubtypes };
    }

    setEntities({ ...entities, [entityKey]: updatedEntity });
    message.success('Field added!');
  };

  const selectedEntity = editingEntity ? entities[editingEntity] : null;

  return (
    <div style={{ padding: '24px', background: '#f5f5f5', minHeight: '100vh' }}>
      {/* HEADER */}
      <Row gutter={16} style={{ marginBottom: '24px' }}>
        <Col span={24}>
          <Card
            title={
              <Space>
                <Badge status="processing" text="Definitions" />
                <span>Entity Schema Builder (Workday-Style BOs)</span>
              </Space>
            }
            extra={
              <Space>
                <Button icon={<SearchOutlined />} onClick={() => setSearchTerm('')}>
                  Clear
                </Button>
                <Button
                  type="primary"
                  icon={<SaveOutlined />}
                  onClick={saveAndApply}
                  loading={isSaving}
                  disabled={computeChanges.changed.length === 0 && computeChanges.deleted.length === 0}
                >
                  SAVE & APPLY ({computeChanges.changed.length + computeChanges.deleted.length})
                </Button>
              </Space>
            }
          >
            <Row gutter={16} style={{ marginBottom: '16px' }}>
              <Col span={24}>
                <ProfessionalSearchInput
                  value={searchTerm}
                  onChange={setSearchTerm}
                  placeholder="Search entities, descriptions, subtypes..."
                  onClear={() => setSearchTerm('')}
                />
              </Col>
            </Row>

            <Divider style={{ margin: '16px 0' }} />

            {/* ENTITY CARDS GRID */}
            <Row gutter={[16, 16]}>
              {/* Add New Entity Button */}
              <Col xs={24} sm={12} md={8} lg={6}>
                <Card
                  hoverable
                  onClick={handleAddEntity}
                  style={{
                    display: 'flex',
                    alignItems: 'center',
                    justifyContent: 'center',
                    minHeight: '220px',
                    cursor: 'pointer',
                    border: '2px dashed #1890ff',
                  }}
                >
                  <Space direction="vertical" align="center">
                    <PlusOutlined style={{ fontSize: '32px', color: '#1890ff' }} />
                    <span style={{ color: '#1890ff', fontWeight: 500 }}>Add New Entity</span>
                  </Space>
                </Card>
              </Col>

              {/* Entity Cards */}
              {Object.entries(filteredEntities).map(([entityKey, entity]) => (
                <Col xs={24} sm={12} md={8} lg={6} key={entityKey}>
                  <Card
                    hoverable
                    size="small"
                    style={{ minHeight: '220px', position: 'relative' }}
                    actions={[
                      <Tooltip title="Edit">
                        <EditOutlined onClick={() => handleEditEntity(entityKey)} />
                      </Tooltip>,
                      <Tooltip title="Clone as Custom">
                        <CopyOutlined
                          onClick={() => handleCloneEntity(entityKey)}
                          style={{ color: entity.isCore ? '#faad14' : '#52c41a' }}
                        />
                      </Tooltip>,
                      <Popconfirm
                        title="Delete Entity?"
                        description="This will delete the entity and all its subtypes/fields."
                        onConfirm={() => handleDeleteEntity(entityKey)}
                        okText="Delete"
                        okType="danger"
                      >
                        <Tooltip title="Delete">
                          <DeleteOutlined style={{ color: '#ff4d4f' }} />
                        </Tooltip>
                      </Popconfirm>,
                    ]}
                  >
                    <Space direction="vertical" size={12} style={{ width: '100%' }}>
                      {/* Entity Badge */}
                      <Space wrap>
                        <Tag color={entity.isCore ? 'blue' : 'green'}>
                          {entity.isCore ? '🔒 CORE BO' : '✏️ CUSTOM'}
                        </Tag>
                        {entity.clonesFrom && <Tag color="orange">Clone</Tag>}
                      </Space>

                      {/* Entity Name */}
                      <div>
                        <h4 style={{ margin: '0 0 4px 0' }}>{entity.name}</h4>
                        <p
                          style={{
                            margin: 0,
                            fontSize: '12px',
                            color: '#666',
                            overflow: 'hidden',
                            textOverflow: 'ellipsis',
                            whiteSpace: 'nowrap',
                          }}
                        >
                          {entity.description}
                        </p>
                      </div>

                      <Divider style={{ margin: '8px 0' }} />

                      {/* Subtypes as Chips */}
                      <div>
                        <small style={{ color: '#999' }}>Subtypes:</small>
                        <div style={{ display: 'flex', flexWrap: 'wrap', gap: '4px', marginTop: '4px' }}>
                          {Object.entries(entity.subtypes).length > 0 ? (
                            Object.entries(entity.subtypes).map(([subtypeKey, subtype]) => (
                              <Tag key={subtypeKey} color={subtype.isCore ? 'blue' : 'cyan'}>
                                {subtype.name}
                              </Tag>
                            ))
                          ) : (
                            <small style={{ color: '#ccc' }}>No subtypes</small>
                          )}
                        </div>
                      </div>

                      {/* Field Count */}
                      <small style={{ color: '#999' }}>
                        Fields: {entity.entity_fields.length} | Subtypes: {Object.keys(entity.subtypes).length}
                      </small>
                    </Space>
                  </Card>
                </Col>
              ))}
            </Row>

            {Object.keys(filteredEntities).length === 0 && (
              <Empty description="No entities found" style={{ marginTop: '40px' }} />
            )}
          </Card>
        </Col>
      </Row>

      {/* DRAWER: Edit Entity */}
      <Drawer
        title={`Edit Entity: ${selectedEntity?.name}`}
        onClose={() => {
          setEditingEntity(null);
          setDrawerOpen(false);
        }}
        open={drawerOpen}
        width={720}
        bodyStyle={{ paddingBottom: '80px' }}
      >
        {selectedEntity && editingEntity && (
          <Tabs
            items={[
              {
                key: 'subtypes',
                label: '📋 Subtypes',
                children: (
                  <Space direction="vertical" style={{ width: '100%' }}>
                    <Button
                      type="primary"
                      icon={<PlusOutlined />}
                      onClick={() =>
                        Modal.confirm({
                          title: 'Add Subtype',
                          content: (
                            <Input
                              id="subtype-name"
                              placeholder="Subtype name (e.g., IndividualInvestor)"
                              autoFocus
                            />
                          ),
                          onOk() {
                            const input = document.getElementById('subtype-name') as HTMLInputElement;
                            if (input?.value) {
                              handleAddSubtype(editingEntity, input.value);
                            }
                          },
                        })
                      }
                    >
                      Add Subtype
                    </Button>

                    <Table
                      dataSource={Object.entries(selectedEntity.subtypes).map(([key, subtype]) => ({
                        key,
                        name: subtype.name,
                        fields: subtype.subtype_fields.length,
                        isCore: subtype.isCore,
                      }))}
                      columns={[
                        { dataIndex: 'name', title: 'Subtype Name', key: 'name' },
                        {
                          dataIndex: 'isCore',
                          title: 'Type',
                          key: 'isCore',
                          render: (isCore) => <Tag color={isCore ? 'blue' : 'cyan'}>{isCore ? 'Core' : 'Custom'}</Tag>,
                        },
                        { dataIndex: 'fields', title: 'Fields', key: 'fields' },
                        {
                          title: 'Actions',
                          key: 'actions',
                          render: (_, record) => (
                            <Space>
                              <Popconfirm
                                title="Delete?"
                                onConfirm={() => {
                                  const newSubtypes = { ...selectedEntity.subtypes };
                                  delete newSubtypes[record.key];
                                  setEntities({
                                    ...entities,
                                    [editingEntity]: { ...selectedEntity, subtypes: newSubtypes },
                                  });
                                  message.success('Subtype deleted');
                                }}
                              >
                                <DeleteOutlined style={{ color: '#ff4d4f' }} />
                              </Popconfirm>
                            </Space>
                          ),
                        },
                      ]}
                      pagination={false}
                      size="small"
                    />
                  </Space>
                ),
              },
              {
                key: 'fields',
                label: '🔧 Fields',
                children: (
                  <Space direction="vertical" style={{ width: '100%' }}>
                    <Button
                      type="primary"
                      icon={<PlusOutlined />}
                      onClick={() =>
                        Modal.confirm({
                          title: 'Add Field',
                          width: 500,
                          content: (
                            <Form layout="vertical">
                              <Form.Item label="Field Name">
                                <Input id="field-name" placeholder="e.g., net_worth" />
                              </Form.Item>
                              <Form.Item label="Field Type">
                                <Select id="field-type" defaultValue="text">
                                  <Option value="text">Text</Option>
                                  <Option value="number">Number</Option>
                                  <Option value="date">Date</Option>
                                  <Option value="boolean">Boolean</Option>
                                </Select>
                              </Form.Item>
                              <Form.Item label="Add to">
                                <Select id="field-level" defaultValue="entity">
                                  <Option value="entity">Entity Level</Option>
                                  {Object.entries(selectedEntity.subtypes).map(([key, subtype]) => (
                                    <Option key={key} value={key}>
                                      Subtype: {subtype.name}
                                    </Option>
                                  ))}
                                </Select>
                              </Form.Item>
                            </Form>
                          ),
                          onOk() {
                            const fieldName = (document.getElementById('field-name') as HTMLInputElement)?.value;
                            const fieldType = (document.getElementById('field-type') as HTMLSelectElement)?.value;
                            const fieldLevel = (document.getElementById('field-level') as HTMLSelectElement)?.value;

                            if (fieldName && fieldType) {
                              if (fieldLevel === 'entity') {
                                handleAddField(editingEntity, fieldName, fieldType, 'entity');
                              } else {
                                handleAddField(editingEntity, fieldName, fieldType, 'subtype', fieldLevel);
                              }
                            }
                          },
                        })
                      }
                    >
                      Add Field
                    </Button>

                    {/* Core Fields Section */}
                    {selectedEntity && (selectedEntity.coreFields || []).length > 0 && (
                      <>
                        <h4>🔒 Core Fields (Inherited)</h4>
                        <Table
                          dataSource={(selectedEntity.coreFields || []).map((f) => ({
                            ...f,
                          }))}
                          columns={[
                            { dataIndex: 'name', title: 'Name', key: 'name' },
                            { dataIndex: 'type', title: 'Type', key: 'type' },
                          ]}
                          pagination={false}
                          size="small"
                          rowKey="key"
                        />
                      </>
                    )}

                    {/* Custom Fields Section */}
                    {selectedEntity && (selectedEntity.customFields || []).length > 0 && (
                      <>
                        <h4>✏️ Custom Fields</h4>
                        <Table
                          dataSource={(selectedEntity.customFields || []).map((f) => ({
                            ...f,
                          }))}
                          columns={[
                            { dataIndex: 'name', title: 'Name', key: 'name' },
                            { dataIndex: 'type', title: 'Type', key: 'type' },
                            {
                              title: 'Actions',
                              key: 'actions',
                              render: (_, record: any) => (
                                <Popconfirm
                                  title="Delete?"
                                  onConfirm={() => {
                                    const newCustom = (selectedEntity.customFields || []).filter(
                                      (f) => f.key !== record.key
                                    );
                                    setEntities({
                                      ...entities,
                                      [editingEntity]: { ...selectedEntity, customFields: newCustom },
                                    });
                                    message.success('Field deleted');
                                  }}
                                >
                                  <DeleteOutlined style={{ color: '#ff4d4f' }} />
                                </Popconfirm>
                              ),
                            },
                          ]}
                          pagination={false}
                          size="small"
                          rowKey="key"
                        />
                      </>
                    )}

                    {/* Entity-Level Fields */}
                    {selectedEntity && selectedEntity.entity_fields.length > 0 && (
                      <>
                        <h4>📌 Entity Fields</h4>
                        <Table
                          dataSource={selectedEntity.entity_fields.map((f) => ({
                            ...f,
                          }))}
                          columns={[
                            { dataIndex: 'name', title: 'Name', key: 'name' },
                            { dataIndex: 'type', title: 'Type', key: 'type' },
                            {
                              dataIndex: 'isCore',
                              title: 'Type',
                              render: (isCore) => <Tag color={isCore ? 'blue' : 'green'}>{isCore ? 'Core' : 'Custom'}</Tag>,
                            },
                          ]}
                          pagination={false}
                          size="small"
                          rowKey="key"
                        />
                      </>
                    )}
                  </Space>
                ),
              },
            ]}
          />
        )}
      </Drawer>

      {/* MODAL: Add Entity */}
      <Modal
        title="Create New Entity"
        open={modalConfig.type === 'entity' && modalConfig.open}
        onCancel={() => setModalConfig({ type: '', open: false })}
        onOk={() => form.submit()}
      >
        <Form form={form} layout="vertical" onFinish={handleFinishModal}>
          <Form.Item name="name" label="Entity Name" rules={[{ required: true }]}>
            <Input placeholder="e.g., Order, Invoice" />
          </Form.Item>
          <Form.Item name="description" label="Description">
            <Input.TextArea placeholder="What is this entity for?" rows={3} />
          </Form.Item>
        </Form>
      </Modal>
    </div>
  );
}
