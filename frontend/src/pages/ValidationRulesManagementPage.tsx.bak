import React from 'react';

const ValidationRulesManagementPage: React.FC = () => {
  return (
    <div style={{ padding: 24, fontFamily: 'Inter, system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif' }}>
      <h1>Validation Rules (placeholder)</h1>
      <p>
        The Validation Rules Management UI has been temporarily simplified to resolve a build error.
        This placeholder allows the dev server to start. We'll restore the full page content once the
        duplicated file content is cleaned up and verified.
      </p>
    </div>
  );
};

const BATCH_SIZE = 10;

interface NormalizedRule extends SharedValidationRule {
  tenant_id?: string;
  datasource_id?: string;
}

type SortField = 'name' | 'entity' | 'status' | 'severity' | 'modified' | 'none';
type SortDirection = 'asc' | 'desc';

export const ValidationRulesManagementPage: React.FC = (): JSX.Element => {
  const { tenant, datasource, isSelected } = useTenant();

  const [rules, setRules] = useState<NormalizedRule[]>([]);
  const [searchQuery, setSearchQuery] = useState('');
  const [statusFilter, setStatusFilter] = useState<'all' | 'active' | 'inactive'>('all');
  const [entityFilter, setEntityFilter] = useState('all');
  const [loading, setLoading] = useState(false);
  const [hasMore, setHasMore] = useState(true);
  const [page, setPage] = useState(0);
  const [entities, setEntities] = useState<string[]>([]);
  const [isBuilderOpen, setIsBuilderOpen] = useState(false);
  const [editingRule, setEditingRule] = useState<NormalizedRule | null>(null);
  const [selectedRuleIds, setSelectedRuleIds] = useState<Set<string>>(new Set());
  const [sortField, setSortField] = useState<SortField>('none');
  const [sortDirection, setSortDirection] = useState<SortDirection>('asc');

  const sentinelRef = useRef<HTMLDivElement>(null);

  const simpleStyles = useMemo(() => `
    .vrm-container { display: flex; flex-direction: column; min-height: 100vh; background: #f6f7f8; color: #1f2937; font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
    .vrm-header { position: sticky; top: 0; z-index: 20; display: flex; align-items: center; justify-content: space-between; padding: 12px 24px; border-bottom: 1px solid #e5e7eb; background: #ffffff; }
    .vrm-header-left { display: flex; align-items: center; gap: 16px; }
    .vrm-header-icon { width: 32px; height: 32px; color: #137fec; display: flex; align-items: center; justify-content: center; }
    .vrm-header-title { margin: 0; font-size: 18px; font-weight: 700; }
    .vrm-header-buttons { display: flex; align-items: center; gap: 12px; }
    .vrm-icon-button { width: 40px; height: 40px; border-radius: 10px; border: 1px solid #e5e7eb; background: #f3f4f6; color: #4b5563; display: flex; align-items: center; justify-content: center; cursor: pointer; }
    .vrm-avatar { width: 40px; height: 40px; border-radius: 50%; background: #d1d5db; }
    .vrm-main { flex: 1; display: flex; justify-content: center; padding: 32px 24px; }
    .vrm-content { width: 100%; max-width: 1180px; display: flex; flex-direction: column; gap: 24px; }
    .vrm-page-header { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 16px; }
    .vrm-heading { display: flex; flex-direction: column; gap: 8px; min-width: 260px; }
    .vrm-title { margin: 0; font-size: 32px; font-weight: 800; }
    .vrm-subtitle { margin: 0; font-size: 16px; color: #4b5563; }
    .vrm-actions { display: flex; flex-wrap: wrap; gap: 12px; justify-content: flex-end; align-items: center; }
    .vrm-button { display: inline-flex; align-items: center; gap: 8px; height: 40px; padding: 0 16px; border-radius: 8px; border: 1px solid #d1d5db; background: #ffffff; color: #1f2937; font-size: 14px; font-weight: 600; cursor: pointer; }
    .vrm-button:disabled { opacity: 0.6; cursor: not-allowed; }
    .vrm-button--primary { background: #137fec; border: none; color: #ffffff; }
    .vrm-button--muted { background: #f3f4f6; border: 1px solid #d1d5db; }
    .vrm-button--success { background: #16a34a; border: none; color: #ffffff; }
    .vrm-button--warning { background: #ea580c; border: none; color: #ffffff; }
    .vrm-button--danger { background: #dc2626; border: none; color: #ffffff; }
    .vrm-warning { padding: 16px; border-radius: 12px; background: #fef3c7; border: 1px solid #fcd34d; color: #92400e; }
    .vrm-panel { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 16px; box-shadow: 0 20px 40px rgba(15,23,42,0.05); overflow: hidden; }
    .vrm-controls { padding: 20px; border-bottom: 1px solid #e5e7eb; display: flex; flex-wrap: wrap; gap: 16px; align-items: center; }
    .vrm-search { width: 100%; min-width: 200px; max-width: 320px; height: 40px; padding: 0 12px; border-radius: 8px; border: 1px solid #d1d5db; font-size: 14px; }
    .vrm-select { height: 40px; min-width: 160px; border-radius: 8px; border: 1px solid #d1d5db; padding: 0 12px; font-size: 14px; background: #ffffff; }
    .vrm-table-wrapper { width: 100%; overflow-x: auto; }
    .vrm-table { width: 100%; border-collapse: collapse; min-width: 720px; }
  .vrm-table thead th { text-align: left; padding: 12px 16px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; background: #f3f4f6; border-bottom: 1px solid #e5e7eb; color: #6b7280; }
  .vrm-checkbox-header { width: 48px; }
                    ) : (
                      filteredAndSorted.map(rule => (
                        <tr key={rule.id}>
                          <td className="vrm-checkbox-cell">
                            <input
                              type="checkbox"
                              checked={selectedRuleIds.has(rule.id)}
                              onChange={() => handleToggleRuleSelect(rule.id)}
                              aria-label={`Select ${rule.rule_name || 'rule'}`}
                            />
                          </td>
                          <td>
                            <button
                              type="button"
                              onClick={() => handleEditRule(rule)}
                              className="vrm-link"
                            >
                              {rule.rule_name || rule.name || 'Unnamed'}
                            </button>
                          </td>
                          <td>{rule.target_entity || rule.entity || '—'}</td>
                          <td>
                            <span className={getStatusBadgeClass(!!rule.is_active)}>
                              {rule.is_active ? 'Active' : 'Inactive'}
                            </span>
                          </td>
                          <td>
                            {rule.severity && (
                              <span className={getSeverityClass(rule.severity)}>
                                {rule.severity.charAt(0).toUpperCase() + rule.severity.slice(1)}
                              </span>
                            )}
                          </td>
                          <td>
                            {rule.updated_at ? new Date(rule.updated_at).toLocaleDateString() : rule.created_at ? new Date(rule.created_at).toLocaleDateString() : '—'}
                          </td>
                          <td className="vrm-action-cell">
                            <div className="vrm-table-actions">
                              <button type="button" className="vrm-link" onClick={() => handleEditRule(rule)}>
                                Edit
                              </button>
                              <button type="button" className="vrm-link vrm-link--danger" onClick={() => handleDeleteRule(rule.id)}>
                                Delete
                              </button>
                            </div>
                          </td>
                        </tr>
                      ))
                    )}
                  </tbody>
                </table>
              </div>

              {loading && (
                <div className="vrm-table-loading">Loading...</div>
              )}

              {hasMore && !loading && (
                <div ref={sentinelRef} className="vrm-sentinel" />
              )}

              {!hasMore && rules.length > 0 && (
                <div className="vrm-footer">
                  Showing {filteredAndSorted.length} of {rules.length} rules
                </div>
              )}
            </div>
          </div>
        </main>

        {isBuilderOpen && (
          <div className="vrm-modal-overlay">
            <div className="vrm-modal">
              <div className="vrm-modal-header">
                <h2 className="vrm-modal-title">{editingRule ? 'Edit Rule' : 'Create New Rule'}</h2>
                <button
                  type="button"
                  onClick={() => setIsBuilderOpen(false)}
                  className="vrm-close"
                  aria-label="Close"
                >
                  ×
                </button>
              </div>
              <div className="vrm-modal-body">
                <UnifiedRuleBuilder
                  rules={rules}
                  onRulesUpdate={(updated) => {
                    setRules(updated);
                    setIsBuilderOpen(false);
                    setEditingRule(null);
                  }}
                  mode="modal"
                />
              </div>
            </div>
          </div>
        )}
      </div>
    </>
  );
};

