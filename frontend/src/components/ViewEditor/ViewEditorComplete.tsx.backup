import { useState, useEffect, useRef, useMemo, useCallback } from 'react';
import ModalHeader from '../../components/ModalHeader';
import { devDebug, devWarn } from '../../utils/devLogger';
  Box,
  Card,
  CardContent,
  CardHeader,
  Grid,
  Paper,
  List,
  ListItem,
  ListItemText,
  ListItemIcon,
  ListItemButton,
  Divider,
  TextField,
  Checkbox,
  CircularProgress,
  Typography,
  FormControlLabel,
  Switch,
  Autocomplete,
  Chip,
  IconButton,
  Button,
  Tooltip,
  Badge,
  Collapse,
  Alert,
  Stack,
  Accordion,
  AccordionSummary,
  AccordionDetails,
  Dialog,
  DialogContent,
  DialogActions,
  Snackbar,
  Tabs,
  Tab,
} from '@mui/material';
import {
  Storage,
  BarChart,
  ViewModule,
  Save,
  CheckCircle,
  Error as ErrorIcon,
  Add,
  Remove,
  DragIndicator,
  ExpandMore,
  ExpandLess,
  ArrowForward,
  ArrowBack,
  SelectAll,
  Clear,
  AccountTree,
  TableChart,
  Functions,
  Visibility,
  VisibilityOff,
  Code,
} from '@mui/icons-material';
import { DragDropContext, Droppable, Draggable } from 'react-beautiful-dnd';
import styles from './ViewEditor.module.css';

interface ViewEditorCompleteProps {
  viewName: string;
  viewData: any;
  setViewData: (data: any) => void;
  onSave: () => void;
  onValidate: () => void;
  isSaving: boolean;
  isValidating: boolean;
  validationResult: any;
  notification: any;
  setNotification: (notification: any) => void;
  tenantId?: string;
  datasourceId?: string;
}

type ComponentType = 'dimension' | 'measure';

type ComponentWarningsState = Record<ComponentType, Record<number, string[]>>;

interface ExtendsOption {
  name: string;
  title?: string;
  description?: string;
  isCore?: boolean;
}

interface JoinPathManagerProps {
  joinPaths: any[];
  onRemove: (index: number) => void;
  onAdd: () => void;
}

const extractJoinPaths = (cubes: any): string[] => {
  if (!Array.isArray(cubes)) return [];
  return cubes
    .map((cube: any) => {
      if (typeof cube === 'string') {
        return cube;
      }
      if (cube && typeof cube === 'object' && typeof cube.join_path === 'string') {
        return cube.join_path;
      }
      if (cube && typeof cube === 'object' && typeof cube.name === 'string') {
        return cube.name;
      }
      return '';
    })
    .map(path => path?.trim())
    .filter((path): path is string => Boolean(path));
};

const isCoreView = (view: any): boolean => {
  if (!view) return false;
  if (typeof view.is_core === 'boolean') return view.is_core;
  if (typeof view.isCore === 'boolean') return view.isCore;
  const tags = Array.isArray(view.tags) ? view.tags : [];
  if (tags.some((tag: any) => typeof tag === 'string' && tag.toLowerCase() === 'core')) {
    return true;
  }
  if (typeof view.name === 'string') {
    return view.name.toLowerCase().startsWith('core_');
  }
  return false;
};

// Interface for available items from cubes/extended views
interface AvailableItem {
  id: string;
  name: string;
  title?: string;
  type: 'dimension' | 'measure';
  source: string; // cube or extended view name
  sourceType: 'cube' | 'extended_view';
  description?: string;
  dataType?: string;
}

interface AvailableSource {
  id: string;
  name: string;
  type: 'cube' | 'extended_view';
  isCore?: boolean;
  isCustom?: boolean;
  dimensions: AvailableItem[];
  measures: AvailableItem[];
  expanded?: boolean;
}

const ViewEditorComplete: React.FC<ViewEditorCompleteProps> = ({
  viewName,
  viewData,
  setViewData,
  onSave,
  onValidate,
  isSaving,
  isValidating,
  validationResult,
  notification,
  setNotification,
  tenantId,
  datasourceId
}) => {
  // View properties state
  const [extendsOptions, setExtendsOptions] = useState<ExtendsOption[]>([]);
  const [extendsLoading, setExtendsLoading] = useState(false);
  const [extendsInputValue, setExtendsInputValue] = useState<string>((viewData?.extends as string) || '');
  const [extendsQuery, setExtendsQuery] = useState<string>((viewData?.extends as string) || '');
  const [extendsError, setExtendsError] = useState<string>('');
  const extendsFetchIdRef = useRef(0);
  const extendsDebounceRef = useRef<number | null>(null);

  // Available sources and items state
  const [availableSources, setAvailableSources] = useState<AvailableSource[]>([]);
  const [sourcesLoading, setSourcesLoading] = useState(false);
  const [selectedAvailableItems, setSelectedAvailableItems] = useState<Set<string>>(new Set());
  
  // Selected items for the view
  const [selectedViewItems, setSelectedViewItems] = useState<Set<string>>(new Set());

  const joinPathItems = useMemo(() => Array.isArray(viewData?.cubes) ? viewData.cubes : [], [viewData?.cubes]);
  const hasTenantScope = Boolean(tenantId && datasourceId);

  // Fetch available cubes and extended views with their components
  const fetchAvailableSources = useCallback(async () => {
    if (!tenantId || !datasourceId) {
      setAvailableSources([]);
      return;
    }

    setSourcesLoading(true);
    try {
      // Fetch cubes
      const cubesResponse = await fetch(`/api/fabric/models?tenant_id=${tenantId}&datasource_id=${datasourceId}`);
      const cubesData = await cubesResponse.json();
      
      // Fetch extended views (from extends options)
      const extendsResponse = await fetch(`/api/views?page_size=200&tenant_id=${tenantId}&datasource_id=${datasourceId}`);
      const extendsData = await extendsResponse.json();

      const sources: AvailableSource[] = [];

      // Process cubes
      if (Array.isArray(cubesData)) {
        cubesData.forEach((cube: any) => {
          const dimensions: AvailableItem[] = [];
          const measures: AvailableItem[] = [];

          // Extract dimensions and measures from cube configuration
          if (cube.resolved_config) {
            const config = typeof cube.resolved_config === 'string' 
              ? JSON.parse(cube.resolved_config) 
              : cube.resolved_config;

            // Process dimensions
            if (config.dimensions) {
              Object.entries(config.dimensions).forEach(([key, dim]: [string, any]) => {
                dimensions.push({
                  id: `${cube.id}.${key}`,
                  name: key,
                  title: dim.title || key,
                  type: 'dimension',
                  source: cube.display_name || cube.model_key,
                  sourceType: 'cube',
                  description: dim.description,
                  dataType: dim.type || 'string'
                });
              });
            }

            // Process measures
            if (config.measures) {
              Object.entries(config.measures).forEach(([key, measure]: [string, any]) => {
                measures.push({
                  id: `${cube.id}.${key}`,
                  name: key,
                  title: measure.title || key,
                  type: 'measure',
                  source: cube.display_name || cube.model_key,
                  sourceType: 'cube',
                  description: measure.description,
                  dataType: measure.type || 'number'
                });
              });
            }
          }

          sources.push({
            id: cube.id,
            name: cube.display_name || cube.model_key,
            type: 'cube',
            isCore: !cube.is_custom,
            isCustom: cube.is_custom,
            dimensions,
            measures,
            expanded: false
          });
        });
      }

      // Process extended views
      if (extendsData?.views && Array.isArray(extendsData.views)) {
        extendsData.views.forEach((view: any) => {
          const dimensions: AvailableItem[] = [];
          const measures: AvailableItem[] = [];

          // Extract dimensions and measures from view
          if (view.dimensions) {
            view.dimensions.forEach((dim: any) => {
              dimensions.push({
                id: `${view.name}.${dim.name}`,
                name: dim.name,
                title: dim.title || dim.name,
                type: 'dimension',
                source: view.name,
                sourceType: 'extended_view',
                description: dim.description,
                dataType: dim.type || 'string'
              });
            });
          }

          if (view.measures) {
            view.measures.forEach((measure: any) => {
              measures.push({
                id: `${view.name}.${measure.name}`,
                name: measure.name,
                title: measure.title || measure.name,
                type: 'measure',
                source: view.name,
                sourceType: 'extended_view',
                description: measure.description,
                dataType: measure.type || 'number'
              });
            });
          }

          if (dimensions.length > 0 || measures.length > 0) {
            sources.push({
              id: view.name,
              name: view.title || view.name,
              type: 'extended_view',
              isCore: isCoreView(view),
              dimensions,
              measures,
              expanded: false
            });
          }
        });
      }

      setAvailableSources(sources);
    } catch (error) {
      console.error('Failed to fetch available sources:', error);
      setAvailableSources([]);
    } finally {
      setSourcesLoading(false);
    }
  }, [tenantId, datasourceId]);

  // Load extends options
  useEffect(() => {
    const nextValue = typeof viewData?.extends === 'string' ? viewData.extends : '';
    setExtendsInputValue(nextValue);
    setExtendsQuery(nextValue);
  }, [viewData?.extends]);

  useEffect(() => {
    if (extendsDebounceRef.current) {
      window.clearTimeout(extendsDebounceRef.current);
    }
    extendsDebounceRef.current = window.setTimeout(() => {
      setExtendsQuery((extendsInputValue || '').trim());
    }, 250);
    return () => {
      if (extendsDebounceRef.current) {
        window.clearTimeout(extendsDebounceRef.current);
      }
    };
  }, [extendsInputValue]);

  useEffect(() => {
    if (!tenantId || !datasourceId) {
      setExtendsOptions([]);
      setExtendsLoading(false);
      return;
    }

    extendsFetchIdRef.current += 1;
    const fetchId = extendsFetchIdRef.current;
    setExtendsLoading(true);

    const params = new URLSearchParams();
    params.set('page_size', '200');
    if (extendsQuery) params.set('q', extendsQuery);
    params.set('tenant_id', tenantId);
    params.set('datasource_id', datasourceId);

    const fetchOptions = async () => {
      try {
        const response = await fetch(`/api/views?${params.toString()}`);
        if (!response.ok) {
          throw new Error(`Failed to load views (${response.status})`);
        }
        const body = await response.json();
        const rawViews: any[] = Array.isArray(body?.views) ? body.views : [];
        const normalized = rawViews
          .map((view: any) => {
            const name = view?.name || view?.view_name || view?.model_key || '';
            return {
              name,
              title: view?.title || view?.display_name || name,
              description: view?.description || '',
              isCore: isCoreView(view),
            } as ExtendsOption;
          })
          .filter((opt: ExtendsOption) => opt.name && opt.name.toLowerCase() !== viewName.toLowerCase());

        const currentExtends = typeof viewData?.extends === 'string' ? viewData.extends : '';
        if (currentExtends && !normalized.some(opt => opt.name === currentExtends)) {
          normalized.push({ name: currentExtends, title: currentExtends, description: '', isCore: false });
        }

        if (fetchId === extendsFetchIdRef.current) {
          setExtendsOptions(normalized);
          setExtendsLoading(false);
        }
      } catch (error) {
        if (fetchId === extendsFetchIdRef.current) {
          setExtendsOptions([]);
          setExtendsLoading(false);
        }
      }
    };

    void fetchOptions();
  }, [tenantId, datasourceId, extendsQuery, viewData?.extends, viewName]);

  // Load available sources when component mounts or tenant/datasource changes
  useEffect(() => {
    fetchAvailableSources();
  }, [fetchAvailableSources]);  const handleSave = () => {
    onSave();
  };

  const handleValidate = () => {
    onValidate();
  };

  const handleExtendsSelection = useCallback((value: ExtendsOption | string | null) => {
    const resolved = typeof value === 'string' ? value : value?.name || '';
    const trimmed = resolved.trim();
    if (trimmed && trimmed.toLowerCase() === viewName.toLowerCase()) {
      setExtendsError('A view cannot extend itself.');
      setExtendsInputValue(typeof viewData?.extends === 'string' ? viewData.extends : '');
      return;
    }
    setExtendsError('');
    setExtendsInputValue(trimmed);
    const nextData = { ...viewData };
    if (trimmed) {
      nextData.extends = trimmed;
    } else {
      delete nextData.extends;
    }
    setViewData(nextData);
  }, [setViewData, viewData, viewName]);

  // Handle adding cubes to join paths
  const handleAddCube = (cubeId: string) => {
    const source = availableSources.find(s => s.id === cubeId);
    if (!source) return;

    const newCube = {
      id: cubeId,
      join_path: source.name,
      includes: '*'
    };

    const newViewData = { ...viewData };
    if (!newViewData.cubes) newViewData.cubes = [];
    newViewData.cubes.push(newCube);
    setViewData(newViewData);
  };

  // Handle removing cubes from join paths
  const handleRemoveCube = (index: number) => {
    const newViewData = { ...viewData };
    if (Array.isArray(newViewData.cubes)) {
      const cubes = [...newViewData.cubes];
      cubes.splice(index, 1);
      newViewData.cubes = cubes;
    }
    setViewData(newViewData);
  };

  // Toggle source expansion
  const toggleSourceExpansion = (sourceId: string) => {
    setAvailableSources(prev =>
      prev.map(source =>
        source.id === sourceId
          ? { ...source, expanded: !source.expanded }
          : source
      )
    );
  };

  // Handle item selection for adding to view
  const handleItemSelection = (itemId: string, selected: boolean) => {
    setSelectedAvailableItems(prev => {
      const newSet = new Set(prev);
      if (selected) {
        newSet.add(itemId);
      } else {
        newSet.delete(itemId);
      }
      return newSet;
    });
  };

  // Handle adding selected items to view
  const handleAddSelectedItems = () => {
    const itemsToAdd: AvailableItem[] = [];
    availableSources.forEach(source => {
      [...source.dimensions, ...source.measures].forEach(item => {
        if (selectedAvailableItems.has(item.id)) {
          itemsToAdd.push(item);
        }
      });
    });

    if (itemsToAdd.length === 0) return;

    const newViewData = { ...viewData };
    
    itemsToAdd.forEach(item => {
      if (item.type === 'dimension') {
        if (!newViewData.dimensions) newViewData.dimensions = [];
        newViewData.dimensions.push({
          id: item.id,
          name: item.name,
          title: item.title || item.name,
          type: item.dataType || 'string',
          description: item.description,
          sql: item.name,
          source: item.source,
          join_path: item.source,
          qualified_name: `${item.source}.${item.name}`
        });
      } else if (item.type === 'measure') {
        if (!newViewData.measures) newViewData.measures = [];
        newViewData.measures.push({
          id: item.id,
          name: item.name,
          title: item.title || item.name,
          type: item.dataType || 'number',
          description: item.description,
          sql: item.name,
          source: item.source,
          join_path: item.source,
          qualified_name: `${item.source}.${item.name}`
        });
      }
    });

    setViewData(newViewData);
    setSelectedAvailableItems(new Set());
  };

  // Handle removing items from view
  const handleRemoveViewItem = (type: 'dimension' | 'measure', index: number) => {
    const newViewData = { ...viewData };
    
    if (type === 'dimension' && Array.isArray(newViewData.dimensions)) {
      const dimensions = [...newViewData.dimensions];
      dimensions.splice(index, 1);
      newViewData.dimensions = dimensions;
    } else if (type === 'measure' && Array.isArray(newViewData.measures)) {
      const measures = [...newViewData.measures];
      measures.splice(index, 1);
      newViewData.measures = measures;
    }
    
    setViewData(newViewData);
  };

  // Handle selecting all items from a source
  const handleSelectAllFromSource = (sourceId: string) => {
    const source = availableSources.find(s => s.id === sourceId);
    if (!source) return;

    const allItemIds = [...source.dimensions, ...source.measures].map(item => item.id);
    setSelectedAvailableItems(prev => {
      const newSet = new Set(prev);
      allItemIds.forEach(id => newSet.add(id));
      return newSet;
    });
  };

  // Add new items
  const handleAddItem = (type: 'cube' | 'dimension' | 'measure', itemData: any) => {
    const itemsToAdd = Array.isArray(itemData) ? itemData : (itemData ? [itemData] : []);
    if (itemsToAdd.length === 0) {
      setShowAddDialog(false);
      return;
    }

    const newViewData = { ...viewData };

    switch (type) {
      case 'cube': {
        if (!newViewData.cubes) newViewData.cubes = [];
        itemsToAdd.forEach((cubeItem: any) => {
          if (!cubeItem) return;
          
          // Always store as object with UUID and model_key
          const cubeObj: any = {
            id: cubeItem.id, // Always store UUID
            join_path: cubeItem.path || cubeItem.join_path || cubeItem.model_key || cubeItem.name,
            includes: cubeItem.includes || '*',
          };
          
          // Optional fields
          if (cubeItem.excludes && cubeItem.excludes.length > 0) cubeObj.excludes = cubeItem.excludes;
          if (cubeItem.prefix) cubeObj.prefix = cubeItem.prefix;
          if (cubeItem.alias) cubeObj.alias = cubeItem.alias;
          
          newViewData.cubes!.push(cubeObj);
        });
        break;
      }
      case 'dimension': {
        if (!newViewData.dimensions) newViewData.dimensions = [];
        itemsToAdd.forEach((selection: any) => {
          const base = selection?.dimensionData || selection;
          if (!base) return;
          const joinPath = base.join_path || selection?.source || '';
          const dimensionName = base.name || selection?.name || (selection?.id ? String(selection.id).split('.').pop() : undefined);
          if (!dimensionName) return;
          const qualifiedName = base.qualified_name || selection?.path || (joinPath ? `${joinPath}.${dimensionName}` : dimensionName);
          const normalizedDimension = {
            ...base,
            id: base.id || selection?.id || qualifiedName,
            name: dimensionName,
            title: base.title || selection?.name || dimensionName,
            sql: base.sql || dimensionName,
            type: base.type || 'string',
            description: base.description ?? selection?.description,
            join_path: joinPath,
            qualified_name: qualifiedName,
            source: base.source || selection?.source || joinPath,
          };
          newViewData.dimensions!.push(normalizedDimension);
        });
        break;
      }
      case 'measure': {
        if (!newViewData.measures) newViewData.measures = [];
        itemsToAdd.forEach((selection: any) => {
          const base = selection?.measureData || selection;
          if (!base) return;
          const joinPath = base.join_path || selection?.source || '';
          const measureName = base.name || selection?.name || (selection?.id ? String(selection.id).split('.').pop() : undefined);
          if (!measureName) return;
          const qualifiedName = base.qualified_name || selection?.path || (joinPath ? `${joinPath}.${measureName}` : measureName);
          const normalizedMeasure = {
            ...base,
            id: base.id || selection?.id || qualifiedName,
            name: measureName,
            title: base.title || selection?.name || measureName,
            sql: base.sql || measureName,
            type: base.type || 'count',
            description: base.description ?? selection?.description,
            join_path: joinPath,
            qualified_name: qualifiedName,
            source: base.source || selection?.source || joinPath,
          };
          newViewData.measures!.push(normalizedMeasure);
        });
        break;
      }
      // folders are not supported on this page
    }

    setViewData(newViewData);
    setShowAddDialog(false);
  };

  // Remove items
  const handleRemoveItem = (type: 'cube' | 'dimension' | 'measure', index: number) => {
    const newViewData = { ...viewData };
    
    switch (type) {
      case 'cube':
        if (Array.isArray(newViewData.cubes)) {
          const cubes = [...newViewData.cubes];
          cubes.splice(index, 1);
          newViewData.cubes = cubes;
        }
        break;
      case 'dimension':
        if (Array.isArray(newViewData.dimensions)) {
          const dimensions = [...newViewData.dimensions];
          dimensions.splice(index, 1);
          newViewData.dimensions = dimensions;
        }
        break;
      case 'measure':
        if (Array.isArray(newViewData.measures)) {
          const measures = [...newViewData.measures];
          measures.splice(index, 1);
          newViewData.measures = measures;
        }
        break;
      // folders are not supported on this page
    }
    
    setViewData(newViewData);

    if (type === 'dimension' || type === 'measure') {
      clearWarnings(type, index);
      shiftWarningsAfterRemoval(type, index);
    }
  };

  // Calculate stats
  const stats = {
    joinPaths: joinPathItems.length,
    dimensions: viewData.dimensions?.length || 0,
    measures: viewData.measures?.length || 0,
  // folders removed from stats
  };

  const validationIcon = validationResult?.valid === false 
    ? <ErrorIcon color="error" />
    : validationResult?.valid === true
    ? <CheckCircle color="success" />
    : null;

  // JoinPathManager Component
  const JoinPathManager: React.FC<JoinPathManagerProps> = ({ joinPaths, onRemove, onAdd }) => {
    return (
      <Accordion defaultExpanded>
        <AccordionSummary expandIcon={<ExpandMore />}>
          <Typography variant="h6">Base & Join Paths ({joinPaths.length})</Typography>
        </AccordionSummary>
        <AccordionDetails>
          <Box sx={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', mb: 2 }}>
            <Typography variant="body2" color="text.secondary">
              Configure the primary cube and any join paths before adding dimensions or measures.
            </Typography>
            <Button variant="outlined" size="small" startIcon={<Add />} onClick={onAdd}>
              Add Join Path
            </Button>
          </Box>
          {joinPaths.length === 0 ? (
            <Box sx={{ border: '2px dashed', borderColor: 'divider', borderRadius: 1, p: 3, textAlign: 'center', color: 'text.secondary' }}>
              No join paths defined yet. Add at least one to expose fields from cubes or extended views.
            </Box>
          ) : (
            <Box sx={{ display: 'flex', flexDirection: 'column', gap: 1.5 }}>
              {joinPaths.map((item, index) => {
                const joinPathName = typeof item === 'string'
                  ? item
                  : (item?.join_path || item?.name || `cube_${index}`);
                const includes = typeof item === 'string'
                  ? '*'
                  : item?.includes ?? '*';
                const includesLabel = Array.isArray(includes)
                  ? includes.map((val: any) => (typeof val === 'string' ? val : (val?.name || val?.alias || JSON.stringify(val)))).join(', ')
                  : includes;
                const excludes = Array.isArray(item?.excludes)
                  ? item.excludes.join(', ')
                  : (typeof item?.excludes === 'string' ? item.excludes : '');
                const alias = typeof item?.alias === 'string' ? item.alias : '';
                const isPrefixed = Boolean(item?.prefix);
                const isPrimary = index === 0;

                return (
                  <Box key={`${joinPathName}_${index}`} sx={{ border: 1, borderColor: 'divider', borderRadius: 1, p: 1.5 }}>
                    <Box sx={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
                      <Box sx={{ display: 'flex', flexDirection: 'column', gap: 0.25 }}>
                        <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                          <ViewModule fontSize="small" />
                          <Typography variant="subtitle1" fontWeight={600}>{joinPathName}</Typography>
                          {alias && <Chip size="small" label={`alias: ${alias}`} />}
                          {isPrefixed && <Chip size="small" label="prefixed" />}
                        </Box>
                        <Typography variant="caption" color="text.secondary">
                          {isPrimary ? 'Primary cube' : 'Join path'} · Includes: {includesLabel === '*' ? 'all fields' : includesLabel}
                        </Typography>
                        {excludes && (
                          <Typography variant="caption" color="text.secondary">Excludes: {excludes}</Typography>
                        )}
                      </Box>
                      <IconButton aria-label={`Remove join path ${joinPathName}`} color="error" size="small" onClick={() => onRemove(index)}>
                        <Delete fontSize="small" />
                      </IconButton>
                    </Box>
                  </Box>
                );
              })}
            </Box>
          )}
        </AccordionDetails>
      </Accordion>
    );
  };

  const validationIcon = validationResult?.valid === false 
    ? <ErrorIcon color="error" />
    : validationResult?.valid === true
    ? <CheckCircle color="success" />
    : null;

  return (
    <Box sx={{ height: '100%', display: 'flex', flexDirection: 'column' }}>
      {/* Header with title and controls */}
      <Paper elevation={1} sx={{ p: 2, borderRadius: 0 }}>
        <Box sx={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
          <Box sx={{ display: 'flex', alignItems: 'center', gap: 2 }}>
            <Typography variant="h5" fontWeight={600}>
              {viewName}
            </Typography>
            {validationIcon}
          </Box>
          
          <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
            <Button
              variant="outlined"
              onClick={handleValidate}
              disabled={isValidating}
              startIcon={isValidating ? <CircularProgress size={16} /> : <CheckCircle />}
            >
              Validate
            </Button>
            <Button
              variant="contained"
              onClick={handleSave}
              disabled={isSaving}
              startIcon={isSaving ? <CircularProgress size={16} /> : <Save />}
            >
              Save
            </Button>
          </Box>
        </Box>
      </Paper>

      {/* Main Content Area */}
      <Box sx={{ flex: 1, display: 'flex', flexDirection: 'column', overflow: 'hidden' }}>
        
        {/* View Properties Section */}
        <Paper elevation={0} sx={{ p: 3, borderBottom: 1, borderColor: 'divider' }}>
          <Typography variant="h6" gutterBottom sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
            <AccountTree />
            View Properties
          </Typography>
          
          <Grid container spacing={3}>
            <Grid item xs={12} md={4}>
              <TextField
                label="Title"
                value={viewData.title || ''}
                onChange={(e) => setViewData({ ...viewData, title: e.target.value })}
                fullWidth
                size="small"
                placeholder="Display name for this view"
              />
            </Grid>
            
            <Grid item xs={12} md={4}>
              <Autocomplete
                freeSolo
                disabled={!hasTenantScope}
                options={extendsOptions}
                loading={extendsLoading}
                value={((): ExtendsOption | string | null => {
                  const current = typeof viewData?.extends === 'string' ? viewData.extends : '';
                  if (!current) return null;
                  return extendsOptions.find(opt => opt.name === current) || current;
                })()}
                inputValue={extendsInputValue}
                onInputChange={(_, newInput) => {
                  setExtendsInputValue(newInput);
                  if (extendsError) {
                    setExtendsError('');
                  }
                }}
                onChange={(_, newValue) => {
                  handleExtendsSelection(newValue);
                }}
                onBlur={() => handleExtendsSelection(extendsInputValue)}
                isOptionEqualToValue={(option, value) => {
                  const optName = typeof option === 'string' ? option : option?.name;
                  const valName = typeof value === 'string' ? value : value?.name;
                  return (optName || '').toLowerCase() === (valName || '').toLowerCase();
                }}
                filterOptions={(options) => options}
                getOptionLabel={(option) => (typeof option === 'string' ? option : option.name)}
                noOptionsText={hasTenantScope ? 'No matching views found' : 'Select a tenant and datasource first'}
                renderOption={(props, option) => {
                  const opt = typeof option === 'string' ? { name: option } : option;
                  return (
                    <li {...props} key={opt.name}>
                      <Box sx={{ display: 'flex', flexDirection: 'column', gap: 0.25 }}>
                        <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                          <Typography variant="body2" fontWeight={600}>{opt.title || opt.name}</Typography>
                          {opt.isCore && <Chip size="small" label="core" color="default" />}
                        </Box>
                        <Typography variant="caption" color="text.secondary">{opt.name}</Typography>
                        {opt.description && (
                          <Typography variant="caption" color="text.secondary">{opt.description}</Typography>
                        )}
                      </Box>
                    </li>
                  );
                }}
                renderInput={(params) => (
                  <TextField
                    {...params}
                    label="Extends"
                    size="small"
                    placeholder={hasTenantScope ? 'Search views to extend (optional)' : 'Select tenant & datasource'}
                    error={Boolean(extendsError)}
                    helperText={extendsError || (hasTenantScope ? 'Choose a core or custom view to inherit from (optional)' : 'Tenant scope required to load extendable views')}
                    InputProps={{
                      ...params.InputProps,
                      endAdornment: (
                        <>
                          {extendsLoading ? <CircularProgress color="inherit" size={16} /> : null}
                          {params.InputProps.endAdornment}
                        </>
                      ),
                    }}
                  />
                )}
              />
            </Grid>
            
            <Grid item xs={12} md={4}>
              <FormControlLabel
                control={
                  <Switch
                    checked={viewData.public !== false}
                    onChange={(e) => setViewData({ ...viewData, public: e.target.checked })}
                  />
                }
                label="Public View"
                sx={{ mt: 1 }}
              />
            </Grid>

            <Grid item xs={12}>
              <TextField
                label="Description"
                value={viewData.description || ''}
                onChange={(e) => setViewData({ ...viewData, description: e.target.value })}
                fullWidth
                multiline
                rows={2}
                size="small"
                placeholder="Human-readable description of this view"
              />
            </Grid>
          </Grid>
        </Paper>

      <JoinPathManager
        joinPaths={joinPathItems}
        onRemove={(index: number) => handleRemoveItem('cube', index)}
        onAdd={() => { setAddItemType('cube'); setShowAddDialog(true); }}
      />

      {/* Stats Palette */}
      <Box sx={{ 
        p: 2, 
        borderBottom: 1, 
        borderColor: 'divider',
        display: 'flex',
        alignItems: 'center',
        gap: 2,
        flexWrap: 'wrap'
      }}>
        <strong>Add Components:</strong>
        
        {/* Join Paths removed from Add Components per request */}
        
        <Tooltip title={`Add Dimension (${stats.dimensions} total)`}>
          <Chip
            icon={<Storage />}
            label={`Dimensions: ${stats.dimensions}`}
            onClick={() => { setAddItemType('dimension'); setShowAddDialog(true); }}
            onDelete={() => { setAddItemType('dimension'); setShowAddDialog(true); }}
            deleteIcon={<Add />}
            variant="outlined"
            color="info"
            clickable
          />
        </Tooltip>
        
        <Tooltip title={`Add Measure (${stats.measures} total)`}>
          <Chip
            icon={<BarChart />}
            label={`Measures: ${stats.measures}`}
            onClick={() => { setAddItemType('measure'); setShowAddDialog(true); }}
            onDelete={() => { setAddItemType('measure'); setShowAddDialog(true); }}
            deleteIcon={<Add />}
            variant="outlined"
            color="secondary"
            clickable
          />
        </Tooltip>
      </Box>

      {/* Edit Mode Tabs */}
      <Box sx={{ borderBottom: 1, borderColor: 'divider' }}>
        <Tabs value={editMode} onChange={(_, value) => handleEditModeChange(value)}>
          <Tab label="UI Editor" value="ui" icon={<Visibility />} />
          <Tab label="Code Editor" value="code" icon={<Code />} />
        </Tabs>
      </Box>

      {/* Validation Results */}
      {validationResult && validationResult.issues && validationResult.issues.length > 0 && (
        <Box sx={{ p: 1, borderBottom: 1, borderColor: 'divider', backgroundColor: '#fffbf0' }}>
          <Alert 
            severity={validationResult.issues.some((issue: any) => issue.level === 'error') ? 'error' : 'warning'}
            variant="outlined"
            sx={{ mb: 1 }}
          >
            <strong>Validation Issues ({validationResult.issues.length})</strong>
            <ul className={styles.validationIssuesList}>
              {validationResult.issues.slice(0, 5).map((issue: any, index: number) => (
                <li key={index} className={styles.validationIssueItem}>
                  <strong>{issue.level}:</strong> {issue.message}
                  {issue.path && <em> (at {issue.path})</em>}
                </li>
              ))}
              {validationResult.issues.length > 5 && (
                <li><em>... and {validationResult.issues.length - 5} more</em></li>
              )}
            </ul>
          </Alert>
        </Box>
      )}

      {/* Add Item Dialog */}
      <AddItemDialog
        open={showAddDialog}
        type={addItemType}
        onClose={() => setShowAddDialog(false)}
        onAdd={handleAddItem}
        tenantId={tenantId}
        datasourceId={datasourceId}
        viewData={viewData}
        onUpgradeCubeRef={(index, cubeObj) => {
          const newCubes = [...(viewData.cubes || [])];
          newCubes[index] = cubeObj;
          setViewData({ ...viewData, cubes: newCubes });
        }}
      />

      {/* Notification Snackbar */}
      <Snackbar
        open={notification.open}
        autoHideDuration={6000}
        onClose={() => setNotification({ ...notification, open: false })}
      >
        <Alert 
          severity={notification.severity} 
          onClose={() => setNotification({ ...notification, open: false })}
        >
          {notification.message}
        </Alert>
      </Snackbar>

      {/* Dimensions Section */}
      <ViewSection
        title="Dimensions"
        items={viewData.dimensions || []}
        onRemove={(index) => handleRemoveItem('dimension', index)}
        renderItem={(item, index) => (
          <DimensionCard
            key={index}
            dimension={item}
            warnings={componentWarnings.dimension[index] || []}
            onRemove={() => handleRemoveItem('dimension', index)}
            onUpdate={(updates) => {
              clearWarnings('dimension', index);
              const newDimensions = [...(viewData.dimensions || [])];
              newDimensions[index] = { ...newDimensions[index], ...updates };
              setViewData({ ...viewData, dimensions: newDimensions });
            }}
          />
        )}
      />

      {/* Measures Section */}
      <ViewSection
        title="Measures"
        items={viewData.measures || []}
        onRemove={(index) => handleRemoveItem('measure', index)}
        renderItem={(item, index) => (
          <MeasureCard
            key={index}
            measure={item}
            warnings={componentWarnings.measure[index] || []}
            onRemove={() => handleRemoveItem('measure', index)}
            onUpdate={(updates) => {
              clearWarnings('measure', index);
              const newMeasures = [...(viewData.measures || [])];
              newMeasures[index] = { ...newMeasures[index], ...updates };
              setViewData({ ...viewData, measures: newMeasures });
            }}
          />
        )}
      />

      {/* Folders removed from this view page */}

      </Box>
    </Box>
  );
};

// Section Component
interface ViewSectionProps {
  title: string;
  items: any[];
  onRemove: (index: number) => void;
  renderItem: (item: any, index: number) => React.ReactNode;
}

const ViewSection: React.FC<ViewSectionProps> = ({ title, items, renderItem }) => {
  return (
    <Accordion defaultExpanded>
      <AccordionSummary expandIcon={<ExpandMore />}>
        <Typography variant="h6">{title} ({items?.length || 0})</Typography>
      </AccordionSummary>
      <AccordionDetails>
        {(!items || items.length === 0) ? (
          <Box sx={{ p: 2, border: '2px dashed #ccc', borderRadius: 1, textAlign: 'center', color: 'text.secondary' }}>
            No {title.toLowerCase()} defined. Use the palette above to add some.
          </Box>
        ) : (
          <Box sx={{ display: 'flex', flexDirection: 'column', gap: 1 }}>
            {items.map((item, index) => renderItem(item, index))}
          </Box>
        )}
      </AccordionDetails>
    </Accordion>
  );
};

// Component Cards (simplified for this example)
const DimensionCard: React.FC<{ dimension: any; warnings?: string[]; onRemove: () => void; onUpdate: (updates: any) => void }> = ({ dimension, warnings = [], onRemove, onUpdate }) => {
  const [expanded, setExpanded] = useState(false);
  const hasWarnings = warnings.length > 0;
  const dimensionName = dimension?.name || 'Unnamed dimension';
  const dimensionType = dimension?.type || 'string';

  return (
    <Box sx={{ border: 1, borderColor: hasWarnings ? 'warning.main' : 'divider', borderRadius: 1, p: 2, backgroundColor: hasWarnings ? 'rgba(255, 247, 224, 0.6)' : 'inherit' }}>
      <Box sx={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
        <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
          <Storage />
          <strong>{dimensionName}</strong>
          <Chip label={dimensionType} size="small" />
        </Box>
        <Box>
          <IconButton onClick={() => setExpanded(!expanded)}>
            {expanded ? <VisibilityOff /> : <Visibility />}
          </IconButton>
          <IconButton onClick={onRemove} color="error">
            <ErrorIcon />
          </IconButton>
        </Box>
      </Box>
      
      {expanded && (
        <Box sx={{ mt: 2, display: 'grid', gap: 2, gridTemplateColumns: '1fr 1fr' }}>
          <TextField
            label="SQL"
            value={dimension.sql || ''}
            onChange={(e) => onUpdate({ sql: e.target.value })}
            fullWidth
          />
          <TextField
            label="Title"
            value={dimension.title || ''}
            onChange={(e) => onUpdate({ title: e.target.value })}
            fullWidth
          />
        </Box>
      )}

      {hasWarnings && (
        <Alert severity="warning" variant="outlined" sx={{ mt: 2 }}>
          <Box component="ul" sx={{ m: 0, pl: 3 }}>
            {warnings.map((message, idx) => (
              <Box component="li" key={idx} sx={{ listStyleType: 'disc' }}>
                {message}
              </Box>
            ))}
          </Box>
        </Alert>
      )}
    </Box>
  );
};

const MeasureCard: React.FC<{ measure: any; warnings?: string[]; onRemove: () => void; onUpdate: (updates: any) => void }> = ({ measure, warnings = [], onRemove, onUpdate }) => {
  const [expanded, setExpanded] = useState(false);
  const hasWarnings = warnings.length > 0;
  const measureName = measure?.name || 'Unnamed measure';
  const measureType = measure?.type || 'count';

  return (
    <Box sx={{ border: 1, borderColor: hasWarnings ? 'warning.main' : 'divider', borderRadius: 1, p: 2, backgroundColor: hasWarnings ? 'rgba(255, 247, 224, 0.6)' : 'inherit' }}>
      <Box sx={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
        <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
          <BarChart />
          <strong>{measureName}</strong>
          <Chip label={measureType} size="small" />
        </Box>
        <Box>
          <IconButton onClick={() => setExpanded(!expanded)}>
            {expanded ? <VisibilityOff /> : <Visibility />}
          </IconButton>
          <IconButton onClick={onRemove} color="error">
            <ErrorIcon />
          </IconButton>
        </Box>
      </Box>
      
      {expanded && (
        <Box sx={{ mt: 2, display: 'grid', gap: 2, gridTemplateColumns: '1fr 1fr' }}>
          <TextField
            label="SQL"
            value={measure.sql || ''}
            onChange={(e) => onUpdate({ sql: e.target.value })}
            fullWidth
          />
          <TextField
            label="Title"
            value={measure.title || ''}
            onChange={(e) => onUpdate({ title: e.target.value })}
            fullWidth
          />
        </Box>
      )}

      {hasWarnings && (
        <Alert severity="warning" variant="outlined" sx={{ mt: 2 }}>
          <Box component="ul" sx={{ m: 0, pl: 3 }}>
            {warnings.map((message, idx) => (
              <Box component="li" key={idx} sx={{ listStyleType: 'disc' }}>
                {message}
              </Box>
            ))}
          </Box>
        </Alert>
      )}
    </Box>
  );
};

// FolderCard removed - folders are not supported on this page

// Add Item Dialog
interface AddItemDialogProps {
  open: boolean;
  type: 'cube' | 'dimension' | 'measure';
  onClose: () => void;
  onAdd: (type: 'cube' | 'dimension' | 'measure', data: any) => void;
  tenantId?: string;
  datasourceId?: string;
  viewData?: any;
  onUpgradeCubeRef?: (index: number, cubeObj: any) => void; // Callback to upgrade legacy cube refs
}

export const AddItemDialog: React.FC<AddItemDialogProps> = ({ open, type, onClose, onAdd, tenantId, datasourceId, viewData, onUpgradeCubeRef }) => {
  const isMultiSelect = type === 'dimension' || type === 'measure';
  const [selectedItems, setSelectedItems] = useState<any[]>([]);
  const [inputValue, setInputValue] = useState('');
  const [loading, setLoading] = useState(false);
  const [allowedDimensionSources, setAllowedDimensionSources] = useState<any[]>([]);
  const [filterType, setFilterType] = useState<'all' | 'core' | 'custom'>('all');

  // Fetch allowed sources when dialog opens
  useEffect(() => {
    if (open && tenantId && datasourceId) {
      setLoading(true);

      if (type === 'cube') {
        // For cubes, fetch published cubes as before
        const fetchCubes = async () => {
          try {
            const dsQuery = datasourceId ? `?datasource_id=${encodeURIComponent(datasourceId)}` : '';
            const response = await fetch(`/api/fabric/models${dsQuery}`);
            if (response.ok) {
              const data = await response.json();
              const cubes = data?.models || [];
              const mapped = cubes
                .filter((cube: any) => cube.published_at || cube.is_core)
                .map((cube: any) => ({
                  id: cube.id || cube.model_key,
                  name: cube.display_name || cube.title || cube.model_key,
                  path: cube.model_key || cube.modelKey || cube.path,
                  type: 'cube',
                  source: cube.source || cube.source_config?.source || 'core',
                  description: cube.description || cube.title || cube.display_name,
                  published_at: cube.published_at || cube.publishedAt,
                  is_core: Boolean(cube.is_core),
                  is_custom: Boolean(cube.is_custom),
                }));
              mapped.sort((a: any, b: any) => {
                const pa = (a.path || a.name || '').toLowerCase();
                const pb = (b.path || b.name || '').toLowerCase();
                if (pa < pb) return -1;
                if (pa > pb) return 1;
                return 0;
              });
              setAllowedDimensionSources(mapped);
            }
          } catch (error) {
            console.error('Failed to fetch cubes:', error);
          } finally {
            setLoading(false);
          }
        };
        fetchCubes();
      } else if ((type === 'dimension' || type === 'measure') && viewData?.cubes) {
        // For dimensions/measures, fetch from the selected cube only
        const fetchDimensionsAndMeasures = async () => {
          try {
            devDebug('[AddItemDialog] Fetching dimensions/measures. viewData.cubes:', viewData.cubes);
            const dsQuery = datasourceId ? `?datasource_id=${encodeURIComponent(datasourceId)}` : '';
            const response = await fetch(`/api/fabric/models${dsQuery}`);
            if (response.ok) {
              const data = await response.json();
              const allCubes = data?.models || [];
              devDebug('[AddItemDialog] Fetched cubes from API:', allCubes.length, 'cubes');
              devDebug('[AddItemDialog] Sample cube keys:', allCubes.slice(0, 5).map((c: any) => ({
                id: c.id,
                model_key: c.model_key,
                modelKey: c.modelKey,
                path: c.path,
                display_name: c.display_name
              })));
              
              // Find employees cube specifically
              const employeesCubes = allCubes.filter((c: any) => {
                const key = c.model_key || c.modelKey || c.path || '';
                return key.toLowerCase().includes('employee');
              });
              devDebug('[AddItemDialog] Found employees cubes:', employeesCubes.map((c: any) => ({
                id: c.id,
                model_key: c.model_key,
                modelKey: c.modelKey,
                display_name: c.display_name,
                is_custom: c.is_custom
              })));

              // Find the selected cube (last added or currently selected)
              let selectedCubeRef = null;
              if (viewData.selectedCube) {
                selectedCubeRef = viewData.selectedCube;
              } else if (Array.isArray(viewData.cubes) && viewData.cubes.length > 0) {
                selectedCubeRef = viewData.cubes[viewData.cubes.length - 1];
              }
              devDebug('[AddItemDialog] Selected cube ref:', selectedCubeRef);
              if (!selectedCubeRef) {
                devWarn('[AddItemDialog] No selected cube found!');
                setAllowedDimensionSources([]);
                setLoading(false);
                return;
              }

              // Extract UUID and resolve if needed
              let cubeId = typeof selectedCubeRef === 'object' ? selectedCubeRef.id : null;
              let cubeModel = null;
              
              if (cubeId) {
                // New format: has UUID, match directly
                devDebug('[AddItemDialog] Matching by UUID:', cubeId);
                cubeModel = allCubes.find((c: any) => c.id === cubeId);
              } else {
                // Legacy format: string value, need to resolve UUID
                devDebug('[AddItemDialog] Legacy cube ref detected, resolving UUID...');
                let legacyValue = typeof selectedCubeRef === 'string' ? selectedCubeRef : (selectedCubeRef.join_path || selectedCubeRef.name);
                
                // Clean up the legacy value
                if (typeof legacyValue === 'string') {
                  legacyValue = legacyValue
                    .replace(/\s*\(Custom\)\s*/gi, '')
                    .replace(/\s*\(Core\)\s*/gi, '')
                    .trim();
                }
                
                devDebug('[AddItemDialog] Cleaned legacy value:', legacyValue);
                
                // Try to find by display_name or model_key
                cubeModel = allCubes.find((c: any) => {
                  const displayName = (c.display_name || c.displayName || '').toLowerCase().trim();
                  const modelKey = (c.model_key || c.modelKey || c.path || '').toLowerCase();
                  const searchValue = legacyValue.toLowerCase();
                  
                  // Match by display_name
                  if (displayName === searchValue || displayName === `${searchValue} (custom)`) {
                    return true;
                  }
                  
                  // Match by model_key with various patterns
                  const modelKeyStripped = modelKey.replace(/^\/public\//, '').replace(/^\//, '');
                  return modelKey === searchValue || 
                         modelKey === `/${searchValue}` ||
                         modelKey === `/public/${searchValue}` ||
                         modelKey === `/public/${searchValue}_custom` ||
                         modelKeyStripped === searchValue ||
                         modelKeyStripped === `${searchValue}_custom`;
                });
                
                if (cubeModel) {
                  devDebug('[AddItemDialog] Resolved legacy cube to UUID:', cubeModel.id);
                  cubeId = cubeModel.id;
                  
                  // Notify parent to upgrade the cube ref to include UUID
                  const cubeIndex = (viewData.cubes || []).length - 1;
                  if (onUpgradeCubeRef && cubeIndex >= 0) {
                    const upgradedCube: any = {
                      id: cubeModel.id,
                      join_path: cubeModel.model_key || cubeModel.modelKey,
                      includes: typeof selectedCubeRef === 'object' ? (selectedCubeRef.includes || '*') : '*',
                    };
                    // Copy over any existing properties
                    if (typeof selectedCubeRef === 'object') {
                      if (selectedCubeRef.alias) upgradedCube.alias = selectedCubeRef.alias;
                      if (selectedCubeRef.prefix) upgradedCube.prefix = selectedCubeRef.prefix;
                      if (selectedCubeRef.excludes) upgradedCube.excludes = selectedCubeRef.excludes;
                    }
                    onUpgradeCubeRef(cubeIndex, upgradedCube);
                    devDebug('[AddItemDialog] Upgraded cube ref to include UUID');
                  }
                }
              }
              
              const alias = typeof selectedCubeRef === 'object' ? selectedCubeRef.alias : null;
              let joinPath = typeof selectedCubeRef === 'string' ? selectedCubeRef : (selectedCubeRef.join_path || selectedCubeRef.name || cubeModel?.model_key);
              
              // Clean up joinPath
              if (typeof joinPath === 'string') {
                joinPath = joinPath
                  .replace(/\s*\(Custom\)\s*/gi, '')
                  .replace(/\s*\(Core\)\s*/gi, '')
                  .trim();
              }
              
              devDebug('[AddItemDialog] Found cube model:', cubeModel ? cubeModel.model_key || cubeModel.modelKey : 'NOT FOUND');
              if (!cubeModel) {
                devWarn('[AddItemDialog] Cube model not found for joinPath:', joinPath);
                setAllowedDimensionSources([]);
                setLoading(false);
                return;
              }

              // Extract dimensions and measures from the merged resolved config
              const rawDimensions = cubeModel.resolved_config?.cubes?.[0]?.dimensions;
              const rawMeasures = cubeModel.resolved_config?.cubes?.[0]?.measures;
              devDebug('[AddItemDialog] Raw dimensions:', rawDimensions ? Object.keys(rawDimensions).length : 0);
              devDebug('[AddItemDialog] Raw measures:', rawMeasures ? Object.keys(rawMeasures).length : 0);

              const dimensionEntries: [string, any][] = Array.isArray(rawDimensions)
                ? rawDimensions.map((dim: any, index: number): [string, any] => {
                    const fallbackName = dim?.name || dim?.sql || `dimension_${index}`;
                    return [fallbackName, dim];
                  })
                : (Object.entries(rawDimensions || {}) as [string, any][]);

              const measureEntries: [string, any][] = Array.isArray(rawMeasures)
                ? rawMeasures.map((meas: any, index: number): [string, any] => {
                    const fallbackName = meas?.name || meas?.title || `measure_${index}`;
                    return [fallbackName, meas];
                  })
                : (Object.entries(rawMeasures || {}) as [string, any][]);

              const items: any[] = [];
              if (type === 'dimension') {
                dimensionEntries.forEach(([dimKey, dimValue]: [string, any]) => {
                  const dimensionName = (dimValue && dimValue.name) || dimKey;
                  const qualifiedName = alias ? `${alias}.${dimensionName}` : `${joinPath}.${dimensionName}`;
                  items.push({
                    id: `${joinPath}.${dimensionName}`,
                    name: dimValue?.title || dimensionName,
                    path: qualifiedName,
                    type: 'dimension',
                    source: joinPath,
                    description: dimValue?.description,
                    dimensionData: {
                      ...dimValue,
                      id: `${joinPath}.${dimensionName}`,
                      name: dimensionName,
                      join_path: joinPath,
                      qualified_name: qualifiedName,
                      source: joinPath,
                      alias,
                    }
                  });
                });
              }
              if (type === 'measure') {
                measureEntries.forEach(([measureKey, measureValue]: [string, any]) => {
                  const measureName = (measureValue && measureValue.name) || measureKey;
                  const qualifiedName = alias ? `${alias}.${measureName}` : `${joinPath}.${measureName}`;
                  items.push({
                    id: `${joinPath}.${measureName}`,
                    name: measureValue?.title || measureName,
                    path: qualifiedName,
                    type: 'measure',
                    source: joinPath,
                    description: measureValue?.description,
                    measureData: {
                      ...measureValue,
                      id: `${joinPath}.${measureName}`,
                      name: measureName,
                      join_path: joinPath,
                      qualified_name: qualifiedName,
                      source: joinPath,
                      alias,
                    }
                  });
                });
              }

              items.sort((a: any, b: any) => {
                const pa = a.path.toLowerCase();
                const pb = b.path.toLowerCase();
                if (pa < pb) return -1;
                if (pa > pb) return 1;
                return 0;
              });

              devDebug('[AddItemDialog] Final items count:', items.length);
              setAllowedDimensionSources(items);
            }
          } catch (error) {
            console.error('Failed to fetch dimensions/measures:', error);
          } finally {
            setLoading(false);
          }
        };
        fetchDimensionsAndMeasures();
      } else {
        // For other types, no data needed
        setAllowedDimensionSources([]);
        setLoading(false);
      }
    }
  }, [open, tenantId, datasourceId, type, viewData]);

  // Filter options based on selected filter type
  const filteredOptions = useMemo(() => {
    if (type !== 'cube') return allowedDimensionSources;
    return allowedDimensionSources.filter(option => {
      if (filterType === 'all') return true;
      if (filterType === 'core') return option.is_core;
      if (filterType === 'custom') return option.is_custom;
      return true;
    });
  }, [allowedDimensionSources, filterType, type]);

  useEffect(() => {
    if (!open) {
      setSelectedItems([]);
      setInputValue('');
    }
  }, [open]);

  useEffect(() => {
    setFilterType('all');
    setSelectedItems([]);
    setInputValue('');
  }, [type]);

  const dialogTitle = type === 'cube' ? 'Cube' : type === 'measure' ? 'Add Measure' : 'Add Dimension';
  const searchLabel = type === 'cube' ? 'Search cubes' : type === 'measure' ? 'Search measures' : 'Search dimensions';
  const searchPlaceholder = type === 'cube' ? 'Type to search cubes...' : type === 'measure' ? 'Type to search measures...' : 'Type to search dimensions...';

  return (
    <Dialog open={open} onClose={onClose} maxWidth="sm" fullWidth>
      <ModalHeader title={<>{dialogTitle}</>} onClose={onClose} />
      <DialogContent>
        <Box sx={{ display: 'flex', flexDirection: 'column', gap: 2, mt: 1 }}>
          {/* Filter Controls - only show for cube type */}
          {type === 'cube' && (
            <Box sx={{ display: 'flex', alignItems: 'center', gap: 2, p: 2, bgcolor: 'grey.50', borderRadius: 1 }}>
              <Typography variant="body2" sx={{ fontWeight: 500, minWidth: 'fit-content' }}>
                Filter:
              </Typography>
              <Box sx={{ display: 'flex', gap: 1 }}>
                <Button
                  size="small"
                  variant={filterType === 'all' ? 'contained' : 'outlined'}
                  onClick={() => setFilterType('all')}
                  sx={{ minWidth: '60px' }}
                >
                  All
                </Button>
                <Button
                  size="small"
                  variant={filterType === 'core' ? 'contained' : 'outlined'}
                  onClick={() => setFilterType('core')}
                  sx={{ minWidth: '60px' }}
                >
                  Core
                </Button>
                <Button
                  size="small"
                  variant={filterType === 'custom' ? 'contained' : 'outlined'}
                  onClick={() => setFilterType('custom')}
                  sx={{ minWidth: '70px' }}
                >
                  Custom
                </Button>
              </Box>
              {filterType !== 'all' && (
                <Button
                  size="small"
                  variant="text"
                  onClick={() => setFilterType('all')}
                  sx={{ minWidth: 'fit-content', ml: 'auto' }}
                >
                  Clear
                </Button>
              )}
            </Box>
          )}

          <Autocomplete
            multiple={isMultiSelect}
            disableCloseOnSelect={isMultiSelect}
            options={filteredOptions}
            getOptionLabel={(opt: any) => opt.path || opt.name}
            value={isMultiSelect ? selectedItems : (selectedItems[0] ?? null)}
            onChange={(_, v) => {
              if (isMultiSelect) {
                setSelectedItems(Array.isArray(v) ? v : []);
              } else {
                setSelectedItems(v ? [v] : []);
              }
            }}
            inputValue={inputValue}
            onInputChange={(_, v) => setInputValue(v)}
            loading={loading}
            filterOptions={(opts) => opts}
            isOptionEqualToValue={(option, value) => option.id === value.id}
            renderOption={(props, option: any, { selected }) => (
              <li {...props} key={option.id}>
                <Box sx={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', width: '100%' }}>
                  <Box sx={{ display: 'flex', alignItems: 'center', gap: 1, flexGrow: 1 }}>
                    {isMultiSelect && (
                      <Checkbox
                        checked={selected}
                        tabIndex={-1}
                        disableRipple
                        size="small"
                      />
                    )}
                    <Box sx={{ flexGrow: 1 }}>
                      <Typography variant="body2" sx={{ fontWeight: 500 }}>
                        {option.name}
                      </Typography>
                      <Typography variant="caption" color="text.secondary">
                        {option.path}
                      </Typography>
                    </Box>
                  </Box>
                  <Box sx={{ display: 'flex', gap: 0.5, ml: 1 }}>
                    {option.type === 'cube' && (
                      <>
                        {option.is_core && (
                          <Chip
                            label="Core"
                            size="small"
                            color="primary"
                            variant="outlined"
                            sx={{ fontSize: '0.7rem', height: '18px' }}
                          />
                        )}
                        {option.is_custom && (
                          <Chip
                            label="Custom"
                            size="small"
                            color="secondary"
                            variant="outlined"
                            sx={{ fontSize: '0.7rem', height: '18px' }}
                          />
                        )}
                      </>
                    )}
                    {(option.type === 'dimension' || option.type === 'measure') && (
                      <Chip
                        label={option.source}
                        size="small"
                        color="info"
                        variant="outlined"
                        sx={{ fontSize: '0.7rem', height: '18px' }}
                      />
                    )}
                  </Box>
                </Box>
              </li>
            )}
            renderInput={(params) => (
              <TextField {...params} label={searchLabel} placeholder={searchPlaceholder} />
            )}
            sx={{ mb: 2 }}
          />
        </Box>
      </DialogContent>
      <DialogActions>
        <Button onClick={onClose}>Cancel</Button>
        <Button
          onClick={() => {
            if (selectedItems.length > 0) {
              const payload = isMultiSelect ? selectedItems : selectedItems[0];
              onAdd(type, payload);
            }
          }}
          disabled={selectedItems.length === 0}
          variant="contained"
        >
          {(() => {
            const baseLabel = type === 'cube' ? 'Add Cube' : type === 'measure' ? 'Add Measure' : 'Add Dimension';
            if (!isMultiSelect || selectedItems.length <= 1) return baseLabel;
            const plural = type === 'measure' ? 'Measures' : 'Dimensions';
            return `Add ${selectedItems.length} ${plural}`;
          })()}
        </Button>
      </DialogActions>
    </Dialog>
  );
};

export default ViewEditorComplete;