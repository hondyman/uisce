-- ============================================================================
-- STEP 4: Verify Data
-- ============================================================================

-- Check tenants
SELECT 'Tenants:' as info;
SELECT id, name FROM tenants WHERE id IN (
    '00000000-0000-0000-0000-000000000001',
    '00000000-0000-0000-0000-000000000002'
);

-- Check users
SELECT 'Users:' as info;
SELECT id, email, name, organization, tenant_id, is_core_admin 
FROM users 
WHERE id IN (
    '10000000-0000-0000-0000-000000000001',
    '20000000-0000-0000-0000-000000000001',
    '99000000-0000-0000-0000-000000000001'
);

-- Check business objects
SELECT 'Business Objects:' as info;
SELECT id, name, tenant_id FROM business_objects 
WHERE tenant_id IN (
    '00000000-0000-0000-0000-000000000001',
    '00000000-0000-0000-0000-000000000002'
)
ORDER BY tenant_id, name;

