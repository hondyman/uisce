      "conversation_id": {
        "type": "string",
        "displayName": "Conversation ID"
      },
      "tenant_id": {
        "type": "string",
        "displayName": "Tenant ID"
      },
      "user_id": {
        "type": "string",
        "displayName": "User ID (Hashed)"
      },
      "query_length": {
        "type": "number",
        "displayName": "Query Length"
