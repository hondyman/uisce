{
  "dashboardMetadata": {
    "name": "Semlayer Governance Platform - Performance & Observability",
    "shared": true,
    "owner": "Platform SRE",
    "description": "Real-time observability for Access Intelligence Service, conversational layer, and governance workflows",
    "tags": ["semlayer", "governance", "performance", "observability"]
  },
  "tiles": [
    {
      "name": "Access Intelligence Latency SLO",
      "type": "SLO",
      "bounds": {
        "top": 0,
        "left": 0,
        "width": 152,
        "height": 76
      },
      "tileFilter": {
        "timeframe": "-1h"
      },
      "configured": true,
      "sloTile": {
        "sloId": "semlayer.access_intelligence.latency_slo",
        "showProblems": true,
        "viewMode": "BOTH"
      }
    },
    {
      "name": "Service Method Latency p50/p95/p99",
      "type": "DATA_EXPLORER",
      "bounds": {
        "top": 76,
        "left": 0,
        "width": 304,
        "height": 228
      },
      "tileFilter": {
        "timeframe": "-1h"
      },
      "configured": true,
      "queries": [
        {
          "id": "A",
          "metric": "semlayer.access_evaluation.duration",
          "spaceAggregation": "AVG",
          "timeAggregation": "PERCENTILE_95",
          "splitBy": ["cache.hit"],
          "filterBy": {
            "dt.entity.service": ["SERVICE-ABC123"]
          }
        }
      ],
      "visualConfig": {
        "type": "GRAPH_CHART",
        "global": {
          "theme": "DEFAULT"
        },
        "rules": [
          {
            "matcher": "A:",
            "properties": {
              "color": "DEFAULT"
            },
            "seriesOverrides": []
          }
        ],
        "axes": {
          "xAxis": {
            "displayName": "",
            "visible": true
          },
          "yAxes": [
            {
              "displayName": "Latency (ms)",
              "visible": true
            }
          ]
        },
        "legend": {
          "visible": true,
          "position": "AUTO"
        }
      }
    },
    {
      "name": "Concurrent Evaluations",
      "type": "DATA_EXPLORER",
      "bounds": {
        "top": 304,
        "left": 0,
        "width": 152,
        "height": 152
      },
      "tileFilter": {
        "timeframe": "-1h"
      },
      "configured": true,
      "queries": [
        {
          "id": "A",
          "metric": "semlayer.access_evaluation.active",
          "spaceAggregation": "MAX",
          "timeAggregation": "VALUE"
        }
      ],
      "visualConfig": {
        "type": "SINGLE_VALUE",
        "global": {
          "theme": "DEFAULT"
        },
        "thresholds": [
          {
            "axisTarget": "LEFT",
            "rules": [
              {
                "color": "RED",
                "comparator": "ABOVE",
                "value": 80,
                "unit": "PERCENT"
              }
            ]
          }
        ]
      }
    },
    {
      "name": "Cache Health",
      "type": "DATA_EXPLORER",
      "bounds": {
        "top": 304,
        "left": 152,
        "width": 152,
        "height": 152
