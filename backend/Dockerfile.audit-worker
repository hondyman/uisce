FROM golang:1.25-alpine AS builder

WORKDIR /app

# Copy isolated go mod files
COPY cmd/audit-worker/go.mod cmd/audit-worker/go.sum ./

# Download dependencies
RUN go mod download

# Copy source code
COPY cmd/audit-worker/ .

# Build the worker
RUN CGO_ENABLED=0 GOOS=linux go build -o audit-worker .

# Final stage
FROM alpine:latest

RUN apk --no-cache add ca-certificates

WORKDIR /root/

COPY --from=builder /app/audit-worker .

CMD ["./audit-worker"]
