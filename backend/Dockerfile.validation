FROM golang:1.25.3-alpine AS builder

RUN apk add --no-cache git
WORKDIR /src

# Copy repo and download modules
COPY . .
RUN go mod download

# Build validation-service binary
RUN CGO_ENABLED=0 GOOS=linux go build -o /app/validation-service ./backend/cmd/validation-service

FROM alpine:3.18
RUN apk add --no-cache ca-certificates curl
WORKDIR /app

COPY --from=builder /app/validation-service /app/validation-service

EXPOSE 8082
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:8082/health || exit 1

CMD ["/app/validation-service"]
