    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/scanner/run": {
            "post": {
                "description": "Scan a datasource by providing a tenant_product_datasource_id",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "scanner"
                ],
                "summary": "Scan a datasource",
                "parameters": [
                    {
                        "description": "Datasource ID",
                        "name": "datasource_id",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.ScanRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Scan completed successfully",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Invalid request format",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Error scanning datasource",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.ScanRequest": {
            "type": "object",
            "properties": {
                "datasource_id": {
                    "type": "string"
                }
            }
        }
    }
