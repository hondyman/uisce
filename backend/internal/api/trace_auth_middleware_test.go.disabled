// TestValidateTraceAuthInsufficientRole tests that insufficient role returns forbidden
func TestValidateTraceAuthInsufficientRole(t *testing.T) {
	config := DefaultTraceAuthConfig()
	// API key has 'viewer' role, which is not in ValidRoles
	config.APIKeys["limited-key"] = []string{"viewer"}

	req := httptest.NewRequest("GET", "/traces", nil)
	req.Header.Set("X-API-Key", "limited-key")
	req.Header.Set("X-Tenant-ID", "tenant-123")

	authInfo, _, errResp, status := ValidateTraceAuth(req, config)

	if authInfo != nil {
		t.Error("Expected nil authInfo, got non-nil")
	}
	if status != http.StatusForbidden {
		t.Errorf("Expected status %d, got %d", http.StatusForbidden, status)
	}
	if errResp == nil || errResp.Error != "forbidden" {
		t.Error("Expected forbidden error response")
	}
}

// TestValidateTraceAuthSuccess tests successful authentication with valid API key
func TestValidateTraceAuthSuccess(t *testing.T) {
	config := DefaultTraceAuthConfig()
	config.APIKeys["valid-key"] = []string{"admin"}

	req := httptest.NewRequest("GET", "/traces", nil)
	req.Header.Set("X-API-Key", "valid-key")
	req.Header.Set("X-Tenant-ID", "tenant-123")
	req.Header.Set("X-User-ID", "user-456")

	authInfo, tenantID, errResp, status := ValidateTraceAuth(req, config)

	if errResp != nil {
		t.Errorf("Unexpected error: %v", errResp)
	}
	if status != 0 {
		t.Errorf("Expected status 0 on success, got %d", status)
	}
	if authInfo == nil {
		t.Fatal("Expected authInfo, got nil")
	}
	if authInfo.UserID != "user-456" {
		t.Errorf("Expected UserID 'user-456', got '%s'", authInfo.UserID)
	}
	if tenantID != "tenant-123" {
		t.Errorf("Expected tenantID 'tenant-123', got '%s'", tenantID)
	}
	if len(authInfo.TenantIDs) != 1 || authInfo.TenantIDs[0] != "tenant-123" {
		t.Error("Expected TenantIDs to contain 'tenant-123'")
	}
	if len(authInfo.Roles) != 1 || authInfo.Roles[0] != "admin" {
		t.Error("Expected Roles to contain 'admin'")
	}
}

