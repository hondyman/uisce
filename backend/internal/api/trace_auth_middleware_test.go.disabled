// TestValidateTraceAuthMissingAPIKey tests that missing API key returns unauthorized
func TestValidateTraceAuthMissingAPIKey(t *testing.T) {
	config := DefaultTraceAuthConfig()
	req := httptest.NewRequest("GET", "/traces", nil)
	req.Header.Set("X-Tenant-ID", "tenant-123")

	authInfo, _, errResp, status := ValidateTraceAuth(req, config)

	if authInfo != nil {
		t.Error("Expected nil authInfo, got non-nil")
	}
	if status != http.StatusUnauthorized {
		t.Errorf("Expected status %d, got %d", http.StatusUnauthorized, status)
	}
	if errResp == nil || errResp.Error != "unauthorized" {
		t.Error("Expected unauthorized error response")
	}
}

