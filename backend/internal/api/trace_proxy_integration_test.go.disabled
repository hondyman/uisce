// TestProxyTempoTracesBackendNotConfigured tests behavior when trace backend is not configured
func TestProxyTempoTracesBackendNotConfigured(t *testing.T) {
	t.Setenv("TRACE_QUERY_URL", "")

	server := &Server{}
	router := chi.NewRouter()
	router.Get("/traces", server.proxyTempoTraces)

	traceAuthConfig.APIKeys = make(map[string][]string)
	traceAuthConfig.APIKeys["test-key"] = []string{"admin"}

	w := httptest.NewRecorder()
	req := httptest.NewRequest("GET", "/traces?plan_id=plan-123", nil)
	req.Header.Set("X-API-Key", "test-key")
	req.Header.Set("X-Tenant-ID", "tenant-123")

	router.ServeHTTP(w, req)

	if w.Code != http.StatusServiceUnavailable {
		t.Errorf("Expected status %d, got %d", http.StatusServiceUnavailable, w.Code)
	}

	var errResp ErrorResponse
	json.NewDecoder(w.Body).Decode(&errResp)
	if errResp.Error != "service_unavailable" {
		t.Errorf("Expected 'service_unavailable' error, got '%s'", errResp.Error)
	}
}

// TestProxyTempoTracesBackendUnreachable tests behavior when trace backend is unreachable
func TestProxyTempoTracesBackendUnreachable(t *testing.T) {
	t.Setenv("TRACE_QUERY_URL", "http://unreachable-backend:3100")

	server := &Server{}
	router := chi.NewRouter()
	router.Get("/traces", server.proxyTempoTraces)

	traceAuthConfig.APIKeys = make(map[string][]string)
	traceAuthConfig.APIKeys["test-key"] = []string{"admin"}

	w := httptest.NewRecorder()
	req := httptest.NewRequest("GET", "/traces?plan_id=plan-123", nil)
	req.Header.Set("X-API-Key", "test-key")
	req.Header.Set("X-Tenant-ID", "tenant-123")

	router.ServeHTTP(w, req)

	if w.Code != http.StatusBadGateway {
		t.Errorf("Expected status %d, got %d", http.StatusBadGateway, w.Code)
	}

	var errResp ErrorResponse
	json.NewDecoder(w.Body).Decode(&errResp)
	if errResp.Error != "trace_backend_unreachable" {
		t.Errorf("Expected 'trace_backend_unreachable' error, got '%s'", errResp.Error)
	}
}

// TestProxyTempoGetTraceWithValidAuth tests fetching a specific trace with valid authentication
func TestProxyTempoGetTraceWithValidAuth(t *testing.T) {
	mockBackend := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		pathParam := r.URL.Path
		if bytes.Contains([]byte(pathParam), []byte("0123456789abcdef0123456789abcdef")) {
			w.Header().Set("Content-Type", "application/json")
			json.NewEncoder(w).Encode(map[string]interface{}{
				"traceID": "0123456789abcdef0123456789abcdef",
				"spans": []map[string]interface{}{
					{
						"spanID": "span-1",
						"tags": []map[string]string{
							{"key": "tenant_id", "value": "tenant-123"},
						},
					},
				},
			})
		} else {
			w.WriteHeader(http.StatusNotFound)
		}
	}))
	defer mockBackend.Close()

	t.Setenv("TRACE_QUERY_URL", mockBackend.URL)

	server := &Server{}
	router := chi.NewRouter()
	router.Get("/traces/{traceId}", server.proxyTempoGetTrace)

	traceAuthConfig.APIKeys = make(map[string][]string)
	traceAuthConfig.APIKeys["test-key"] = []string{"admin"}

	w := httptest.NewRecorder()
	req := httptest.NewRequest("GET", "/traces/0123456789abcdef0123456789abcdef", nil)
	req.Header.Set("X-API-Key", "test-key")
	req.Header.Set("X-Tenant-ID", "tenant-123")

	router.ServeHTTP(w, req)

	if w.Code != http.StatusOK {
		t.Errorf("Expected status %d, got %d", http.StatusOK, w.Code)
		t.Logf("Response body: %s", w.Body.String())
	}
}

