// TestProxyTempoTracesWithValidAuth tests tracing search with valid authentication
func TestProxyTempoTracesWithValidAuth(t *testing.T) {
	// Create a mock trace backend
	mockBackend := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		if r.URL.Query().Get("plan_id") == "plan-123" {
			w.Header().Set("Content-Type", "application/json")
			json.NewEncoder(w).Encode(map[string]interface{}{
				"traces": []map[string]interface{}{
					{
						"traceID": "trace-1",
						"spans": []map[string]interface{}{
							{
								"spanID": "span-1",
								"tags": []map[string]string{
									{"key": "tenant_id", "value": "tenant-123"},
								},
							},
						},
					},
				},
			})
		} else {
			w.WriteHeader(http.StatusNotFound)
		}
	}))
	defer mockBackend.Close()

	t.Setenv("TRACE_QUERY_URL", mockBackend.URL)

	// Create server with auth config
	server := &Server{}
	router := chi.NewRouter()
	router.Get("/traces", server.proxyTempoTraces)

	// Setup auth config with test API key
	traceAuthConfig.APIKeys["test-key"] = []string{"admin"}

	// Make authenticated request
	w := httptest.NewRecorder()
	req := httptest.NewRequest("GET", "/traces?plan_id=plan-123", nil)
	req.Header.Set("X-API-Key", "test-key")
	req.Header.Set("X-Tenant-ID", "tenant-123")

	router.ServeHTTP(w, req)

	if w.Code != http.StatusOK {
		t.Errorf("Expected status %d, got %d", http.StatusOK, w.Code)
	}

	if w.Header().Get("Content-Type") != "application/json" {
		t.Error("Expected Content-Type: application/json")
	}

	if w.Header().Get("X-Tenant-ID") != "tenant-123" {
		t.Error("Expected X-Tenant-ID header in response")
	}
}

// TestProxyTempoTracesWithoutAuth tests that requests without auth are rejected
func TestProxyTempoTracesWithoutAuth(t *testing.T) {
	t.Setenv("TRACE_QUERY_URL", "http://localhost:3100")

	server := &Server{}
	router := chi.NewRouter()
	router.Get("/traces", server.proxyTempoTraces)

	w := httptest.NewRecorder()
	req := httptest.NewRequest("GET", "/traces?plan_id=plan-123", nil)
	// Deliberately omit X-API-Key and X-Tenant-ID

	router.ServeHTTP(w, req)

	if w.Code != http.StatusUnauthorized {
		t.Errorf("Expected status %d, got %d", http.StatusUnauthorized, w.Code)
	}

	var errResp ErrorResponse
	json.NewDecoder(w.Body).Decode(&errResp)
	if errResp.Error != "unauthorized" {
		t.Errorf("Expected 'unauthorized' error, got '%s'", errResp.Error)
	}
}

// TestProxyTempoTracesWithInvalidAPIKey tests that invalid API keys are rejected
func TestProxyTempoTracesWithInvalidAPIKey(t *testing.T) {
	t.Setenv("TRACE_QUERY_URL", "http://localhost:3100")

	server := &Server{}
	router := chi.NewRouter()
	router.Get("/traces", server.proxyTempoTraces)

	// Ensure the invalid key is not in config
	traceAuthConfig.APIKeys = make(map[string][]string)
	traceAuthConfig.APIKeys["valid-key"] = []string{"admin"}

	w := httptest.NewRecorder()
	req := httptest.NewRequest("GET", "/traces?plan_id=plan-123", nil)
	req.Header.Set("X-API-Key", "invalid-key")
	req.Header.Set("X-Tenant-ID", "tenant-123")

	router.ServeHTTP(w, req)

	if w.Code != http.StatusUnauthorized {
		t.Errorf("Expected status %d, got %d", http.StatusUnauthorized, w.Code)
	}
}

