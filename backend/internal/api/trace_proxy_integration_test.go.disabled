// TestCacheControlHeaders tests that trace responses have appropriate cache headers
func TestCacheControlHeaders(t *testing.T) {
	mockBackend := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		io.WriteString(w, `{"traces":[]}`)
	}))
	defer mockBackend.Close()

	t.Setenv("TRACE_QUERY_URL", mockBackend.URL)

	server := &Server{}
	router := chi.NewRouter()
	router.Get("/traces", server.proxyTempoTraces)

	traceAuthConfig.APIKeys = make(map[string][]string)
	traceAuthConfig.APIKeys["test-key"] = []string{"admin"}

	w := httptest.NewRecorder()
	req := httptest.NewRequest("GET", "/traces?plan_id=plan-123", nil)
	req.Header.Set("X-API-Key", "test-key")
	req.Header.Set("X-Tenant-ID", "tenant-123")

	router.ServeHTTP(w, req)

	cacheControl := w.Header().Get("Cache-Control")
	if cacheControl != "no-cache, no-store, must-revalidate" {
		t.Errorf("Expected proper cache control header, got: %s", cacheControl)
	}
}

// TestTenantIsolationInResponse tests that trace responses are filtered by tenant
func TestTenantIsolationInResponse(t *testing.T) {
	mockBackend := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		// Return traces from multiple tenants
		json.NewEncoder(w).Encode(map[string]interface{}{
			"spans": []interface{}{
				map[string]interface{}{
					"spanID": "span-1",
					"tags": []map[string]string{
						{"key": "tenant_id", "value": "tenant-123"},
					},
				},
				map[string]interface{}{
					"spanID": "span-2",
					"tags": []map[string]string{
						{"key": "tenant_id", "value": "tenant-999"},
					},
				},
			},
		})
	}))
	defer mockBackend.Close()

	t.Setenv("TRACE_QUERY_URL", mockBackend.URL)

	server := &Server{}
	router := chi.NewRouter()
	router.Get("/traces", server.proxyTempoTraces)

	traceAuthConfig.APIKeys = make(map[string][]string)
	traceAuthConfig.APIKeys["test-key"] = []string{"admin"}

	w := httptest.NewRecorder()
	req := httptest.NewRequest("GET", "/traces?plan_id=plan-123", nil)
	req.Header.Set("X-API-Key", "test-key")
	req.Header.Set("X-Tenant-ID", "tenant-123")

	router.ServeHTTP(w, req)

	if w.Code != http.StatusOK {
		t.Errorf("Expected status %d, got %d", http.StatusOK, w.Code)
	}

	// Parse response and verify only tenant-123 spans are included
	var response map[string]interface{}
	if err := json.NewDecoder(w.Body).Decode(&response); err != nil {
		t.Fatalf("Failed to decode response: %v", err)
	}

	if spans, ok := response["spans"].([]interface{}); ok {
		if len(spans) != 1 {
			t.Errorf("Expected 1 filtered span, got %d", len(spans))
		}
	}
}

// TestMultipleRoleAccess tests that users with different authorized roles can access traces
func TestMultipleRoleAccess(t *testing.T) {
	roles := []string{"admin", "sre", "ops_manager"}

	for _, role := range roles {
		mockBackend := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
			w.Header().Set("Content-Type", "application/json")
			json.NewEncoder(w).Encode(map[string]interface{}{"traces": []interface{}{}})
		}))
		defer mockBackend.Close()

		t.Setenv("TRACE_QUERY_URL", mockBackend.URL)

		server := &Server{}
		router := chi.NewRouter()
		router.Get("/traces", server.proxyTempoTraces)

		traceAuthConfig.APIKeys = make(map[string][]string)
		traceAuthConfig.APIKeys["test-key"] = []string{role}

		w := httptest.NewRecorder()
		req := httptest.NewRequest("GET", "/traces?plan_id=plan-123", nil)
		req.Header.Set("X-API-Key", "test-key")
		req.Header.Set("X-Tenant-ID", "tenant-123")

		router.ServeHTTP(w, req)

		if w.Code != http.StatusOK {
			t.Errorf("Expected status %d for role %s, got %d", http.StatusOK, role, w.Code)
		}
	}
}
