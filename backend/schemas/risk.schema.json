{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://semlayer.io/schemas/risk/v1",
    "title": "RiskContexts",
    "description": "Input contexts for risk engine computations",
    "definitions": {
        "FactorModelContext": {
            "type": "object",
            "required": [
                "portfolio",
                "positions",
                "factor_exposures",
                "factor_covariance",
                "tenant_id"
            ],
            "properties": {
                "portfolio": {
                    "type": "object",
                    "required": [
                        "id",
                        "aum"
                    ],
                    "properties": {
                        "id": {
                            "type": "string",
                            "format": "uuid"
                        },
                        "aum": {
                            "type": "number",
                            "minimum": 0
                        }
                    }
                },
                "positions": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "security_id",
                            "market_value"
                        ],
                        "properties": {
                            "security_id": {
                                "type": "string",
                                "format": "uuid"
                            },
                            "market_value": {
                                "type": "number",
                                "minimum": 0
                            }
                        }
                    }
                },
                "factor_exposures": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "security_id",
                            "factor_id",
                            "exposure"
                        ],
                        "properties": {
                            "security_id": {
                                "type": "string",
                                "format": "uuid"
                            },
                            "factor_id": {
                                "type": "string"
                            },
                            "exposure": {
                                "type": "number"
                            }
                        }
                    }
                },
                "factor_covariance": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "number"
                        }
                    }
                },
                "tenant_id": {
                    "type": "string",
                    "format": "uuid"
                }
            }
        },
        "VaRContext": {
            "type": "object",
            "required": [
                "portfolio",
                "method",
                "confidence_levels",
                "tenant_id"
            ],
            "properties": {
                "portfolio": {
                    "$ref": "#/definitions/FactorModelContext/properties/portfolio"
                },
                "method": {
                    "type": "string",
                    "enum": [
                        "historical",
                        "parametric"
                    ]
                },
                "returns": {
                    "type": "array",
                    "items": {
                        "type": "number"
                    }
                },
                "confidence_levels": {
                    "type": "array",
                    "items": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1
                    },
                    "minItems": 1
                },
                "factor_exposures": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "number"
                    }
                },
                "factor_covariance": {
                    "$ref": "#/definitions/FactorModelContext/properties/factor_covariance"
                },
                "tenant_id": {
                    "type": "string",
                    "format": "uuid"
                }
            },
            "oneOf": [
                {
                    "required": [
                        "returns"
                    ],
                    "properties": {
                        "method": {
                            "const": "historical"
                        }
                    }
                },
                {
                    "required": [
                        "factor_exposures",
                        "factor_covariance"
                    ],
                    "properties": {
                        "method": {
                            "const": "parametric"
                        }
                    }
                }
            ]
        }
    }
}