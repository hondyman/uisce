{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://semlayer.io/schemas/scenario_context/v1",
    "title": "ScenarioContext",
    "type": "object",
    "required": [
        "portfolio",
        "positions",
        "scenario",
        "tenant_id"
    ],
    "properties": {
        "portfolio": {
            "type": "object",
            "required": [
                "id",
                "aum"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uuid"
                },
                "aum": {
                    "type": "number",
                    "minimum": 0
                }
            }
        },
        "positions": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "security_id",
                    "market_value",
                    "factor_exposures"
                ],
                "properties": {
                    "security_id": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "market_value": {
                        "type": "number",
                        "minimum": 0
                    },
                    "factor_exposures": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "number"
                        }
                    }
                }
            }
        },
        "scenario": {
            "type": "object",
            "required": [
                "scenario_id",
                "name",
                "shocks"
            ],
            "properties": {
                "scenario_id": {
                    "type": "string",
                    "format": "uuid"
                },
                "name": {
                    "type": "string"
                },
                "shocks": {
                    "type": "object",
                    "required": [
                        "factors"
                    ],
                    "properties": {
                        "factors": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "required": [
                                    "factor_id",
                                    "shock"
                                ],
                                "properties": {
                                    "factor_id": {
                                        "type": "string"
                                    },
                                    "shock": {
                                        "type": "number"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "tenant_id": {
            "type": "string",
            "format": "uuid"
        }
    }
}