FROM golang:1.21-alpine AS builder

WORKDIR /app

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source
COPY . .

# Build the audit sink consumer
RUN CGO_ENABLED=0 GOOS=linux go build -o audit-sink ./cmd/audit-sink

FROM alpine:latest

RUN apk --no-cache add ca-certificates

WORKDIR /root/

COPY --from=builder /app/audit-sink .

CMD ["./audit-sink"]
