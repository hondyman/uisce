## Copy this file to .env and update values before running `docker compose up`
# On macOS Docker Desktop `host.docker.internal` resolves to the host machine
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PWD=your_local_postgres_password
POSTGRES_DATABASE=temporal

# Optional: override Temporal image versions here
TEMPORAL_IMAGE_VERSION=1.24.1

# Notes:
# - Replace POSTGRES_PWD with your actual local Postgres password.
# - For local development you may need to adjust pg_hba.conf and listen_addresses.