{
  "name": "entity-manager",
  "version": "1.0.0",
  "description": "Production-grade entity management system with polymorphic validation and integrated workflows",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "demo:create-accounts": "curl -X POST http://localhost:4000/api/demo/create-sample-accounts",
    "demo:validate-trade": "curl -X POST http://localhost:4000/api/demo/validate-trade",
    "demo:compliance": "curl http://localhost:4000/api/compliance/validate-all"
  },
  "dependencies": {
    "@apollo/client": "^3.8.8",
    "apollo-server-express": "^3.12.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "helmet": "^7.1.0",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "temporalio": "^1.8.6",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "kafkajs": "^2.2.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "entity-management",
    "polymorphic-validation",
    "temporal-workflows",
    "hasura",
    "typescript"
  ],
  "author": "SemLayer Team",
  "license": "MIT"
}
