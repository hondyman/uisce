diff --git a/frontend/src/components/common/semanticChips.tsx b/frontend/src/components/common/semanticChips.tsx
new file mode 100644
index 0000000..251fdfd
--- /dev/null
+++ b/frontend/src/components/common/semanticChips.tsx
@@ -0,0 +1,28 @@
+import React from 'react';
+import { Chip, Stack } from '@mui/material';
+
+// Centralized colors for Core and Custom chips. Use MUI palette names so
+// colors remain theme-aware and consistent across the app.
+const CORE_COLOR: 'success' = 'success';
+const CUSTOM_COLOR: 'warning' = 'warning';
+
+export function renderCoreCustomChips(option?: any) {
+  if (!option) return null;
+  const isCore = Boolean(option.isCore ?? option.is_core);
+  const isCustom = Boolean(option.isCustom ?? option.is_custom);
+  const chips: React.ReactNode[] = [];
+  if (isCore) {
+    chips.push(
+      <Chip key="core" label="Core" size="small" color={CORE_COLOR} variant="outlined" />
+    );
+  }
+  if (isCustom) {
+    chips.push(
+      <Chip key="custom" label="Custom" size="small" color={CUSTOM_COLOR} variant="outlined" />
+    );
+  }
+  if (chips.length === 0) return null;
+  return <Stack direction="row" spacing={0.5} sx={{ ml: 1, flexWrap: 'nowrap' }}>{chips}</Stack>;
+}
+
+export default renderCoreCustomChips;
