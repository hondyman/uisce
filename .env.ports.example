# =============================================================================
# Port Configuration for SemLayer Services
# =============================================================================
# This file centralizes all port mappings for Docker Compose services.
# Copy this file to .env.ports and customize as needed for your environment.

# =============================================================================
# Infrastructure Services
# =============================================================================

# PostgreSQL (Trino/Iceberg Metastore)
METASTORE_PORT=5433

# Redpanda (Kafka-compatible streaming)
REDPANDA_KAFKA_PORT=9092
REDPANDA_OUTSIDE_PORT=19092
REDPANDA_ADMIN_PORT=9644
REDPANDA_SCHEMA_PORT=8081
REDPANDA_CONSOLE_PORT=8096

# Debezium (CDC connector)
DEBEZIUM_PORT=8083

# MinIO (Object storage)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# RisingWave (Real-time analytics)
RISINGWAVE_PORT=4566

# Trino (Query engine)
TRINO_PORT=8084

# Cube.js (Semantic layer)
CUBE_API_PORT=4000
CUBE_PG_PORT=15432

# Hasura (GraphQL engine)
HASURA_PORT=8085

# =============================================================================
# Application Microservices
# Port Range: 8001-8099
# All services use internal port 8080, mapped to unique external ports
# =============================================================================

# Core Services
BACKEND_PORT=8082
API_GATEWAY_PORT=8001

# Business Process Services
BP_BACKEND_PORT=8086

# Data Management Services
ENTITY_MANAGER_PORT=8087
NBA_ML_SERVICE_PORT=8088

# Infrastructure Services
NOTIFICATIONS_PORT=8089
VALIDATION_ENGINE_PORT=8090
RULE_ENGINE_PORT=8091
SEARCH_SERVICE_PORT=8092
POLICY_ENGINE_PORT=8093

# Analytics & Compliance
ANALYTICS_ENGINE_PORT=8094
COMPLIANCE_ENGINE_PORT=8095
CATALOG_SYNC_PORT=8097

# =============================================================================
# Notes
# =============================================================================
# 
# Port Range Allocation Strategy:
# - 4000-4999: Analytics & Data services
# - 5000-5999: Databases and database-like services
# - 8000-8099: Core platform and microservices
# - 9000-9999: Infrastructure (Message queues, object storage)
# - 15000+: Alternate protocols
#
# Important:
# - All application services use internal port 8080
# - External ports are mapped via docker-compose.yml
# - Worker services (sync-worker, event-router, etc.) have no exposed ports
#
# To change a port:
# 1. Update the value in this file
# 2. Restart the affected service: docker-compose up -d <service-name>
# 3. Update any clients that connect to the service
