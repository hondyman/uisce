*/// Should return: Audit records in JSON format  }'    "format": "json"    "end_date": "2026-02-01T00:00:00Z",    "start_date": "2026-01-01T00:00:00Z",  -d '{  -H "Authorization: Bearer <token>" \  -H "Content-Type: application/json" \curl -X POST http://localhost:8081/api/v1/audit/reports \// Test audit reports// Should return: JSON with security metrics  -H "Authorization: Bearer <admin-token>"curl -X GET http://localhost:8081/api/security/dashboard \// Test security dashboard// Some should return: 429 Too Many Requestsdone    -H "X-Tenant-ID: tenant-id"    -H "Authorization: Bearer <token>" \  curl -X GET http://localhost:8081/api/v1/calendars \for i in {1..25}; do// Test rate limiting (make >20 requests quickly)// Should return: 200 OK with data  -H "X-Tenant-ID: tenant-id"  -H "Authorization: Bearer <valid-jwt>" \curl -X GET http://localhost:8081/api/v1/calendars \// Test with valid token// Should return: 401 Unauthorizedcurl -X GET http://localhost:8081/api/v1/calendars// Test JWT authentication// Should show: X-Content-Type-Options: nosniff, etc.curl -I http://localhost:8081/api/v1/calendars// Test security headers/*// ================================================================// TESTING: Verify Integration// ================================================================*/rateLimiter.UpdateLimits(5.0, 10)// Update limits dynamically if needed// Returns: {total_limiters: 42, rps: 10.0, burst: 20, version: "1.0"}stats := rateLimiter.GetStats()// Get current rate limiter stats for monitoring/*// ================================================================// EXAMPLE: Rate Limit Monitoring// ================================================================*/}    json.NewEncoder(w).Encode(map[string]string{"status": "logged_out"})    w.WriteHeader(http.StatusOK)    w.Header().Set("Content-Type", "application/json")        }        metrics.RecordTokenRevoked("logout")        // Record metric                }            h.logger.WithError(err).Error("Token revocation failed")        if err != nil {        err := h.tokenRevoker.Revoke(ctx, jti, userID, 0)    if jti != "" {    // Phase 3: Revoke token        userID := middleware.ExtractUserIDFromContext(ctx)    jti := middleware.ExtractJTIFromContext(ctx)    // Extract token info from context        ctx := r.Context()func (h *AuthHandler) Logout(w http.ResponseWriter, r *http.Request) {/*// ================================================================// EXAMPLE: Using Token Revocation on Logout// ================================================================*/}    json.NewEncoder(w).Encode(result)    w.Header().Set("Content-Type", "application/json")        }        return        http.Error(w, err.Error(), http.StatusInternalServerError)        h.logger.WithError(err).Error("Operation failed")    if err != nil {    result, err := h.service.DoSomething(ctx, tenantID, userID)    // Perform operation        metrics.RecordAuditLog("calendar", "create")    // Phase 4: Record audit entry        }        return        http.Error(w, "Forbidden: admin role required", http.StatusForbidden)    if !middleware.HasRole(ctx, "admin") {    // Check if user has required role        roles := middleware.ExtractRolesFromContext(ctx)    tenantID := middleware.ExtractTenantIDFromContext(ctx)        }        return        http.Error(w, "Unauthorized", http.StatusUnauthorized)    if err != nil {    userID, err := middleware.ExtractUserIDFromContextStrict(ctx)    // Phase 2: Extract JWT context with error handling        ctx := r.Context()func (h *MyHandler) MyEndpoint(w http.ResponseWriter, r *http.Request) {/*// ================================================================// EXAMPLE: Using JWT Context in Handler// ================================================================}	return router	}).Info("Security configuration loaded")		"jwt_auth": "enabled",		"security_headers": "enabled",		"token_revocation": "enabled",		"rate_limit_burst": rateLimitBurst,		"rate_limit_rps":  rateLimitRPS,	logger.WithFields(logrus.Fields{	logger.Info("✅ Security hardening enabled")	//     TOKEN_REVOCATION_TTL - TTL for revoked tokens (default: 24h)	//     JWT_SECRET          - REQUIRED: Secret for JWT signing	//     RATE_LIMIT_BURST    - Burst capacity (default: 20)	//     RATE_LIMIT_RPS      - Requests per second per tenant (default: 10.0)	//     REDIS_URL           - Redis connection (default: redis://localhost:6379)	// Environment variables used:	// ================================================================	// CONFIGURATION REFERENCE	// ================================================================	// router.Handle("/metrics", promhttp.Handler())	// 	// import "github.com/prometheus/client_golang/prometheus/promhttp"	// 	// Add Prometheus /metrics endpoint (usually port 8081):	// ================================================================	// PROMETHEUS METRICS ENDPOINT	// ================================================================	//     metrics.RecordDataResidencyViolation(tenantID, "wrong_region")	//     metrics.RecordSecurityEvent("auth_failure")	//     metrics.RecordAuditLog("calendar", "create")	// Compliance:	//	//     metrics.RecordTokenRevoked("logout")	//     metrics.RecordRateLimitExceeded(tenantID)	//     metrics.RecordAuthzFailure(tenantID, "calendar", "access_denied")	//     metrics.RecordAuthFailure("invalid_token")	// Failures:	//	//     metrics.RecordAuthSuccess()	// Success:	//	// Throughout your handlers, record security metrics:	// ================================================================	// MONITORING: Record Security Events	// ================================================================	// }	//     w.WriteHeader(http.StatusNoContent)	//     	//     }	//         }	//             logger.WithError(err).Warn("Failed to revoke token")	//         if err != nil {	//         err := tokenRevoker.Revoke(ctx, jti, userID, 0)	//     if jti != "" {	//     	//     userID := middleware.ExtractUserIDFromContext(ctx)	//     jti := middleware.ExtractJTIFromContext(ctx)	//     ctx := r.Context()	// func (h *Handler) Logout(w http.ResponseWriter, r *http.Request) {	// 	// When user logs out, revoke their token:	// ================================================================	// MONITORING: Token Revocation Example	// ================================================================	// ... other endpoints	//     Methods("POST")	//     calendarHandler.Create).	// router.HandleFunc("/api/v1/calendars",	// - etc.	// - middleware.ExtractEmailFromContext(ctx)	// - middleware.ExtractTenantIDFromContext(ctx)	// - middleware.ExtractUserIDFromContext(ctx)	// Existing calendar handlers automatically use JWT context:	// ================================================================	// HANDLERS: Existing Handlers with JWT Context (Phase 2)	// ================================================================	//     Methods("GET")	//     auditReportHandler.VerifyCompliance).	// router.HandleFunc("/api/v1/audit/compliance",	//     Methods("GET")	//     auditReportHandler.GetSummary).	// router.HandleFunc("/api/v1/audit/summary",	//     Methods("POST")	//     auditReportHandler.GenerateReport).	// router.HandleFunc("/api/v1/audit/reports",	// )	//     logger.WithField("handler", "audit_report"),	//     *auditReportService,	// auditReportHandler := api.NewAuditReportHandler(	// Audit Report API (POST /api/v1/audit/reports)	// ================================================================	// HANDLERS: Audit Reports (Phase 4)	// ================================================================		Methods("GET")		securityDashboardHandler.HealthCheck).	router.HandleFunc("/api/security/health",		Methods("GET")		securityDashboardHandler.GetDashboard).	router.HandleFunc("/api/security/dashboard",	)		logger.WithField("handler", "security_dashboard"),		nil, // Would pass Prometheus registry in production	securityDashboardHandler := api.NewSecurityDashboardHandler(	// Security Dashboard API (GET /api/security/dashboard)	// ================================================================	// HANDLERS: Security Dashboard (Phase 4)	// ================================================================	router.Use(rateLimiter.RateLimit)	// Must come AFTER JWT and TenantGuard so we have tenant context	// 4. Add rate limiting middleware (Phase 3)	router.Use(middleware.TenantGuardMiddleware(logger.WithField("component", "tenant-guard")))	// Ensures user has access to requested tenant	// 3. Add tenant guard middleware (Phase 2)	router.Use(middleware.JWTMiddleware(jwtSecret, logger.WithField("component", "jwt")))	}		logger.Fatal("JWT_SECRET environment variable not set")	if jwtSecret == "" {	jwtSecret := os.Getenv("JWT_SECRET")	// Extracts claims into context	// 2. Add JWT middleware (Phase 2)	// router.Use(middleware.SecurityHeadersStrict)	// Alternative: Use strict variant for APIs only	router.Use(middleware.SecurityHeaders)	// Prevents MIME sniffing, clickjacking, XSS, etc.	// 1. Add security headers (Phase 3)	// 6. Logging/Metrics (observation)	// 5. Rate Limiting (traffic control)	// 4. Tenant Guard (authorization)	// 3. JWT Middleware (authentication)	// 2. Security Headers (CORS, CSP, XSS protection)	// 1. Request ID (for tracing)	// MIDDLEWARE CHAIN ORDER IS CRUCIAL:	router := mux.NewRouter()	// ================================================================	// SETUP: Router with Middleware Chain	// ================================================================	// auditReportService := services.NewAuditReportService(db, logger)	// Requires database connection	// Audit Report Service (Phase 4)		// For this example, we'll show how to create the new services:		// (calendar service, audit service, etc.)	// Assuming you have these services already initialized	// ================================================================	// Initialize Services	// ================================================================	// They're registered with the default registry and available at /metrics	// via promauto in internal/metrics/security_metrics.go	// Prometheus metrics are already initialized and exposed automatically	// ================================================================	// PHASE 4: Initialize Security Metrics & Monitoring	// ================================================================	)		logger.WithField("component", "rate-limiter"),		rateLimitBurst,		rateLimitRPS,	rateLimiter := middleware.NewTenantRateLimiter(	}		fmt.Sscanf(rpsStr, "%f", &rateLimitRPS)		// Parse float value	if rpsStr := os.Getenv("RATE_LIMIT_RPS"); rpsStr != "" {	// Allow override from environment	rateLimitBurst := 20 // max burst capacity	rateLimitRPS := 10.0 // requests per second per tenant	// ================================================================	// PHASE 3: Initialize Rate Limiting (Per-tenant)	// ================================================================	)		logger.WithField("component", "token_revoker"),		24*time.Hour,         // Default TTL for revoked tokens		"calendar",           // Redis key prefix		redisClient,	tokenRevoker := security.NewTokenRevoker(	}		logger.WithError(err).Warn("Warning: Redis not available - token revocation disabled")	if err := redisClient.Ping(context.Background()).Err(); err != nil {	// Test Redis connection	})		Addr: redisURL,	redisClient := redis.NewClient(&redis.Options{	}		redisURL = "redis://localhost:6379"	if redisURL == "" {	redisURL := os.Getenv("REDIS_URL")		// ================================================================	// PHASE 3: Initialize Token Revocation (Redis-backed)	// ================================================================func ExampleSecurityIntegration(logger *logrus.Logger) *mux.Router {// ExampleSecurityIntegration demonstrates how to set up all security components)	"github.com/sirupsen/logrus"	"github.com/gorilla/mux"	"github.com/go-redis/redis/v8"	"calendar-service/internal/services"	"calendar-service/internal/security"	"calendar-service/internal/metrics"	"calendar-service/internal/middleware"	"calendar-service/internal/api"