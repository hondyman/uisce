# ===========================
# SERVER CONFIGURATION
# ===========================
SERVER_PORT=8081
ENVIRONMENT=development
LOG_LEVEL=info

# ===========================
# DATABASE (PostgreSQL)
# ===========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=calendar_db
POSTGRES_SSL_MODE=disable

# ===========================
# HASURA GRAPHQL
# ===========================
HASURA_ENDPOINT=http://localhost:8080/v1/graphql
HASURA_ADMIN_SECRET=myadminsecret
HASURA_JWT_SECRET=your-secret-key

# ===========================
# TEMPORAL (Orchestration)
# ===========================
TEMPORAL_HOST_PORT=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=calendar-task-queue

# ===========================
# REDPANDA (Event Streaming)
# ===========================
REDPANDA_BROKERS=localhost:9092
REDPANDA_CDC_TOPIC=cdc_holidays
REDPANDA_CONSUMER_GROUP=calendar-cdc-group

# ===========================
# REDIS (Caching)
# ===========================
REDIS_URL=localhost:6379
REDIS_CACHE_TTL=3600
REDIS_PREFIX=calendar
CACHE_ENABLED=true

# ===========================
# GLOBAL DISTRIBUTION
# ===========================
WORKER_REGIONS=us-east-1,eu-west-1,ap-southeast-1
DEFAULT_REGION=us-east-1
DATA_RESIDENCY_POLICY=strict

# ===========================
# JOB PRIORITY
# ===========================
PRIORITY_QUEUES=critical,standard,bulk
DEFAULT_PRIORITY=5
CRITICAL_QUEUE_WORKERS=3
STANDARD_QUEUE_WORKERS=2
BULK_QUEUE_WORKERS=1

# ===========================
# AI INTEGRATION (Phase 3)
# ===========================
AI_API_KEY=your-ai-api-key
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4
AI_TIMEOUT=30

# ===========================
# SECURITY
# ===========================
JWT_SIGNING_KEY=your-jwt-signing-key
ENCRYPTION_KEY=your-32-byte-encryption-key
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================
# MONITORING
# ===========================
PROMETHEUS_PORT=9090
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
METRICS_ENABLED=true
