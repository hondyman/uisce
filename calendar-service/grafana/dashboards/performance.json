    "panels": [
        {
            "title": "Query Cache Hit Rate",
            "type": "timeseries",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "sum(rate(calendar_cache_hits_total[5m])) / (sum(rate(calendar_cache_hits_total[5m])) + sum(rate(calendar_cache_misses_total[5m])))",
                    "legendFormat": "Hit Rate",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Query Latency",
            "type": "timeseries",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=~\"/api/v1/availability.*\"}[5m])) by (le))",
                    "legendFormat": "p95 Latency",
                    "refId": "A"
                }
            ]
        }
    ],
