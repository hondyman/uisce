cubes:
  - name: test_context
    sql_table: "{{ CUBE }}_{{ COMPILE_CONTEXT.securityContext.tenant_id | default('default') }}.data"
    data_source: default

    joins:
      - name: related
        sql: "{CUBE}.id = related.{CUBE}_id"
        relationship: one_to_many

    dimensions:
      - name: id
        sql: "{CUBE}.id"
        type: number
        primary_key: true

      - name: name
        sql: "{CUBE}.name"
        type: string

    measures:
      - name: count
        type: count

    # Test SQL_UTILS
    dimensions:
      - name: created_at_converted
        sql: "{{ convertTz('created_at') }}"
        type: time

      - name: updated_at_converted
        sql: "{{ convertTz('updated_at') }}"
        type: time

    # Test COMPILE_CONTEXT
    sql_table: "{{ CUBE }}_{{ COMPILE_CONTEXT.securityContext.tenant_id | default('default') }}.data"
