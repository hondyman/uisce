# ============================================
# Rebalancing System - Docker Environment
# ============================================

# PostgreSQL
POSTGRES_DB=portfolio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Hasura
HASURA_SECRET=secret
HASURA_JWT_SECRET='{"type":"HS256","key":"your-256-bit-secret-key-here"}'

# Temporal
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233

# Kafka / Redpanda
KAFKA_BROKERS=redpanda:9092

# Redis
REDIS_URL=redis://redis:6379

# External APIs
XAI_API_KEY=sk-your-xai-api-key-here
FINNHUB_API_KEY=your-finnhub-api-key-here

# Frontend Environment (Build Args)
VITE_API_URL=http://localhost:8090
VITE_GRAPHQL_URL=http://localhost:8080/v1/graphql
VITE_TEMPORAL_UI_URL=http://localhost:8081

# Optional: Application Configuration
NODE_ENV=development
LOG_LEVEL=info
ENABLE_TELEMETRY=false

# Optional: Performance Tuning
POSTGRES_POOL_SIZE=20
REDIS_CACHE_TTL=300
API_TIMEOUT=30000

# Optional: Feature Flags
ENABLE_DRY_RUN=true
ENABLE_TAX_HARVESTING=true
ENABLE_WASH_SALE_CHECK=true
MAX_TRADES_PER_REBALANCE=100
