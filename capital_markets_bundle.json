{
  "bundle_id": "capital_markets_bundle",
  "domain": "capital_markets",
  "audience": ["trader", "portfolio_manager", "risk_manager"],
  "version": "v1.0.0",
  "owner": "patrick",
  "tags": ["trading", "portfolio", "risk", "performance", "market_risk"],
  "functions": [
    {
      "name": "SUMX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns the sum of an expression evaluated over a table."
    },
    {
      "name": "AVERAGEX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Calculates the average of an expression evaluated over a table."
    },
    {
      "name": "FILTER",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns a table that represents a subset of another table or expression."
    },
    {
      "name": "DISTINCTCOUNT",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Counts the number of distinct values in a column."
    },
    {
      "name": "DIVIDE",
      "class": "DAX-Logical",
      "badge": "🟧",
      "description": "Performs division and returns alternate result or BLANK() on division by 0."
    },
    {
      "name": "STDEVX.P",
      "class": "DAX-Financial",
      "badge": "🟩",
      "description": "Returns the standard deviation of an expression evaluated over a table."
    },
    {
      "name": "SQRT",
      "class": "DAX-Logical",
      "badge": "🟧",
      "description": "Returns the square root of a number."
    }
  ],
  "metrics": [
    {
      "node_id": "value_at_risk",
      "category": "market_risk",
      "description": "Maximum expected loss over a specific time period at a given confidence level.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "STDEVX.P({returns_table}, {portfolio_returns}) * SQRT({holding_period}) * {confidence_factor}",
        "arguments": {
          "returns_table": "table:portfolio_returns",
          "portfolio_returns": "field:daily_return",
          "holding_period": "field:holding_days",
          "confidence_factor": "field:confidence_multiplier"
        }
      },
      "badge": "🟩",
      "function_class": "DAX-Financial",
      "functions_used": ["STDEVX.P", "SQRT"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "sharpe_ratio",
      "category": "risk_adjusted_performance",
      "description": "Risk-adjusted return using Sharpe Ratio.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(AVERAGEX({returns_table}, {portfolio_returns}) - {risk_free_rate}, STDEVX.P({returns_table}, {portfolio_returns}))",
        "arguments": {
          "returns_table": "table:portfolio_returns",
          "portfolio_returns": "field:daily_return",
          "risk_free_rate": "field:risk_free_rate"
        }
      },
      "badge": "🟧",
      "function_class": "DAX-Logical",
      "functions_used": ["AVERAGEX", "STDEVX.P", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "portfolio_turnover",
      "category": "trading_activity",
      "description": "Portfolio turnover ratio measuring trading activity.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({trades_table}, ABS({trade_amount})), 2 * AVERAGEX({portfolio_table}, {portfolio_value}))",
        "arguments": {
          "trades_table": "table:trades",
          "trade_amount": "field:transaction_amount",
          "portfolio_table": "table:portfolio_values",
          "portfolio_value": "field:total_value"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "AVERAGEX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "beta_coefficient",
      "category": "market_risk",
      "description": "Portfolio beta relative to market benchmark.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({correlation_table}, ({portfolio_return} - {portfolio_mean}) * ({market_return} - {market_mean})), SUMX({correlation_table}, POWER({market_return} - {market_mean}, 2)))",
        "arguments": {
          "correlation_table": "table:portfolio_market_returns",
          "portfolio_return": "field:portfolio_return",
          "portfolio_mean": "field:portfolio_average",
          "market_return": "field:market_return",
          "market_mean": "field:market_average"
        }
      },
      "badge": "🟧",
      "function_class": "DAX-Logical",
      "functions_used": ["SUMX", "DIVIDE", "POWER"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "tracking_error",
      "category": "active_risk",
      "description": "Standard deviation of active returns vs. benchmark.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "STDEVX.P({active_returns_table}, {active_return})",
        "arguments": {
          "active_returns_table": "table:active_returns",
          "active_return": "field:active_return"
        }
      },
      "badge": "🟩",
      "function_class": "DAX-Financial",
      "functions_used": ["STDEVX.P"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "information_ratio",
      "category": "active_performance",
      "description": "Risk-adjusted active return.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(AVERAGEX({active_returns_table}, {active_return}), STDEVX.P({active_returns_table}, {active_return}))",
        "arguments": {
          "active_returns_table": "table:active_returns",
          "active_return": "field:active_return"
        }
      },
      "badge": "🟧",
      "function_class": "DAX-Logical",
      "functions_used": ["AVERAGEX", "STDEVX.P", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "maximum_drawdown",
      "category": "risk",
      "description": "Largest peak-to-trough decline in portfolio value.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "MINX({drawdown_table}, {drawdown_amount})",
        "arguments": {
          "drawdown_table": "table:rolling_drawdowns",
          "drawdown_amount": "field:drawdown"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["MINX"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "sortino_ratio",
      "category": "downside_risk",
      "description": "Return relative to downside volatility.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(AVERAGEX({returns_table}, {portfolio_return}) - {risk_free_rate}, STDEVX.P(FILTER({returns_table}, {portfolio_return} < {risk_free_rate}), {portfolio_return}))",
        "arguments": {
          "returns_table": "table:portfolio_returns",
          "portfolio_return": "field:daily_return",
          "risk_free_rate": "field:risk_free_rate"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["AVERAGEX", "STDEVX.P", "FILTER", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "alpha_coefficient",
      "category": "active_performance",
      "description": "Excess return over expected return given beta.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "AVERAGEX({returns_table}, {portfolio_return}) - ({risk_free_rate} + {beta} * (AVERAGEX({market_table}, {market_return}) - {risk_free_rate}))",
        "arguments": {
          "returns_table": "table:portfolio_returns",
          "portfolio_return": "field:daily_return",
          "risk_free_rate": "field:risk_free_rate",
          "beta": "calc:beta_coefficient",
          "market_table": "table:market_returns",
          "market_return": "field:daily_return"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["AVERAGEX"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "win_rate",
      "category": "trading_performance",
      "description": "Percentage of profitable trades.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(DISTINCTCOUNT(FILTER({trades_table}, {trade_pnl} > 0), {trade_id}), DISTINCTCOUNT({trades_table}, {trade_id}))",
        "arguments": {
          "trades_table": "table:trades",
          "trade_pnl": "field:profit_loss",
          "trade_id": "field:id"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["DISTINCTCOUNT", "FILTER", "DIVIDE"],
      "governance": { "status": "draft" }
    }
  ]
}
