# ----------------------------------------------------------------------------
# Database Configuration
# IMPORTANT: PostgreSQL is NOT run inside Docker in this stack.
# Point DB_HOST at your native (host-installed) Postgres server so that
# users / clients / tenants persist across `docker compose down`.
# Examples:
#   DB_HOST=100.84.50.65     # native Postgres on the Tailscale network
#   DB_HOST=localhost        # native Postgres on this Mac
#   DB_HOST=db               # ONLY if you run a Postgres container named `db`
# ----------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=alpha
DB_HOST=100.84.50.65
DB_PORT=5432

# Constructed DATABASE_URL - docker-compose interpolates ${DB_HOST} etc.
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=disable

# Hasura Configuration
HASURA_ADMIN_SECRET=your_admin_secret_here
JWT_SECRET=your_jwt_secret_key_here_should_be_at_least_32_characters

# GraphQL Backend Feature Flag (hasura | gqlgen)
UI_GRAPHQL_BACKEND=hasura
# Frontend GraphQL endpoint configuration (Vite)
# When UI_GRAPHQL_BACKEND=gqlgen, set this to the scaffold route:
# VITE_GRAPHQL_ENDPOINT=http://localhost:8001/api/gqlgen/scaffold
VITE_GRAPHQL_ENDPOINT=http://localhost:8001/api/graphql

# AI/LLM Configuration (Phase 3)
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# Phase 4: AI Holiday Intelligence & Advanced Features Configuration
# ============================================================================

# OpenAI API Configuration
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7
OPENAI_REQUEST_TIMEOUT_SECS=30
OPENAI_RETRY_ATTEMPTS=3

# Holiday AI Service Settings
AI_HOLIDAY_CACHE_TTL_HOURS=24
AI_HOLIDAY_MAX_SUGGESTIONS=10
AI_HOLIDAY_CONFIDENCE_THRESHOLD=0.75
AI_CONFLECT_DETECTION_ENABLED=true

# Cost Tracking (Phase 4+)
AI_COST_TRACKING_ENABLED=true
AI_MONTHLY_TOKEN_BUDGET=100000
AI_ALERT_THRESHOLD_PERCENT=80

# Temporal Workflow Configuration (Phase 4)
TEMPORAL_NAMESPACE=calendar-service
TEMPORAL_TASK_QUEUE=holiday-ai-tasks
TEMPORAL_MAX_CONCURRENT_WORKFLOWS=50

# Monitoring & Observability (Phase 4)
AI_METRICS_COLLECTION_ENABLED=true
AI_METRICS_CACHE_TTL_MINUTES=5
PROMETHEUS_AI_METRICS_PORT=9090

# Development Settings
DEV_ALLOW_UNAUTH_FABRIC=true
DEV_ALLOW_UNAUTH_MODELS=true
DEV_ALLOW_UNAUTH_XUSER=true
ENABLE_SECURITY=false

# Local runtime helpers
# If you run a Postgres instance on your host and do NOT want the compose stack to start its own postgres,
# set USE_LOCAL_POSTGRES=true. This will prevent the `postgres` container from being started and will make
# services use the host DB (DB_HOST above).
USE_LOCAL_POSTGRES=true

# Convenience flag for starting only the primary backend container (skips building many microservices).
# Use with: ONLY_BACKEND=true ./docker-start.sh backend
ONLY_BACKEND=false

# Messaging / streaming
KAFKA_BROKERS=localhost:9092

# Redis Cache (Availability caching)
REDIS_URL=redis:6379
REDIS_PREFIX=calendar
REDIS_CACHE_TTL=3600
CACHE_ENABLED=true

# Security services
PORT=8080
