# Example .env file for remote deploy
# Copy this to .env.remote and set values before running deploy scripts or CI.

# Remote host (Tailscale IP or DNS)
REMOTE_HOST=100.84.126.19

# Secrets (do NOT commit actual secrets)
HASURA_GRAPHQL_ADMIN_SECRET=replace_with_strong_secret
HASURA_ADMIN_SECRET=${HASURA_GRAPHQL_ADMIN_SECRET}

# Image overrides (pin to explicit versions for reproducible deploys)
# Replace the :latest defaults with known-good tags before deploy.
REDPANDA_IMAGE=docker.redpanda.com/redpandadata/redpanda:latest
TEMPORAL_IMAGE=temporalio/auto-setup:latest
STARROCKS_FE_IMAGE=starrocks/fe-ubuntu:latest
STARROCKS_BE_IMAGE=starrocks/be-ubuntu:latest
TRINO_IMAGE=trinodb/trino:latest

# Optional overrides
HASURA_URL=http://${REMOTE_HOST}:20005
POSTGRES_URL=postgres://postgres:postgres@${REMOTE_HOST}:5432/alpha
