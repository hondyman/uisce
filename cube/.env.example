
# Cube.dev Configuration

# General
CUBEJS_DEV_MODE=true
CUBEJS_API_SECRET=supersecret

# StarRocks Data Source (Historical/Lakehouse Data)
# Protocol: MySQL compatible
CUBEJS_DB_STARROCKS_TYPE=mysql
CUBEJS_DB_STARROCKS_HOST=starrocks-fe
CUBEJS_DB_STARROCKS_PORT=9030
CUBEJS_DB_STARROCKS_USER=root
CUBEJS_DB_STARROCKS_PASS=
CUBEJS_DB_STARROCKS_DB=demo

# RisingWave Data Source (Real-Time Data)
# Protocol: PostgreSQL wire-compatible
CUBEJS_DB_RISINGWAVE_TYPE=postgres
CUBEJS_DB_RISINGWAVE_HOST=risingwave-frontend
CUBEJS_DB_RISINGWAVE_PORT=4566
CUBEJS_DB_RISINGWAVE_USER=root
CUBEJS_DB_RISINGWAVE_PASS=
CUBEJS_DB_RISINGWAVE_DB=dev

