actions: []

custom_types:
  scalars: []
  enums:
  - name: Direction
    values:
    - OUTBOUND
    - INBOUND
  - name: EdgeType
    values:
    - REFERENCE
    - COMPOSITION
    - ASSOCIATION
    - FOREIGN_KEY
  objects:
  - name: BusinessObject
    fields:
    - name: id
      type: ID!
    - name: name
      type: String!
    - name: kind
      type: String!
    - name: description
      type: String

  - name: RelatedObject
    fields:
    - name: edgeId
      type: ID!
    - name: direction
      type: Direction!
    - name: edgeType
      type: EdgeType!
    - name: cardinality
      type: String
    - name: source
      type: BusinessObject!
    - name: target
      type: BusinessObject!

  - name: RelationshipSuggestion
    fields:
    - name: id
      type: ID!
    - name: title
      type: String!
    - name: description
      type: String!
    - name: sourceEntity
      type: String!
    - name: targetEntity
      type: String!
    - name: edgeType
      type: EdgeType!
    - name: cardinality
      type: String
    - name: fkColumn
      type: String
    - name: confidence
      type: Float!
    - name: reasoning
      type: String!
    - name: dismissible
      type: Boolean!

  - name: ApplyRelationshipResponse
    fields:
    - name: edgeId
      type: ID!
    - name: direction
      type: Direction!
    - name: edgeType
      type: EdgeType!
    - name: cardinality
      type: String
    - name: source
      type: BusinessObject!
    - name: target
      type: BusinessObject!

  - name: DismissSuggestionResponse
    fields:
    - name: status
      type: String!
