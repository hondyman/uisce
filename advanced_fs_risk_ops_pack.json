        }
      },
      "badge": "🟧",
      "function_class": "DAX-Logical",
      "functions_used": ["DIVIDE"],
      "governance": { "status": "draft" }
    },
    {
      "node_id": "cost_per_transaction",
      "category": "operations",
      "description": "Total operations cost divided by transaction volume.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE({total_ops_cost}, {transaction_volume})",
        "arguments": {
          "total_ops_cost": "field:total_ops_cost",
          "transaction_volume": "field:transaction_volume"
        }
      },
      "badge": "🟧",
      "function_class": "DAX-Logical",
      "functions_used": ["DIVIDE"],
      "governance": { "status": "draft" }
    },
    {
      "node_id": "multi_factor_attribution",
      "category": "performance_attribution",
      "description": "Performance attribution across style, sector, currency, duration, credit factors.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "SUMX({attribution_factors}, {factor_contribution})",
        "arguments": {
          "attribution_factors": "table:attribution_factors",
          "factor_contribution": "field:factor_contribution"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX"],
      "governance": { "status": "draft" }
    },
    {
      "node_id": "currency_impact",
      "category": "performance_attribution",
      "description": "Currency contribution to total return.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "{hedged_return} - {unhedged_return}",
        "arguments": {
          "hedged_return": "calc:hedged_portfolio_return",
          "unhedged_return": "calc:unhedged_portfolio_return"
        }
      },
      "badge": "🟧",
      "function_class": "DAX-Logical",
      "functions_used": ["SUBTRACT"],
      "governance": { "status": "draft" }
    },
    {
      "node_id": "hedging_effectiveness",
      "category": "performance_attribution",
      "description": "Hedge P/L divided by exposure P/L.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE({hedge_pnl}, {exposure_pnl})",
        "arguments": {
          "hedge_pnl": "field:hedge_pnl",
          "exposure_pnl": "field:exposure_pnl"
        }
      },
      "badge": "🟧",
      "function_class": "DAX-Logical",
      "functions_used": ["DIVIDE"],
      "governance": { "status": "draft" }
    },
    {
      "node_id": "liquidity_premium_capture",
      "category": "performance_attribution",
      "description": "Excess return from illiquid assets.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "{illiquid_return} - {liquid_benchmark_return}",
        "arguments": {
          "illiquid_return": "calc:illiquid_portfolio_return",
          "liquid_benchmark_return": "calc:liquid_benchmark_return"
        }
      },
      "badge": "🟧",
      "function_class": "DAX-Logical",
