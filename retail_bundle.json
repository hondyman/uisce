{
  "bundle_id": "retail_bundle",
  "domain": "retail",
  "audience": ["retail_manager", "analyst", "executive"],
  "version": "v1.0.0",
  "owner": "patrick",
  "tags": ["retail", "sales", "inventory", "customer"],
  "functions": [
    {
      "name": "SUMX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns the sum of an expression evaluated over a table."
    },
    {
      "name": "AVERAGEX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Calculates the average of an expression evaluated over a table."
    },
    {
      "name": "FILTER",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns a table that represents a subset of another table or expression."
    },
    {
      "name": "DIVIDE",
      "class": "DAX-Logical",
      "badge": "🟧",
      "description": "Performs division and returns alternate result or BLANK() on division by 0."
    },
    {
      "name": "MINX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns the minimum value of an expression evaluated over a table."
    },
    {
      "name": "MAXX",
      "class": "DAX-Iterator",
      "badge": "🟨",
      "description": "Returns the maximum value of an expression evaluated over a table."
    }
  ],
  "metrics": [
    {
      "node_id": "sales_per_square_foot",
      "category": "store_performance",
      "description": "Annual sales revenue per square foot of retail space.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({sales_table}, {annual_sales}), SUMX({stores_table}, {square_footage}))",
        "arguments": {
          "sales_table": "table:store_sales",
          "annual_sales": "field:revenue",
          "stores_table": "table:store_dimensions",
          "square_footage": "field:area_sqft"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "inventory_turnover_ratio",
      "category": "inventory_management",
      "description": "Number of times inventory is sold and replaced over a period.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({sales_table}, {cost_of_goods_sold}), AVERAGEX({inventory_table}, {average_inventory}))",
        "arguments": {
          "sales_table": "table:sales_data",
          "cost_of_goods_sold": "field:cogs",
          "inventory_table": "table:inventory_levels",
          "average_inventory": "field:value"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "AVERAGEX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "customer_acquisition_cost",
      "category": "marketing_efficiency",
      "description": "Average cost to acquire a new customer.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({marketing_table}, {marketing_spend}), SUMX({customers_table}, {new_customers}))",
        "arguments": {
          "marketing_table": "table:marketing_expenses",
          "marketing_spend": "field:amount",
          "customers_table": "table:new_customer_acquisitions",
          "new_customers": "field:count"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "gross_margin_percentage",
      "category": "profitability",
      "description": "Gross profit as a percentage of sales revenue.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({sales_table}, {gross_profit}), SUMX({sales_table}, {total_sales}))",
        "arguments": {
          "sales_table": "table:sales_revenue",
          "gross_profit": "field:profit",
          "total_sales": "field:revenue"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "average_transaction_value",
      "category": "sales_performance",
      "description": "Average dollar amount per customer transaction.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({transactions_table}, {transaction_amount}), SUMX({transactions_table}, {transaction_count}))",
        "arguments": {
          "transactions_table": "table:customer_transactions",
          "transaction_amount": "field:amount",
          "transaction_count": "field:count"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "customer_lifetime_value",
      "category": "customer_value",
      "description": "Total revenue expected from a customer over their relationship.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "SUMX({customers_table}, {average_purchase_value} * {purchase_frequency} * {customer_lifespan})",
        "arguments": {
          "customers_table": "table:customer_segments",
          "average_purchase_value": "field:avg_value",
          "purchase_frequency": "field:frequency",
          "customer_lifespan": "field:years"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "shrinkage_rate",
      "category": "loss_prevention",
      "description": "Percentage of inventory lost to theft, damage, or error.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({shrinkage_table}, {shrinkage_amount}), SUMX({inventory_table}, {total_inventory_value}))",
        "arguments": {
          "shrinkage_table": "table:inventory_shrinkage",
          "shrinkage_amount": "field:value",
          "inventory_table": "table:inventory_value",
          "total_inventory_value": "field:amount"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "conversion_rate",
      "category": "store_traffic",
      "description": "Percentage of store visitors who make a purchase.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({purchases_table}, {purchase_count}), SUMX({traffic_table}, {visitor_count}))",
        "arguments": {
          "purchases_table": "table:store_purchases",
          "purchase_count": "field:count",
          "traffic_table": "table:store_traffic",
          "visitor_count": "field:count"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "employee_productivity",
      "category": "staff_efficiency",
      "description": "Sales revenue per employee hour worked.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({sales_table}, {total_sales}), SUMX({labor_table}, {total_hours}))",
        "arguments": {
          "sales_table": "table:store_sales",
          "total_sales": "field:revenue",
          "labor_table": "table:employee_hours",
          "total_hours": "field:hours"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "DIVIDE"],
      "governance": { "status": "golden" }
    },
    {
      "node_id": "seasonal_sales_index",
      "category": "seasonal_analysis",
      "description": "Sales performance relative to seasonal average.",
      "financial_calc": {
        "type": "dax_formula",
        "formula": "DIVIDE(SUMX({current_table}, {current_sales}), AVERAGEX({seasonal_table}, {seasonal_average}))",
        "arguments": {
          "current_table": "table:current_period_sales",
          "current_sales": "field:revenue",
          "seasonal_table": "table:seasonal_averages",
          "seasonal_average": "field:avg_revenue"
        }
      },
      "badge": "🟨",
      "function_class": "DAX-Iterator",
      "functions_used": ["SUMX", "AVERAGEX", "DIVIDE"],
      "governance": { "status": "golden" }
    }
  ]
}
