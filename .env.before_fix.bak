# Database Configuration - Update these values for your local PostgreSQL
DB_USER=postgres
DB_PASSWORD=
DB_NAME=semlayer
DB_HOST=host.docker.internal
DB_PORT=5432

# Constructed DATABASE_URL - Update with your actual credentials  
DATABASE_URL=postgresql://postgres@host.docker.internal:5432/semlayer?sslmode=disable

# DSN for backend service - standard format with explicit dbname parameter
DSN=host=host.docker.internal port=5432 user=postgres dbname=semlayer sslmode=disable

# Hasura Configuration
HASURA_ADMIN_SECRET=development_admin_secret_123
JWT_SECRET=development_jwt_secret_key_that_is_long_enough_for_hasura_requirements

# Development Settings
DEV_ALLOW_UNAUTH_FABRIC=true
DEV_ALLOW_UNAUTH_MODELS=true
DEV_ALLOW_UNAUTH_XUSER=true
ENABLE_SECURITY=false
